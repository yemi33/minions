{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016RWiGg9estUgfaPykwyTt7","type":"tool_result","content":"     1→import { useEffect } from 'react';\n     2→import { useAtomValue, useSetAtom } from 'jotai';\n     3→import { chatModeAtom, chatModeDispatchAtom } from '../../../atoms/chatModeAtoms';\n     4→import type { ChatModeData } from '../../../atoms/chatModeAtoms';\n     5→\n     6→export type { ChatModeData };\n     7→\n     8→export type ChatModeActions = {\n     9→  pin: () => void;\n    10→  collapse: () => void;\n    11→  expand: () => void;\n    12→  fill: () => void;\n    13→  empty: () => void;\n    14→};\n    15→\n    16→export type ChatModeResult = {\n    17→  mode: ChatModeData;\n    18→  actions: ChatModeActions;\n    19→};\n    20→\n    21→/**\n    22→ * Hook to read chat mode state and get action dispatchers.\n    23→ * State is shared via Jotai atoms - no Context provider needed.\n    24→ */\n    25→export function useChatMode(): ChatModeResult {\n    26→  const mode = useAtomValue(chatModeAtom);\n    27→  const dispatch = useSetAtom(chatModeDispatchAtom);\n    28→\n    29→  // Reset state on unmount\n    30→  useEffect(() => {\n    31→    return () => {\n    32→      dispatch({ type: 'reset' });\n    33→    };\n    34→  }, [dispatch]);\n    35→\n    36→  return {\n    37→    mode,\n    38→    actions: {\n    39→      pin: () => dispatch({ type: 'pin' }),\n    40→      collapse: () => dispatch({ type: 'collapse' }),\n    41→      expand: () => dispatch({ type: 'expand' }),\n    42→      fill: () => dispatch({ type: 'fill' }),\n    43→      empty: () => dispatch({ type: 'empty' })\n    44→    }\n    45→  };\n    46→}\n    47→"}]},"parent_tool_use_id":"toolu_01XrfUS8UeV8YDsw48sFBkQR","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"a816e7b1-9a86-4c42-84fc-7349ed67cb90"}
