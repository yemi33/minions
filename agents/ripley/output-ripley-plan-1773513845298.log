{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ADCDHy7HTyHN1YqsRE4mNz","type":"tool_result","content":"     1→import type { IContainerRuntime } from '@fluidframework/container-runtime-definitions/legacy';\n     2→import { AttachState } from '@fluidframework/container-definitions';\n     3→\n     4→import type { IAnnotation, IOperation } from '@augloop/types-core';\n     5→import { AddOperation, DeleteOperation, MoveOperation, SchemaObject, UpdateOperation } from '@augloop/types-core';\n     6→import type { ISession } from '@augloop/runtime-client';\n     7→import { OfficeBohemiaSession } from './OfficeBohemiaSession';\n     8→import {\n     9→  LazyInitializedLogger,\n    10→  NamespaceLoggerAdapter,\n    11→  sendDeprecatedEvent,\n    12→  sendErrorEvent,\n    13→  sendTelemetryEvent\n    14→} from '@fluidx/telemetry';\n    15→import { Deferred, getSpoId, getFluidExperiencesSetting } from '@fluidx/utilities';\n    16→import type {\n    17→  ITelemetryNamespaceLogger,\n    18→  ProvideNamespaceLogger,\n    19→  ProvideResolvedUrlProvider,\n    20→  ResolvedUrlProvider,\n    21→  ProvideHostAugmentationSession\n    22→} from '@fluidx/1p-loop-types';\n    23→import type {\n    24→  AsyncProvider,\n    25→  IContainerServiceFactoryHelper,\n    26→  ProvideInternationalizationContext,\n    27→  ProvideDisposable,\n    28→  ProvideLoopTelemetrySink,\n    29→  ProvideSettingsProvider,\n    30→  ProvideTelemetryConfig,\n    31→  ProvideTokenProvider,\n    32→  Provider,\n    33→  TokenProvider,\n    34→  LoopContentNode,\n    35→  SettingsProvider,\n    36→  AugmentationSessionContext,\n    37→  ProvideAugmentationSessionContext,\n    38→  TokenRequestOptions\n    39→} from '@fluidx/loop-types';\n    40→\n    41→import type { IAppInfo } from './AppInfo';\n    42→import { getAppInfo } from './AppInfo';\n    43→import { AugLoopLogger } from './AugLoopLogger';\n    44→import { AugLoopRuntimeManager } from './AugLoopRuntimeManager';\n    45→import type { IVersionedDataRequest, ProvideAugmentationSession } from './AugmentationSession';\n    46→import type {\n    47→  IVersionedData,\n    48→  IVersionedDataData,\n    49→  VersionedAnnotationActivation,\n    50→  VersionedDataCallback\n    51→} from './IVersionedData';\n    52→import type { IResponse } from '@augloop/session-protocol';\n    53→import type { ProvideAugLoopRuntimeProvider } from './AugLoopRuntimeProvider';\n    54→import { getAugLoopFlights, getTokenForAugLoop } from './AugLoopUtils';\n    55→import { getAugLoopEditorFlights } from './ContextIQAugLoopFlights';\n    56→\n    57→// TODO remove these type declarations once ProvideEditorContext is moved to a shared location\n    58→// to avoid circular dependencies between fluidx/augloop and fluidx/contextiq\n    59→// https://office.visualstudio.com/DefaultCollection/OC/_workitems/edit/8281491\n    60→interface ProvideCIQEditorSettings {\n    61→  readonly CIQEditorSettings: CIQEditorSettings;\n    62→}\n    63→type CIQEditorSettings = ProvideCIQEditorSettings & {\n    64→  /**\n    65→   * If implemented, this method will be called to modify the flights to track for Editor\n    66→   * @param flights Editor/Augloop flights\n    67→   * @param settingsProvider Fluid settings provider\n    68→   * @returns modified flights\n    69→   */\n    70→  modifyFlightsToTrack?(flights: string[], settingsProvider?: SettingsProvider): string[];\n    71→};\n    72→\n    73→/**\n    74→ * AugLoopComponent handles data binding with other components.\n    75→ * The class consumes changes in tile data from the components and pushes back any augloop results (if any)\n    76→ */\n    77→export class AugLoopComponent\n    78→  extends OfficeBohemiaSession\n    79→  implements ProvideAugmentationSession, ProvideAugmentationSessionContext, ProvideDisposable, ISession\n    80→{\n    81→  override get session(): ISession | undefined {\n    82→    return this.#augLoopRuntimeManager;\n    83→  }\n    84→\n    85→  override get sessionPromise(): Promise<ISession> {\n    86→    return this.#getAugLoopRuntimeManager();\n    87→  }\n    88→\n    89→  public get AugmentationSession(): this {\n    90→    return this;\n    91→  }\n    92→\n    93→  public get AugmentationSessionContext(): AugmentationSessionContext {\n    94→    return this;\n    95→  }\n    96→\n    97→  /**\n    98→   * Augloop Component constructor\n    99→   * @param providers DI providers\n   100→   * @param runtime container runtime - this should never be undefined for production apps\n   101→   * @param spoId provides a way to supply the spoId directly when available instead of getting it from the runtime\n   102→   */\n   103→  constructor(\n   104→    private readonly providers: AsyncProvider<\n   105→      ProvideNamespaceLogger &\n   106→        ProvideInternationalizationContext &\n   107→        ProvideSettingsProvider &\n   108→        ProvideTokenProvider &\n   109→        ProvideAugLoopRuntimeProvider &\n   110→        ProvideLoopTelemetrySink &\n   111→        ProvideTelemetryConfig &\n   112→        ProvideCIQEditorSettings &\n   113→        ProvideResolvedUrlProvider &\n   114→        ProvideHostAugmentationSession\n   115→    >,\n   116→    runtime?: IContainerRuntime,\n   117→    spoId?: string\n   118→  ) {\n   119→    super();\n   120→    this.#logger = new LazyInitializedLogger(this.#loggerPromise);\n   121→\n   122→    this.#appInfoPromise = Promise.all([this.providers.SettingsProvider, this.providers.TelemetryConfig]).then(\n   123→      ([settingsProvider, telemetryConfig]) => {\n   124→        return getAppInfo(settingsProvider, telemetryConfig);\n   125→      }\n   126→    );\n   127→\n   128→    this.initialize(runtime, spoId);\n   129→  }\n   130→\n   131→  /**\n   132→   * Maps component source types to callbacks.\n   133→   * @deprecated Use annotationResultCallbacks instead.\n   134→   */\n   135→  #versionedDataCallbacks = new Map<string, VersionedDataCallback>();\n   136→\n   137→  /**\n   138→   * Maps annotation types to callbacks.\n   139→   * Components should set these callbacks by sending VersionedAnnotationActivations.\n   140→   */\n   141→  #annotationResultCallbacks = new Map<string, VersionedDataCallback[]>();\n   142→\n   143→  /**\n   144→   * The types of AugLoop annotations that this component supports and subscribes to.\n   145→   * These are annotations that can be shared with coauthors because they are not specific to a given user,\n   146→   * as opposed to personalizedAnnotationTypes, which cannot be shared with coauthors.\n   147→   */\n   148→  #annotationTypes: string[] = [];\n   149→\n   150→  /**\n   151→   * The types of AugLoop annotations from personalized scenarios that this component supports and subscribes to.\n   152→   * These annotations cannot be shared with coauthors because they are specific to a given user, as opposed to\n   153→   * annotationTypes, which can be shared with coauthors.\n   154→   */\n   155→  #personalizedAnnotationTypes: string[] = [];\n   156→\n   157→  /**\n   158→   * The adapter between AugLoopComponent and the AugLoop runtime that has a session initialized.\n   159→   */\n   160→  #augLoopRuntimeManager?: AugLoopRuntimeManager;\n   161→\n   162→  /**\n   163→   * A logger instance.\n   164→   */\n   165→  #logger: ITelemetryNamespaceLogger & Provider<ProvideDisposable>;\n   166→\n   167→  #loggerPromise = new Deferred<ITelemetryNamespaceLogger | undefined>();\n   168→\n   169→  /**\n   170→   * A logger instance for the AugLoop client runtime.\n   171→   */\n   172→  #augLoopLogger?: AugLoopLogger;\n   173→\n   174→  /**\n   175→   * App info for the AL runtime and telemetry.\n   176→   */\n   177→  #appInfoPromise: Promise<IAppInfo>;\n   178→\n   179→  /**\n   180→   * Default content locale\n   181→   */\n   182→  #defaultContentLocale?: string;\n   183→\n   184→  #spoIdPromise = new Deferred<string | undefined>();\n   185→\n   186→  /**\n   187→   * Initialize AugLoopComponent by initializing the AugLoop runtime manager, getting the data binding service from the\n   188→   * container, and registering the data binding between other components and AugLoopComponent.\n   189→   */\n   190→  public initialize(runtime?: IContainerRuntime, spoId?: string): void {\n   191→    this.providers.NamespaceLogger?.then((namespaceLogger) => {\n   192→      this.#loggerPromise.resolve(namespaceLogger && new NamespaceLoggerAdapter('AugLoop', namespaceLogger));\n   193→    }).catch((_error: unknown) => {\n   194→      // TODO: Task 8208399: Empty catch blocks are a bad practice and should be refactored.\n   195→    });\n   196→\n   197→    if (spoId) {\n   198→      this.#setSpoId(spoId).catch((error) => {\n   199→        sendErrorEvent(this.#logger, { eventName: 'SpoIdError' }, error);\n   200→      });\n   201→    } else if (!runtime || runtime.attachState === AttachState.Attached) {\n   202→      this.#setSpoId(undefined /* spoId */, this.providers.TokenProvider, this.providers.ResolvedUrlProvider).catch(\n   203→        (error) => {\n   204→          sendErrorEvent(this.#logger, { eventName: 'SpoIdError' }, error);\n   205→        }\n   206→      );\n   207→    } else {\n   208→      runtime.once('attached', async () => {\n   209→        this.#setSpoId(undefined /* spoId */, this.providers.TokenProvider, this.providers.ResolvedUrlProvider).catch(\n   210→          (error) => {\n   211→            sendErrorEvent(this.#logger, { eventName: 'SpoIdError' }, error);\n   212→          }\n   213→        );\n   214→      });\n   215→    }\n   216→  }\n   217→\n   218→  //#region Disposable implementation\n   219→  public get Disposable(): this {\n   220→    return this;\n   221→  }\n   222→\n   223→  /**\n   224→   * Clean-up/disposal of resources\n   225→   * Use this guide https://office.visualstudio.com/OC/_git/office-bohemia?path=/docs/partner-guide/containers/HowToDisposeResources.md\n   226→   * for reference of what resources to dispose\n   227→   */\n   228→  public dispose(): void {\n   229→    this.close();\n   230→    this.#versionedDataCallbacks.clear();\n   231→    this.#annotationResultCallbacks.clear();\n   232→    this.#annotationTypes.length = 0;\n   233→    this.#personalizedAnnotationTypes.length = 0;\n   234→    this.#augLoopRuntimeManager = undefined;\n   235→    this.#augLoopLogger = undefined;\n   236→    this.#defaultContentLocale = undefined;\n   237→    this.#logger.Disposable?.dispose();\n   238→  }\n   239→  //#endregion Disposable\n   240→\n   241→  /**\n   242→   * Copy of processDataRequest, while we move consumers away to providerPattern and find a better contract\n   243→   * */\n   244→  public async processVersionedData(data: IVersionedDataRequest, customParentPath?: string[]): Promise<void> {\n   245→    // Set content locale and return\n   246→    if (data.versionedData.type === 'VersionedContentLocale') {\n   247→      this.#defaultContentLocale = data.versionedData.value.defaultContentLocale;\n   248→      return;\n   249→    }\n   250→\n   251→    // Set annotation results callback and return\n   252→    if (data.versionedData.type === 'VersionedAnnotationActivation') {\n   253→      await this.#handleVersionedAnnotationActivation(data);\n   254→      return;\n   255→    }\n   256→\n   257→    // Set annotation results callback and return\n   258→    if (data.versionedData.type === 'VersionedMessage') {\n   259→      await this.#handleVersionedMessage(data);\n   260→      return;\n   261→    }\n   262→\n   263→    // Submit content to AugLoop\n   264→    await this.#submitLastModifiedData(data, customParentPath);\n   265→    return;\n   266→  }\n   267→\n   268→  /**\n   269→   * Queries data from the producer component for submitting the last modified tile result to the runtime manager.\n   270→   */\n   271→  #submitLastModifiedData = async (data: IVersionedDataData, customParentPath?: string[]): Promise<void> => {\n   272→    const versionedData: IVersionedData = data.versionedData;\n   273→\n   274→    const runtimeManager: AugLoopRuntimeManager = await this.#getAugLoopRuntimeManager();\n   275→\n   276→    if (versionedData.componentSource) {\n   277→      this.#versionedDataCallbacks.set(versionedData.componentSource, (versionedData: IVersionedData) =>\n   278→        data.setVersionedData(versionedData)\n   279→      );\n   280→    }\n   281→\n   282→    switch (versionedData.type) {\n   283→      case 'VersionedSessionKey':\n   284→        runtimeManager.getVersionedSessionKey((versionedSessionKey) => {\n   285→          data.setVersionedData({\n   286→            type: 'VersionedSessionKey',\n   287→            value: versionedSessionKey,\n   288→            version: 0,\n   289→            id: 'VersionedSessionKey'\n   290→          });\n   291→        });\n   292→        break;\n   293→      case 'VersionedSignal':\n   294→        if (versionedData.value.canBeAnnotated) {\n   295→          /* The canBeAnnotated field is set to true when versioned signals are being used in reduce workflows. In this type of workflow, we need to attach the versioned signal to\n   296→             the data model with an add operation. This allows us to set an annotation and receive a response from augloop. However, this is not required for single item workflows,\n   297→             which still allow us to annotate a response after submitting a signal operation */\n   298→          runtimeManager.submitAddOperationForVersionedSignal(versionedData, customParentPath);\n   299→        } else {\n   300→          runtimeManager.submitSignalOperation(versionedData, customParentPath);\n   301→        }\n   302→        break;\n   303→      default:\n   304→        runtimeManager.submitLastModifiedResult(versionedData, customParentPath);\n   305→    }\n   306→  };\n   307→\n   308→  #handleVersionedAnnotationActivation = async (data: IVersionedDataData): Promise<void> => {\n   309→    const { annotationType, shareable } = data.versionedData.value as VersionedAnnotationActivation;\n   310→    if (shareable) {\n   311→      if (!this.#annotationTypes.includes(annotationType)) {\n   312→        this.#annotationTypes.push(annotationType);\n   313→      }\n   314→    } else {\n   315→      if (!this.#personalizedAnnotationTypes.includes(annotationType)) {\n   316→        this.#personalizedAnnotationTypes.push(annotationType);\n   317→      }\n   318→    }\n   319→\n   320→    // Add a callback for the given annotation type.\n   321→    // NOTE: We never need to remove callbacks. If this client becomes not leader, we will\n   322→    // release annotation types so that we no longer receive results from AL for those types.\n   323→    const isNewAnnotationType: boolean = !this.#annotationResultCallbacks.has(annotationType);\n   324→    const callbacks = this.#annotationResultCallbacks.get(annotationType) || [];\n   325→    callbacks.push((versionedData: IVersionedData) => {\n   326→      data.setVersionedData(versionedData);\n   327→    });\n   328→    this.#annotationResultCallbacks.set(annotationType, callbacks);\n   329→\n   330→    // Activate the given annotation type only if it is a new type.\n   331→    if (isNewAnnotationType) {\n   332→      try {\n   333→        await this.#activateAnnotations([annotationType]);\n   334→      } catch {\n   335→        // NOTE: Errors are handled in the activateAnnotations function.\n   336→      }\n   337→    }\n   338→  };\n   339→\n   340→  #handleVersionedMessage = async (data: IVersionedDataData): Promise<IResponse> => {\n   341→    const manager: AugLoopRuntimeManager = await this.#getAugLoopRuntimeManager();\n   342→    const response: IResponse = await manager.submitCustomMessage(data.versionedData);\n   343→    return response;\n   344→  };\n   345→\n   346→  /**\n   347→   * Close the runtime session, ending the connection to the AugLoop service.\n   348→   * This should happen when the container runtime is disposed.\n   349→   */\n   350→  public override close(): void {\n   351→    // Read and clear augLoopRuntimeManager atomically before closeSession context switch\n   352→    const manager = this.#augLoopRuntimeManager;\n   353→    this.#augLoopRuntimeManager = undefined;\n   354→\n   355→    // Close the session and then shutdown the AugLoopLogger\n   356→    if (manager) {\n   357→      this.#closeSession(manager);\n   358→    }\n   359→\n   360→    // No-op if no AugLoopLogger has been instantiated or shutdown multiple times\n   361→\n   362→    this.#augLoopLogger = undefined;\n   363→  }\n   364→\n   365→  /**\n   366→   * Get the runtime manager and activate the annotations corresponding to the given array of types.\n   367→   */\n   368→  #activateAnnotations = (annotationTypes: string[]): Promise<string[]> => {\n   369→    sendTelemetryEvent(this.#logger, { eventName: 'ActivateAugLoopAnnotations' });\n   370→\n   371→    return this.#getAugLoopRuntimeManager()\n   372→      .then((manager) => {\n   373→        return manager.activateAnnotations(annotationTypes, (result) => {\n   374→          result.forEach((versionedData: IVersionedData) => {\n   375→            // Handle mismatches between the client's list of annotation types and shareable annotations from the server\n   376→            if (versionedData.type === 'VersionedItem') {\n   377→              const body = versionedData.value.body as IAnnotation | undefined;\n   378→              // Don't log delete operations, deletes previously didn't have a body and avoided this call,\n   379→              // the event will already be logged for when the item was actually added.\n   380→              if (body && versionedData.value.operationType !== DeleteOperation.getTypeName()) {\n   381→                const typeName = SchemaObject.getTypeNameFor(body);\n   382→                const source = versionedData.value.source || 'the server';\n   383→                if (body.M_?.shareable) {\n   384→                  if (this.#personalizedAnnotationTypes.includes(typeName)) {\n   385→                    // Not an error case, but this annotation could potentially be shared with coauthors\n   386→                    sendTelemetryEvent(this.#logger, {\n   387→                      eventName: 'ShareableAnnotationResult',\n   388→                      message: `Received shareable annotation of type ${typeName} from ${source}, but the client expected it to be personalized`\n   389→                    });\n   390→                  }\n   391→                } else {\n   392→                  if (this.#annotationTypes.includes(typeName)) {\n   393→                    // This annotation cannot be shared with coauthors -- eat it and log and error\n   394→                    sendErrorEvent(\n   395→                      this.#logger,\n   396→                      { eventName: 'UnshareableAnnotationResult' },\n   397→                      new Error(\n   398→                        `Received unshareable annotation of type ${typeName} from ${source}, but the client expected it to be shareable`\n   399→                      )\n   400→                    );\n   401→                    return;\n   402→                  }\n   403→                }\n   404→              }\n   405→            }\n   406→\n   407→            // Get callback by componentSource\n   408→            if (versionedData.componentSource) {\n   409→              const callback = this.#versionedDataCallbacks.get(versionedData.componentSource);\n   410→              if (callback !== undefined) {\n   411→                callback(versionedData);\n   412→              }\n   413→            }\n   414→\n   415→            // Get callbacks by annotation type\n   416→            if (versionedData.type === 'VersionedItem') {\n   417→              const body = versionedData.value.body as IAnnotation | undefined;\n   418→              if (body) {\n   419→                // Get callbacks for annotation type and parent types, e.g.,\n   420→                // NeuralRewriteCritique will trigger NeuralRewriteCritique and Critique callbacks\n   421→                const typeNames: string[] = SchemaObject.getAllTypesFor(body);\n   422→                for (const typeName of typeNames) {\n   423→                  const callbacks = this.#annotationResultCallbacks.get(typeName);\n   424→                  if (callbacks !== undefined) {\n   425→                    for (const callback of callbacks) {\n   426→                      callback(versionedData);\n   427→                    }\n   428→                  }\n   429→                }\n   430→              }\n   431→            }\n   432→          });\n   433→        });\n   434→      })\n   435→      .catch((error) => {\n   436→        sendErrorEvent(this.#logger, { eventName: 'ActivateAugLoopAnnotationsError' }, error);\n   437→        return [];\n   438→      });\n   439→  };\n   440→\n   441→  /**\n   442→   * Close the session corresponding to the given runtime manager promise.\n   443→   */\n   444→  #closeSession = (manager: AugLoopRuntimeManager): void => {\n   445→    sendTelemetryEvent(this.#logger, { eventName: 'CloseAugLoopSession' });\n   446→    manager.closeSession();\n   447→  };\n   448→\n   449→  /**\n   450→   * Get a promise that resolves with an AugLoopRuntimeManager after initialization.\n   451→   */\n   452→  #getAugLoopRuntimeManager = (): Promise<AugLoopRuntimeManager> => {\n   453→    if (!this.#augLoopRuntimeManagerPromise) {\n   454→      this.#augLoopRuntimeManagerPromise = this.#initializeAugLoopRuntimeManager();\n   455→    }\n   456→    return this.#augLoopRuntimeManagerPromise;\n   457→  };\n   458→\n   459→  /**\n   460→   * Instantiate and initialize an AugLoopRuntimeManager, and return a Promise that resolves with the\n   461→   * AugLoopRuntimeManager when finished.\n   462→   */\n   463→  #initializeAugLoopRuntimeManager = async (): Promise<AugLoopRuntimeManager> => {\n   464→    // Callbacks capturing \"this\" end up capturing the entire component, which causes them to leak\n   465→    // due to issue 7682454. To avoid this, we capture only the values we need, reducing the size of the\n   466→    // leak until that issue is resolved. This is also a good practice in general, reducing the exposure\n   467→    // of the closure.\n   468→    const [\n   469→      internationalizationContext,\n   470→      telemetryConfig,\n   471→      tokenProvider,\n   472→      settingsProvider,\n   473→      augLoopRuntimeProvider,\n   474→      editorSettings,\n   475→      hostAugmentationSessionProvider,\n   476→      appInfo\n   477→    ] = await Promise.all([\n   478→      this.providers.InternationalizationContext,\n   479→      this.providers.TelemetryConfig,\n   480→      this.providers.TokenProvider,\n   481→      this.providers.SettingsProvider,\n   482→      this.providers.AugLoopRuntimeProvider,\n   483→      this.providers.CIQEditorSettings,\n   484→      this.providers.HostAugmentationSessionProvider,\n   485→      this.#appInfoPromise\n   486→    ]);\n   487→\n   488→    let editorFlights = getAugLoopEditorFlights(settingsProvider);\n   489→    if (editorSettings?.modifyFlightsToTrack) {\n   490→      editorFlights = editorSettings.modifyFlightsToTrack(editorFlights, settingsProvider);\n   491→    }\n   492→\n   493→    performance.mark('SpoIdDelayStart');\n   494→    let spoId = undefined;\n   495→    try {\n   496→      spoId = await this.#spoIdPromise;\n   497→    } catch (e) {\n   498→      sendErrorEvent(this.#logger, { eventName: 'SpoIdError' }, e);\n   499→    }\n   500→    performance.mark('SpoIDDelayEnd');\n   501→    let measure = performance.measure('SpoIdDelay', 'SpoIdDelayStart', 'SpoIDDelayEnd') as PerformanceEntry | undefined;\n   502→    if (!measure) {\n   503→      measure = performance.getEntriesByName('SpoIdDelay')[0] as PerformanceEntry | undefined;\n   504→    }\n   505→\n   506→    sendTelemetryEvent(this.#logger, {\n   507→      eventName: 'SpoIDDelay',\n   508→      spoIdDelay: measure?.duration\n   509→    });\n   510→\n   511→    cons