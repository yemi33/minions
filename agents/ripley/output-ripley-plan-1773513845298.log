{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014XN4KeA4u3VcELLdikVZRy","type":"tool_result","content":"     1→{\n     2→\t\"name\": \"bebop-prototype\",\n     3→\t\"private\": true,\n     4→\t\"version\": \"0.0.0\",\n     5→\t\"type\": \"module\",\n     6→\t\"scripts\": {\n     7→\t\t\"setup\": \"npm run setRegistry && npm run auth && npm install\",\n     8→\t\t\"setRegistry\": \"npm exec --yes cross-env npm_config_registry=https://registry.npmjs.org\",\n     9→\t\t\"auth\": \"npm exec --yes ado-npm-auth\",\n    10→\t\t\"clean\": \"npm exec --yes cross-env rimraf dist node_modules .vite\",\n    11→\t\t\"start\": \"npm run dev\",\n    12→\t\t\"dev\": \"vite\",\n    13→\t\t\"build\": \"tsc && vite build  && zip -rFS dist.zip dist; open .\",\n    14→\t\t\"lint\": \"eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0\",\n    15→\t\t\"preview\": \"vite preview\",\n    16→\t\t\"setPrototypeName\": \"node ./scripts/setPrototypeName.js\",\n    17→\t\t\"fixFigmaSVG\": \"npx jscodeshift -t scripts/svgCamelCase.js src --extensions=tsx,jsx --parser=tsx\",\n    18→\t\t\"gql-compile\": \"graphql-codegen --config codegen.mjs\",\n    19→\t\t\"gql-watch\": \"graphql-codegen --config codegen.mjs --watch\"\n    20→\t},\n    21→\t\"dependencies\": {\n    22→\t\t\"@fluentui-copilot/react-copilot\": \"^0.28.5\",\n    23→\t\t\"@fluentui/keyboard-keys\": \"^9.0.8\",\n    24→\t\t\"@fluentui/react-brand-icons\": \"^2.0.174\",\n    25→\t\t\"@fluentui/react-components\": \"^9.68.3\",\n    26→\t\t\"@fluentui/react-context-selector\": \"^9.2.5\",\n    27→\t\t\"@fluentui/react-icons\": \"^2.0.307\",\n    28→\t\t\"@fluentui/react-jsx-runtime\": \"^9.1.5\",\n    29→\t\t\"@fluentui/react-shared-contexts\": \"^9.24.1\",\n    30→\t\t\"@fluentui/react-tabster\": \"^9.26.3\",\n    31→\t\t\"@fluentui/react-utilities\": \"^9.23.2\",\n    32→\t\t\"@fluidframework/azure-client\": \"^2.60.0\",\n    33→\t\t\"@fluidframework/presence\": \"^2.60.0\",\n    34→\