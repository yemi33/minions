{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DNXBkGsGJydPX9XR6i6UrK","type":"tool_result","content":"     1→import type { IClientRuntime, ISession, AnnotationActivationOptions } from '@augloop/runtime-client';\n     2→import { createRuntime } from '@augloop/runtime-client';\n     3→import type { IOperation, ISchemaObject } from '@augloop/types-core';\n     4→import { AddOperation, Document, SignalOperation } from '@augloop/types-core';\n     5→import { v4 as uuidv4 } from 'uuid';\n     6→import { TokenEnvironment } from './token-server';\n     7→import { getAugLoopToken } from './token-server/tokenServerManager';\n     8→\n     9→\n    10→const AUGLOOP_ENDPOINTS: Record<TokenEnvironment, string> = {\n    11→    Dev: 'http://localhost:11040',\n    12→    Local: 'http://localhost:11040',\n    13→    Test: 'https://test.augloop.svc.cloud.dev.microsoft',\n    14→    Int: 'https://int.augloop.svc.cloud.dev.microsoft',\n    15→    Dogfood: 'https://dogfood.augloop.svc.cloud.microsoft',\n    16→    MSIT: 'https://msit.augloop.svc.cloud.microsoft',\n    17→    Prod: 'https://augloop.svc.cloud.microsoft',\n    18→    UsGov: 'https://augloop.gov.online.office365.us',\n    19→    Gallatin: 'https://augloop.microsoftonline.cn'\n    20→};\n    21→\n    22→/**\n    23→ * Get an authentication token for Augloop API requests\n    24→ * @param environment - The AugLoop environment to use\n    25→ * @returns The auth token or null if failed\n    26→ */\n    27→async function getAugLoopAuthToken(environment: TokenEnvironment): Promise<string | null> {\n    28→    try {\n    29→        const authToken = await getAugLoopToken({ environment });\n    30→        return authToken ?? null;\n    31→    } catch (error) {\n    32→        console.error('❌ Error fetching AugLoop auth token:', (error as Error).message);\n    33→        return null;\n    34→    }\n    35→}\n    36→\n    37→/**\n    38→ * AugLoop runtime client that encapsulates runtime and session state\n    39→ */\n    40→class AugLoopClient {\n    41→    private runtime: IClientRuntime | undefined;\n    42→    private session: ISession | undefined;\n    43→    private sessionId: string;\n    44→    private annotationCallbacks: Map<string, (annotation: any) => void>;\n    45→    private activatedAnnotationsByType: Map<string, string | undefined>;\n    46→\n    47→    constructor() {\n    48→        this.sessionId = uuidv4();\n    49→        this.annotationCallbacks = new Map();\n    50→        this.activatedAnnotationsByType = new Map();\n    51→    }\n    52→\n    53→    async initialize(\n    54→        environment: TokenEnvironment = TokenEnvironment.Dogfood,\n    55→        flights?: string\n    56→    ): Promise<void> {\n    57→        const endpointUrl = AUGLOOP_ENDPOINTS[environment];\n    58→        console.log(`🌐 Initializing AugLoop client for environment: ${environment} (${endpointUrl})`);\n    59→\n    60→        // Auth token callback\n    61→        const authTokenCallback = async () => {\n    62→            try {\n    63→                const authToken = await getAugLoopAuthToken(environment);\n    64→                return { Token: authToken || '' };\n    65→            } catch (error) {\n    66→                console.error('❌ Failed to get AugLoop access token in callback:', error);\n    67→                return { Token: '' };\n    68→            }\n    69→        };\n    70→\n    71→        return new Promise((resolve, reject) => {\n    72→            this.runtime = createRuntime();\n    73→\n    74→            if (!this.session) {\n    75→                this.runtime?.init(\n    76→                    endpointUrl,\n    77→                    {\n    78→                        appName: 'OfficeAgent',\n    79→                        appPlatform: 'TestClient',\n    80→                        flights,\n    81→                        uiLanguage: 'en-US',\n    82→                    },\n    83→                    {\n    84→                        onAnnotationResult: (op: IOperation) => {\n    85→                            // Process each item in the operation\n    86→                            for (const item of op.items) {\n    87→                                if (item.body) {\n    88→                                    const correlationId = op.parentPath[2]; // Correlation ID from the operation path\n    89→\n    90→                                    // Call specific callback if registered by correlation ID\n    91→                                    if (correlationId && this.annotationCallbacks.has(correlationId)) {\n    92→                                        const callback = this.annotationCallbacks.get(correlationId);\n    93→                                        if (callback) {\n    94→                                            callback(item.body);\n    95→                                        }\n    96→                                    }\n    97→                                }\n    98→                            }\n    99→                        },\n   100→                        sendTelemetryEvent: () => {\n   101→                            // No-op for test client\n   102→                        },\n   103→                        requestAuthToken: authTokenCallback,\n   104→                        isFeatureEnabled: () => Promise.resolve(false),\n   105→                        areLicenseFeaturesEnabled: () => Promise.resolve(false),\n   106→                    },\n   107→                    {\n   108→                        telemetryAggregationIntervalSec: 30,\n   109→                        initSession: false,\n   110→                    },\n   111→                )\n   112→                    .then(() => {\n   113→                        this.runtime\n   114→                            ?.createSession({\n   115→                                docSessionId: this.sessionId,\n   116→                                onSessionConnect: (isSeedingRequired: boolean, sessionUrl: string) => {\n   117→                                    console.log('✅ AugLoop WebSocket session connected:', sessionUrl);\n   118→                                    // Submit parent tile operation if seeding is required\n   119→                                    if (isSeedingRequired) {\n   120→                                        this.submitParentTile();\n   121→                                    }\n   122→                                },\n   123→                            })\n   124→                            .then((session: ISession) => {\n   125→                                this.session = session;\n   126→                                console.log('✅ AugLoop WebSocket session initialized');\n   127→                                resolve();\n   128→                            });\n   129→                    })\n   130→                    .catch((error) => {\n   131→                        console.error('❌ Failed to initialize AugLoop client runtime:', error);\n   132→                        reject(error);\n   133→                    });\n   134→            } else {\n   135→                resolve();\n   136→            }\n   137→        });\n   138→    }\n   139→\n   140→    submitOperation(operation: IOperation): void {\n   141→        if (!this.session) {\n   142→            throw new Error('AugLoop session not initialized. Call initialize() first.');\n   143→        }\n   144→        this.session.submitOperation(operation);\n   145→    }\n   146→\n   147→    submitParentTile(): void {\n   148→        if (!this.session) {\n   149→            throw new Error('AugLoop session not initialized. Call initialize() first.');\n   150→        }\n   151→        this.session.submitSeedOperations([\n   152→            new AddOperation({\n   153→                parentPath: ['session'],\n   154→                items: [\n   155→                    {\n   156→                        id: 'doc',\n   157→                        revId: '0',\n   158→                        body: new Document({\n   159→                            isReadonly: false,\n   160→                        }),\n   161→                    },\n   162→                ],\n   163→            }),\n   164→        ]);\n   165→        console.log('📋 Submitted parent tile operation');\n   166→    }\n   167→\n   168→    submitSignal(signal: ISchemaObject, uuid?: string): void {\n   169→        if (!this.session) {\n   170→            throw new Error('AugLoop session not initialized. Call initialize() first.');\n   171→        }\n   172→        const id = uuid || uuidv4();\n   173→        this.session.submitOperation(\n   174→            new SignalOperation({\n   175→                parentPath: ['session', 'doc'],\n   176→                items: [\n   177→                    {\n   178→                        id,\n   179→                        body: signal,\n   180→                    },\n   181→                ],\n   182→            }),\n   183→        );\n   184→    }\n   185→\n   186→    registerCallback(correlationId: string, callback: (annotation: any) => void): void {\n   187→        this.annotationCallbacks.set(correlationId, callback);\n   188→    }\n   189→\n   190→    unregisterCallback(correlationId: string): void {\n   191→        this.annotationCallbacks.delete(correlationId);\n   192→    }\n   193→\n   194→    async activateAnnotation(annotationType: string, options?: AnnotationActivationOptions): Promise<void> {\n   195→        if (!this.session) {\n   196→            throw new Error('AugLoop session not initialized. Call initialize() first.');\n   197→        }\n   198→        if (!this.activatedAnnotationsByType.has(annotationType)) {\n   199→            const result = await this.session.activateAnnotation(annotationType, options);\n   200→            this.activatedAnnotationsByType.set(annotationType, result?.token);\n   201→            console.log(`✅ Activated annotation type: ${annotationType}`);\n   202→        }\n   203→    }\n   204→\n   205→    isInitialized(): boolean {\n   206→        return this.session !== undefined;\n   207→    }\n   208→\n   209→    dispose(): void {\n   210→        this.session?.close();\n   211→        this.session = undefined;\n   212→        this.runtime?.flushTelemetry(true);\n   213→        this.annotationCallbacks.clear();\n   214→        this.activatedAnnotationsByType.clear();\n   215→        this.sessionId = uuidv4();\n   216→        console.log('🔌 AugLoop session disposed');\n   217→    }\n   218→}\n   219→\n   220→// Singleton instance for backward compatibility\n   221→let clientInstance: AugLoopClient | undefined;\n   222→\n   223→/**\n   224→ * Get or create the AugLoop client instance\n   225→ */\n   226→function getClient(): AugLoopClient {\n   227→    if (!clientInstance) {\n   228→        clientInstance = new AugLoopClient();\n   229→    }\n   230→    return clientInstance;\n   231→}\n   232→\n   233→/**\n   234→ * Send a request to the AugLoop workflow endpoint using HTTP\n   235→ * @param message - The JSON object to send in the request body\n   236→ * @param workflow - The workflow to target (default: 'OfficeAgentServices')\n   237→ * @param options - Optional configuration\n   238→ * @param options.authToken - Optional auth token. If not provided, will fetch a new one\n   239→ * @param options.flights - Optional flighting information to include in the request\n   240→ * @param options.environment - The AugLoop environment to use (default: 'Dogfood')\n   241→ * @returns The response from the AugLoop API\n   242→ */\n   243→export async function sendAugLoopHttpRequest(\n   244→    message: Record<string, any>,\n   245→    workflow = 'OfficeAgentServices',\n   246→    options?: {\n   247→        authToken?: string;\n   248→        flights?: string;\n   249→        environment?: TokenEnvironment;\n   250→    }\n   251→): Promise<any> {\n   252→    const environment = options?.environment ?? TokenEnvironment.Dogfood;\n   253→    const token = options?.authToken ?? await getAugLoopAuthToken(environment);\n   254→\n   255→    if (!token) {\n   256→        throw new Error('Failed to get authentication token');\n   257→    }\n   258→\n   259→    const baseUrl = AUGLOOP_ENDPOINTS[environment];\n   260→    const url = `${baseUrl}/workflows/${workflow}`;\n   261→\n   262→    try {\n   263→        const response = await fetch(url, {\n   264→            method: 'POST',\n   265→            headers: {\n   266→                'Content-Type': 'application/json',\n   267→                'Authorization': `BEARER ${token}`,\n   268→                'x-client-metadata': JSON.stringify({\n   269→                    appName: 'OfficeAgent',\n   270→                    appPlatform: 'TestClient',\n   271→                    appVersion: '1.0.0',\n   272→                    sessionId: 'TestClient-OfficeAgent',\n   273→                    flights: options?.flights ?? '',\n   274→                    uiLanguage: 'en-US',\n   275→                    roamingServiceAppId: 0\n   276→                })\n   277→            },\n   278→            body: JSON.stringify({\n   279→                message: JSON.stringify(message)\n   280→            })\n   281→        });\n   282→\n   283→        if (!response.ok) {\n   284→            throw new Error(`HTTP error! status: ${response.status}`);\n   285→        }\n   286→\n   287→        return await response.json();\n   288→    } catch (error) {\n   289→        console.error('❌ Error sending AugLoop HTTP request:', (error as Error).message);\n   290→        throw error;\n   291→    }\n   292→}\n   293→\n   294→\n   295→/**\n   296→ * Send a request to the AugLoop workflow using WebSocket with annotation callback\n   297→ * @param message - The message object to send\n   298→ * @param onAnnotation - Callback to handle the annotation result\n   299→ * @param options - Optional configuration\n   300→ * @returns Promise that resolves when the request is sent (not when response is received)\n   301→ */\n   302→export async function sendAugLoopWsRequest(\n   303→    message: Record<string, any>,\n   304→    onAnnotation: (annotation: any) => void,\n   305→    options?: {\n   306→        flights?: string;\n   307→        environment?: TokenEnvironment;\n   308→        timeoutMs?: number;\n   309→        annotationTypes?: string[];\n   310→        annotationActivationOptions?: AnnotationActivationOptions;\n   311→    }\n   312→): Promise<void> {\n   313→    const environment = options?.environment ?? TokenEnvironment.Dogfood;\n   314→    const timeoutMs = options?.timeoutMs ?? (5 * 60 * 1000); // 5 minute default timeout\n   315→\n   316→    const client = getClient();\n   317→\n   318→    // Initialize session if not already done\n   319→    if (!client.isInitialized()) {\n   320→        await client.initialize(environment, options?.flights);\n   321→    }\n   322→\n   323→    // Activate annotation types if provided\n   324→    if (options?.annotationTypes && options.annotationTypes.length > 0) {\n   325→        for (const annotationType of options.annotationTypes) {\n   326→            await client.activateAnnotation(annotationType, options?.annotationActivationOptions);\n   327→        }\n   328→    }\n   329→\n   330→    return new Promise((resolve, reject) => {\n   331→        const requestId = message.id || uuidv4();\n   332→        const correlationId = message.sessionId || requestId;\n   333→\n   334→        // Set up timeout\n   335→        const timeout = setTimeout(() => {\n   336→            client.unregisterCallback(correlationId);\n   337→            reject(new Error(`AugLoop request timed out after ${timeoutMs} ms`));\n   338→        }, timeoutMs);\n   339→\n   340→        // Register callback for this specific request\n   341→        client.registerCallback(correlationId, (annotation: any) => {\n   342→            clearTimeout(timeout);\n   343→            try {\n   344→                onAnnotation(annotation);\n   345→                resolve();\n   346→            } catch (error) {\n   347→                reject(error);\n   348→            }\n   349→        });\n   350→\n   351→        // Submit the operation\n   352→        try {\n   353→            const operation = new AddOperation({\n   354→                parentPath: ['session', 'doc'],\n   355→                items: [\n   356→                    {\n   357→                        id: requestId,\n   358→                        body: message as ISchemaObject,\n   359→                    },\n   360→                ],\n   361→            });\n   362→\n   363→            client.submitOperation(operation);\n   364→        } catch (error) {\n   365→            clearTimeout(timeout);\n   366→            client.unregisterCallback(correlationId);\n   367→            console.error('❌ Error sending AugLoop WebSocket request:', requestId, error);\n   368→            reject(error);\n   369→        }\n   370→    });\n   371→}\n   372→\n   373→/**\n   374→ * Dispose the AugLoop session and cleanup resources\n   375→ */\n   376→export function disposeAugLoopSession(): void {\n   377→    if (clientInstance) {\n   378→        clientInstance.dispose();\n   379→        clientInstance = undefined;\n   380→    }\n   381→}\n   382→"}]},"parent_tool_use_id":"toolu_01VApgtj8eVTCBzG1z4b1uAa","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"e0ec558d-185a-40c9-abb1-065645176fc3"}
