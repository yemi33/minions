oll, { passive: true });\n   106→\n   107→      cleanupRef.current = () => {\n   108→        active = false;\n   109→        if (baselineRafId !== null) {\n   110→          cancelAnimationFrame(baselineRafId);\n   111→        }\n   112→        if (rafId !== null) {\n   113→          cancelAnimationFrame(rafId);\n   114→        }\n   115→        el.removeEventListener('scroll', onScroll);\n   116→      };\n   117→    },\n   118→    [threshold, dispatch]\n   119→  );\n   120→\n   121→  return ref;\n   122→}\n   123→"}]},"parent_tool_use_id":"toolu_01XrfUS8UeV8YDsw48sFBkQR","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"c64dffab-e806-4029-8ac7-439911886900"}
