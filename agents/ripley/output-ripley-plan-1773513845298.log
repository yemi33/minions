{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PxFsAMvRqYPTsRAwas62tB","type":"tool_result","content":"     1→import { useEffect, useState } from 'react'\n     2→import styled from 'styled-components'\n     3→import {\n     4→\tAgent,\n     5→\tCannedResponseReference,\n     6→\tChainOfThoughtStyle,\n     7→\tCoTProcessingStep,\n     8→\tCoTProcessingStepStatus,\n     9→} from '../../types/types'\n    10→\n    11→import { MinimizedContent } from './MinimizedContent'\n    12→import { ExpandedContent } from './ExpandedContent'\n    13→import { useSettingsStore } from '../../store/settingsStore'\n    14→import { useChatStore } from '../../store/useChatStore'\n    15→import { AnimatePresence, motion } from 'motion/react'\n    16→import { Body1, tokens } from '@fluentui/react-components'\n    17→import { QuickAnswerButton } from '../QuickAnswerButton/QuickAnswerButton'\n    18→import { ShimmerText } from '../ShimmerText/ShimmerText'\n    19→\n    20→import {\n    21→\tAgents20Regular,\n    22→\tChevronRight12Regular,\n    23→\tDataLine20Regular,\n    24→\tPlanet20Regular,\n    25→} from '@fluentui/react-icons'\n    26→import { SalesIcon20Monoline } from '@/assets/icons/SalesIcon'\n    27→import { postEventKeyToIframe } from '@/lib/IframeMessageInterface'\n    28→\n    29→type Props = {\n    30→\tcotProcessingSteps?: CoTProcessingStep[]\n    31→\treferences?: CannedResponseReference[]\n    32→\tonReferenceClicked: (reference: CannedResponseReference) => void\n    33→\tcompletedSummary?: string\n    34→\tisThinking?: boolean // New prop for the initial \"Thinking...\" state\n    35→\tmessageId?: string // Message ID for quick answer functionality\n    36→\thasShown?: boolean // Whether the card has been shown\n    37→\tagent?: Agent\n    38→\tdidSkip?: boolean\n    39→}\n    40→\n    41→export const ChainOfThoughtCard = (props: Props) => {\n    42→\tconst {\n    43→\t\treferences,\n    44→\t\tonReferenceClicked,\n    45→\t\tcotProcessingSteps,\n    46→\t\tcompletedSummary,\n    47→\t\tisThinking = false,\n    48→\t\tmessageId,\n    49→\t\thasShown,\n    50→\t\tagent,\n    51→\t\tdidSkip,\n    52→\t\t...rest\n    53→\t} = props\n    54→\n    55→\tconst [currentSteps, setCurrentSteps] = useState<CoTProcessingStep[]>([])\n    56→\tconst [isLoading, setIsLoading] = useState(false)\n    57→\tconst [refreshTrigger, setRefreshTrigger] = useState(0) // Force re-checks\n    58→\n    59→\tconst [isExpanded, setIsExpanded] = useState(false)\n    60→\tconst chainOfThoughtStyle = useSettingsStore((state) => state.chainOfThoughtStyle)\n    61→\tconst skipToQuickAnswer = useChatStore((state) => state.skipToQuickAnswer)\n    62→\n    63→\tconst iconForAgent = (agent?: Agent) => {\n    64→\t\tif (!agent) return null\n    65→\n    66→\t\tswitch (agent) {\n    67→\t\t\tcase Agent.Researcher:\n    68→\t\t\t\treturn <Planet20Regular />\n    69→\n    70→\t\t\tcase Agent.Analyst:\n    71→\t\t\t\treturn <DataLine20Regular />\n    72→\t\t\tcase Agent.Sales:\n    73→\t\t\t\treturn <SalesIcon20Monoline />\n    74→\t\t\tdefault:\n    75→\t\t\t\treturn <Agents20Regular />\n    76→\t\t}\n    77→\t}\n    78→\n    79→\tconst toggleExpanded = () => {\n    80→\t\tsetIsExpanded((prev) => !prev)\n    81→\t}\n    82→\n    83→\tconst variants = {\n    84→\t\texpanded: {\n    85→\t\t\theight: 'auto',\n    86→\t\t\topacity: 1,\n    87→\t\t},\n    88→\t\tcollapsed: {\n    89→\t\t\theight: 32, // Change this to match your intended collapsed height\n    90→\t\t\topacity: 1,\n    91→\t\t},\n    92→\t\tloading: {\n    93→\t\t\theight: 100,\n    94→\t\t\topacity: 1,\n    95→\t\t},\n    96→\t\tinitial: {\n    97→\t\t\theight: 32, // Start with the collapsed height\n    98→\t\t\topacity: 0,\n    99→\t\t},\n   100→\t}\n   101→\n   102→\t// Timer to periodically check status while loading\n   103→\tuseEffect(() => {\n   104→\t\tif (!isLoading) return\n   105→\n   106→\t\tconst timer = setInterval(() => {\n   107→\t\t\tsetRefreshTrigger((prev) => prev + 1)