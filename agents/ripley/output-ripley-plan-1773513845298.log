{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0112ENMcWjVH7vFVMNw1kgG1","type":"tool_result","content":"     1→/**\n     2→ * Claude Hook Adapter\n     3→ *\n     4→ * Translates provider-agnostic GenericToolHooks into the Claude Agent SDK\n     5→ * Options['hooks'] format ({ PreToolUse, PostToolUse, SessionStart, SessionEnd }).\n     6→ *\n     7→ * This adapter allows hook providers (ppt-hooks, word-hooks, etc.) to be\n     8→ * written once using GenericToolHooks and work with the Claude orchestrator.\n     9→ */\n    10→\n    11→import type { Options, HookCallback, HookInput, SyncHookJSONOutput } from '@anthropic-ai/claude-agent-sdk';\n    12→import type { GenericToolHooks, PreToolUseHook, PostToolUseHook } from '../types';\n    13→\n    14→/**\n    15→ * Adapt a GenericToolHooks instance into Claude SDK Options['hooks'] format.\n    16→ *\n    17→ * @param genericHooks - Provider-agnostic hook definitions\n    18→ * @returns Claude SDK hooks object ready to be passed to Options.hooks\n    19→ */\n    20→export function toClaudeHooks(genericHooks: GenericToolHooks): NonNullable<Options['hooks']> {\n    21→    const claudeHooks: NonNullable<Options['hooks']> = {};\n    22→\n    23→    // Adapt PreToolUse hooks\n    24→    if (genericHooks.preToolUse && genericHooks.preToolUse.length > 0) {\n    25→        claudeHooks.PreToolUse = [\n    26→            {\n    27→                hooks: genericHooks.preToolUse.map((hook) => wrapPreToolUseHook(hook)),\n    28→            },\n    29→        ];\n    30→    }\n    31→\n    32→    // Adapt PostToolUse hooks\n    33→    if (genericHooks.postToolUse && genericHooks.postToolUse.length > 0) {\n    34→        claudeHooks.PostToolUse = [\n    35→            {\n    36→                hooks: genericHooks.postToolUse.map((hook) => wrapPostToolUseHook(hook)),\n    37→            },\n    38→        ];\n    39→    }\n    40→\n    41→    // Adapt SessionStart hooks\n    42→    if (genericHooks.onSessionStart && genericHooks.onSessionStart.length > 0) {\n    43→        claudeHooks.SessionStart = genericHooks.onSessionStart.map((hook) => ({\n    44→            hooks: [(async (_input: HookInput, _toolUseID: string | undefined, _options: { signal: AbortSignal }): Promise<SyncHookJSONOutput> => {\n    45→                await hook();\n    46→                return {};\n    47→            }) as HookCallback],\n    48→        }));\n    49→    }\n    50→\n    51→    // Adapt SessionEnd hooks\n    52→    if (genericHooks.onSessionEnd && genericHooks.onSessionEnd.length > 0) {\n    53→        claudeHooks.SessionEnd = genericHooks.onSessionEnd.map((hook) => ({\n    54→            hooks: [(async (_input: HookInput, _toolUseID: string | undefined, _options: { signal: AbortSignal }): Promise<SyncHookJSONOutput> => {\n    55→                await hook();\n    56→                return {};\n    57→            }) as HookCallback],\n    58→        }));\n    59→    }\n    60→\n    61→    return claudeHooks;\n    62→}\n    63→\n    64→/**\n    65→ * Wrap a generic PreToolUseHook into a Claude SDK HookCallback.\n    66→ *\n    67→ * Claude PreToolUse hooks receive (input: HookInput, toolUseID, options) and return\n    68→ * a SyncHookJSONOutput with optional `decision` ('block'|'approve'), `reason`, and\n    69→ * `hookSpecificOutput` for input modifications.\n    70→ */\n    71→function wrapPreToolUseHook(hook: PreToolUseHook): HookCallback {\n    72→    return (async (input: HookInput, _toolUseID: string | undefined, _options: { signal: AbortSignal }): Promise<SyncHookJSONOutput> => {\n    73→        const preInput = input as { tool_name?: string; tool_input?: unknown };\n    74→        const toolName = preInput.tool_name ?? '';\n    75→        const toolInput = preInput.tool_input;\n    76→\n    77→        const result = await hook(toolName, toolInput);\n    78→\n    79→        if (!result.continue) {\n    80→            return {\n    81→                decision: 'block' as const,\n    82→                reason: result.reason ?? 'Blocked by generic hook',\n    83→            };\n    84→        }\n    85→\n    86→        if (result.modifiedInput !== undefined) {\n    87→            return {\n    88→                decision: 'approve' as const,\n    89→                hookSpecificOutput: {\n    90→                    hookEventName: 'PreToolUse' as const,\n    91→                    updatedInput: result.modifiedInput as Record<string, unknown>,\n    92→                },\n    93→            };\n    94→        }\n    95→\n    96→        return {};\n    97→    }) as HookCallback;\n    98→}\n    99→\n   100→/**\n   101→ * Wrap a generic PostToolUseHook into a Claude SDK HookCallback.\n   102→ *\n   103→ * Claude PostToolUse hooks receive (input: HookInput, toolUseID, options) and return\n   104→ * a SyncHookJSONOutput with optional `hookSpecificOutput` for output modifications.\n   105→ */\n   106→function wrapPostToolUseHook(hook: PostToolUseHook): HookCallback {\n   107→    return (async (input: HookInput, _toolUseID: string | undefined, _options: { signal: AbortSignal }): Promise<SyncHookJSONOutput> => {\n   108→        const postInput = input as { tool_name?: string; tool_response?: unknown };\n   109→        const toolName = postInput.tool_name ?? '';\n   110→        const output = postInput.tool_response;\n   111→\n   112→        const result = await hook(toolName, output);\n   113→\n   114→        if (result.modifiedOutput !== undefined) {\n   115→            return {\n   116→                hookSpecificOutput: {\n   117→                    hookEventName: 'PostToolUse' as const,\n   118→                    updatedMCPToolOutput: result.modifiedOutput,\n   119→                },\n   120→            };\n   121→        }\n   122→\n   123→        return {};\n   124→    }) as HookCallback;\n   125→}\n   126→\n   127→/**\n   128→ * Merge generic hooks with existing Claude SDK hooks.\n   129→ *\n   130→ * Useful during migration when some hooks are already in Claude format\n   131→ * and others are in the new generic format.\n   132→ */\n   133→export function mergeWithClaudeHooks(\n   134→    existingClaudeHooks: Options['hooks'],\n   135→    genericHooks: GenericToolHooks\n   136→): NonNullable<Options['hooks']> {\n   137→    const adaptedHooks = toClaudeHooks(genericHooks);\n   138→    const merged: NonNullable<Options['hooks']> = { ...(existingClaudeHooks ?? {}) };\n   139→\n   140→    // Concatenate PreToolUse arrays\n   141→    if (adaptedHooks.PreToolUse) {\n   142→        merged.PreToolUse = [...(merged.PreToolUse ?? []), ...adaptedHooks.PreToolUse];\n   143→    }\n   144→\n   145→    // Concatenate PostToolUse arrays\n   146→    if (adaptedHooks.PostToolUse) {\n   147→        merged.PostToolUse = [...(merged.PostToolUse ?? []), ...adaptedHooks.PostToolUse];\n   148→    }\n   149→\n   150→    // Concatenate SessionStart arrays"}]},"parent_tool_use_id":"toolu_01D1btGNgUTxKhKd2oyCp7xP","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"7e790d49-1e35-410f-a8cf-bfa4518cc74a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Doi79phNbPTn1dBLcNpq7H","type":"tool_result","content":"     1→/**\n     2→ * Converts OrchestratorMessage → chain-of-thought module shape.\n     3→ *\n     4→ * Bridges Copilot SDK (flat events) to Claude Agent SDK (nested message.content[]) by:\n     5→ * 1. Deduplicating accumulated assistant text (Copilot SDK sends full content on every event)\n     6→ * 2. Converting tool_use → synthetic assistant messages with tool_use content blocks\n     7→ * 3. Mapping tool names (view→Read, create→Write, bash→Bash, etc.) and input params (path→file_path)\n     8→ *\n     9→ * The chain-of-thought module now uses a structural `ChainOfThoughtMessage` interface\n    10→ * (no Claude SDK imports), so the output of this adapter is type-safe without casts.\n    11→ */\n    12→\n    13→import { OrchestratorMessage } from './types';\n    14→import { ChainOfThoughtMessage } from '@officeagent/chain-of-thought';\n    15→\n    16→/**\n    17→ * Stateful adapter — deduplicates assistant text across accumulated SDK events.\n    18→ * Create one instance per orchestrator run.\n    19→ */\n    20→export class ChainOfThoughtAdapter {\n    21→    private lastContent = '';\n    22→    private syntheticIdCounter = 0;\n    23→\n    24→    reset(): void {\n    25→        this.lastContent = '';\n    26→        this.syntheticIdCounter = 0;\n    27→    }\n    28→\n    29→    /** Returns null for skipped/duplicate messages. */\n    30→    convert(msg: OrchestratorMessage): ChainOfThoughtMessage | null {\n    31→        if (msg.type === 'assistant') {\n    32→            const fullText = msg.content || '';\n    33→\n    34→            // Extract tool_use content blocks and parent_tool_use_id from the raw\n    35→            // provider message. Claude SDK assistant messages carry nested\n    36→            // message.content[] with tool_use blocks and an optional\n    37→            // parent_tool_use_id for sub-agent messages. Without forwarding these\n    38→            // fields the chain-of-thought module cannot register or track sub-agents.\n    39→            const raw = msg.raw as Record<string, unknown> | undefined;\n    40→            const rawContent = ((raw?.message as Record<string, unknown> | undefined)?.content ?? []) as any[];\n    41→            const toolUseBlocks = rawContent.filter((b: any) => b.type === 'tool_use');\n    42→            const parentToolUseId = raw?.parent_tool_use_id as string | null | undefined;\n    43→\n    44→            // Dedup text content (for Copilot SDK accumulated events)\n    45→            let text = fullText;\n    46→            let hasNewText = false;\n    47→            if (fullText.trim()) {\n    48→                if (fullText === this.lastContent) {\n    49→                    text = '';\n    50→                } else if (this.lastContent && fullText.startsWith(this.lastContent)) {\n    51→                    text = fullText.slice(this.lastContent.length);\n    52→                }\n    53→                this.lastContent = fullText;\n    54→                hasNewText = !!text.trim();\n    55→            }\n    56→\n    57→            // Build content blocks — deduped text + raw tool_use blocks\n    58→            const contentBlocks: any[] = [];\n    59→            if (hasNewText) {\n    60→                contentBlocks.push({ type: 'text', text });\n    61→            }\n    62→            contentBlocks.push(...toolUseBlocks);\n    63→\n    64→            // Nothing new to report\n    65→            if (contentBlocks.length === 0) return null;\n    66→\n    67→            const result: ChainOfThoughtMessage = {\n    68→                type: 'assistant',\n    69→                message: { content: contentBlocks },\n    70→            };\n    71→\n    72→            if (parentToolUseId) {\n    73→                result.parent_tool_use_id = parentToolUseId;\n    74→            }\n    75→\n    76→            return result;\n    77→        }\n    78→\n    79→        // Forward GPT-5 reasoning events as assistant text for CoT progress display.\n    80→        // Does not update lastContent — thinking is a separate stream from assistant text.\n    81→        if (msg.type === 'thinking') {\n    82→            const text = msg.content || '';\n    83→            if (!text.trim()) return null;\n    84→            return { type: 'assistant', message: { content: [{ type: 'text', text }] } };\n    85→        }\n    86→\n    87→        // tool_use needs the instance counter for unique IDs\n    88→        if (msg.type === 'tool_use') {\n    89→            let input: Record<string, unknown> = {};\n    90→            try {\n    91→                input = msg.content ? JSON.parse(msg.content) : {};\n    92→            } catch { /* ignore parse errors */ }\n    93→\n    94→            const mapped = mapToolForChainOfThought(msg.toolName || '', input);\n    95→            if (!mapped) return null;\n    96→\n    97→            return {\n    98→                type: 'assistant',\n    99→                message: {\n   100→                    content: [{"}]},"parent_tool_use_id":"toolu_01D1btGNgUTxKhKd2oyCp7xP","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"23c50efd-ceb7-4e7d-b6b3-00f56292e43d"}
