{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AFRgpAPWZXGfx2yEJepgBU","type":"tool_result","content":"     1→'use client';\n     2→\n     3→import { useConversationOrchestrator } from '@bebopjs/bebop-conversation';\n     4→import { useReplayFixturePrompt } from '@bebopjs/bebop-ux';\n     5→import { ChatPrompt } from './ChatPrompt';\n     6→import { useChatPrompt } from './hooks/useChatPrompt';\n     7→import { useChatStatus } from './hooks/useChatStatus';\n     8→import type { Status } from '@bebopjs/bebop-response-mapping';\n     9→import type { FC } from 'react';\n    10→import type { ChatClientStatus } from '@bebopjs/bebop-conversation-orchestrator';\n    11→\n    12→/* This noop serves:\n    13→ * 1. SetResponseStatus -- ChatInput currently uses this setting to bridge suspense\n    14→ * time-gap when triggering action. This is no longer necessary.\n    15→ * The DirectDOM method requires no async load time\n    16→ * and syncs directly via useSyncExternalStore.\n    17→ * 2. LoAF -- LoAF metrics are not collected and emitted within bebop-conversation-orchestrator.\n    18→ * This orchestration will be removed once we fully migrate.\n    19→ * https://dev.azure.com/office/OC/_workitems/edit/11267013\n    20→ **/\n    21→const noop = (): void => undefined;\n    22→\n    23→/*\n    24→ * Mapping between ChatClientStatus and bebop-response-mapping status\n    25→ * Todo VSO: #11267010\n    26→ * This mapping harmonizes chatInput status to ChatClientStatus\n    27→ **/\n    28→const responseStatusMap: Record<ChatClientStatus, Status | null> = {\n    29→  idle: null,\n    30→  pending: 'inProgress',\n    31→  streaming: 'inProgress',\n    32→  error: new Error('')\n    33→};\n    34→\n    35→export const ChatPromptWrapper: FC = () => {\n    36→  const { submitPrompt, abortControllerRef } = useChatPrompt();\n    37→  const status = useChatStatus();\n    38→  const responseStatus = responseStatusMap[status];\n    39→  const { conversationId } = useConversationOrchestrator();\n    40→  const initialPrompt = useReplayFixturePrompt();\n    41→\n    42→  return (\n    43→    <ChatPrompt\n    44→      startSpan={noop}\n    45→      endSpan={noop}\n    46→      responseStatus={responseStatus}\n    47→      setResponseStatus={noop}\n    48→      submitPrompt={submitPrompt}\n    49→      abortControllerRef={abortControllerRef}\n    50→      conversationId={conversationId}\n    51→      initialPrompt={initialPrompt}\n    52→    />\n    53→  );\n    54→};\n    55→"}]},"parent_tool_use_id":"toolu_01XrfUS8UeV8YDsw48sFBkQR","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"02216d76-235b-4a9f-b4f9-ba4b1a1bfc4b"}
