{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M2iAoU7Wk9LuiozmgCFH6X","type":"tool_result","content":"     1→import type { ITelemetryNamespaceLogger } from '@fluidx/1p-loop-types';\n     2→import type { IdentityType, SettingsProvider } from '@fluidx/loop-types';\n     3→import type { BizChatTokenProvider } from '@fluidx/loop-workspace-types';\n     4→import type { AuthServices, AuthServiceType } from './BizChatAuth.types';\n     5→import { BizChatAuthService } from './BizChatAuthService';\n     6→\n     7→class BizChatTokenProviderImpl implements BizChatTokenProvider {\n     8→  public readonly identityType: IdentityType | undefined;\n     9→  #bizChatAuthService: BizChatAuthService;\n    10→\n    11→  constructor(\n    12→    loginHint: string,\n    13→    logger: ITelemetryNamespaceLogger,\n    14→    settingsProvider: SettingsProvider | undefined,\n    15→    capabilities: Array<string> | undefined,\n    16→    tenantId: string | undefined\n    17→  ) {\n    18→    this.#bizChatAuthService = new BizChatAuthService(loginHint, logger, settingsProvider, capabilities, tenantId);\n    19→  }\n    20→\n    21→  get BizChatTokenProvider() {\n    22→    return this;\n    23→  }\n    24→\n    25→  public augloop = (_headers?: Headers) => this.#getTokenHelper('AugLoop');\n    26→  public substrate = () => this.#getTokenHelper('Substrate');\n    27→  public sydney = (_shouldForceRefresh?: boolean, _headers?: Headers) => this.#getTokenHelper('Sydney');\n    28→  public tenantFeedback = () => this.#getTokenHelper('TenantFeedback');\n    29→  public loki = async () => ({\n    30→    accessToken: await this.#getTokenHelper('Loki'),\n    31→    expirationTime: 0\n    32→  });\n    33→  public feed = (_headers?: Headers) => this.#getTokenHelper('Substrate');\n    34→  //public yammer = () => Promise<string>;\n    35→  public spo = async (_domain: string, _headers?: Headers) => {\n    36→    const accessToken = await this.#getTokenHelper('SharePoint');\n    37→    return Promise.resolve({\n    38→      AuthToken: accessToken,\n    39→      AuthTokenTtl: undefined\n    40→    });\n    41→  };\n    42→  public mos = () => this.#getTokenHelper('MetaOS');\n    43→  //public oboToken = (resource: string, consentRequired?: boolean) => Promise<string>;\n    44→  public aeaToken = () => this.#getTokenHelper('Aea');\n    45→  public amsToken = () => this.#getTokenHelper('Ams');\n    46→  public graph = (_headers?: Headers) => this.#getTokenHelper('Graph');\n    47→  public powerAutomate = () => this.#getTokenHelper('PowerAutomate');\n    48→  public powerPlatform = (clusterCategory: string) => {\n    49→    let category:\n    50→      | (typeof AuthServiceType)['PpapiProd']\n    51→      | (typeof AuthServiceType)['PpapiPreProd']\n    52→      | (typeof AuthServiceType)['PpapiTest']\n    53→      | undefined = undefined;\n    54→\n    55→    switch (clusterCategory) {\n    56→      case 'prod':\n    57→        category = 'PpapiProd';\n    58→        break;\n    59→      case 'preprod':\n    60→        category = 'PpapiPreProd';\n    61→        break;\n    62→      case 'test':\n    63→        category = 'PpapiTest';\n    64→        break;\n    65→      default:\n    66→        return Promise.reject(new Error('Unknown clusterCategory'));\n    67→    }\n    68→\n    69→    return this.#getTokenHelper(category);\n    70→  };\n    71→  public apiHub = () => this.#getTokenHelper('ApiHub');\n    72→  public apiSkype = (_headers?: Headers) => this.#getTokenHelper('Skype');\n    73→  public teams = () => this.#getTokenHelper('Teams');\n    74→  public outlook = () => this.#getTokenHelper('Outlook'); // returning of a token is gated in 1JS\n    75→  public designer = () => this.#getTokenHelper('DesignerAppService');\n    76→  public apiUrlp = () => this.#getTokenHelper('ApiUrlp');\n    77→  public ocps = (_headers?: Headers) => this.#getTokenHelper('Ocps');\n    78→  public powerbi = (_headers?: Headers) => this.#getTokenHelper('PowerBI'); // returning of a token is gated in 1JS\n    79→  public pushChannel = (_headers?: Headers) => this.#getTokenHelper('FluidPushChannel');\n    80→  public mss = () => this.#getTokenHelper('BingAnswers');\n    81→  public copilotStudio = (realm: string) =>\n    82→    this.#getTokenHelper(realm === 'prod' ? 'CopilotStudioProd' : 'CopilotStudioTest');\n    83→  public bap = (_realm: string) => this.#getTokenHelper('Bap');\n    84→  public gcs = () => this.#getTokenHelper('GCS');\n    85→  public mruPlusPlus = (_headers?: Headers) => this.#getTokenHelper('MruPlusPlus');\n    86→  public trouter = (_aadId?: string) => this.#getTokenHelper('Trouter');\n    87→  public onenote = () => this.#getTokenHelper('OneNote');\n    88→  public pacman = () => this.#getTokenHelper('Pacman');\n    89→  public iris = () => this.#getTokenHelper('Iris');\n    90→  public safeLinks = (isLegacy?: boolean) =>\n    91→    isLegacy ? this.#getTokenHelper('SafeLinksLegacy') : this.#getTokenHelper('SafeLinks');\n    92→\n    93→  async #getTokenHelper(service: AuthServices) {\n    94→    // We need to find mechanism from BizChat to pass request and claims options at least.\n    95→    const response = await this.#bizChatAuthService.getToken(service /*, options*/);\n    96→    return response.token;\n    97→  }\n    98→}\n    99→\n   100→export function getBizChatTokenProvider(\n   101→  loginHint: string,\n   102→  logger: ITelemetryNamespaceLogger,\n   103→  settingsProvider: SettingsProvider | undefined,\n   104→  capabilities: Array<string> | undefined,\n   105→  tenantId: string | undefined\n   106→): Promise<BizChatTokenProvider> {\n   107→  return Promise.resolve(new BizChatTokenProviderImpl(loginHint, logger, settingsProvider, capabilities, tenantId));\n   108→}\n   109→"}]},"parent_tool_use_id":"toolu_01LamMSZH4D3xtZzNhF4Uoq8","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"677e2cb5-011b-4173-ad83-2dd4449a7055"}
