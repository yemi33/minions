{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015JxJGgzFpL8rWdmek9kSjk","type":"tool_result","content":"     1→import { useConversationOrchestrator } from '@bebopjs/bebop-conversation';\n     2→import type { RefObject } from 'react';\n     3→import type { SubmitPromptParameters } from '@bebopjs/bebop-shared-types';\n     4→\n     5→export interface ChatPromptResponse {\n     6→  submitPrompt: (parameters: SubmitPromptParameters) => void;\n     7→  abortControllerRef: RefObject<AbortController | null>;\n     8→}\n     9→\n    10→/**\n    11→ * Provides prompt submission and abort control for the chat client.\n    12→ * The abortControllerRef is a live getter that always reflects the current in-flight controller.\n    13→ */\n    14→export const useChatPrompt = (): ChatPromptResponse => {\n    15→  const { chat } = useConversationOrchestrator();\n    16→\n    17→  const submitPrompt = (parameters: SubmitPromptParameters): void => {\n    18→    chat.addChatRequest({ message: parameters.prompt, clientRequestId: parameters.clientRequestId });\n    19→  };\n    20→\n    21→  // Bridge to ref-like object for ChatInput compatibility\n    22→  // todo VSO: #11272297 remove once converged.\n    23→  const abortControllerRef: RefObject<AbortController | null> = {\n    24→    get current() {\n    25→      return chat.abortController ?? null;\n    26→    }\n    27→  };\n    28→\n    29→  return { submitPrompt, abortControllerRef };\n    30→};\n    31→"}]},"parent_tool_use_id":"toolu_01XrfUS8UeV8YDsw48sFBkQR","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"ad9af6c7-4e7e-484e-99ab-a26e3ad584cc"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015U9QR5ztqqKj5BKty7x8mK","type":"tool_result","content":"     1→import { initializeComponentRegistry, makeMarkdownToHtmlParser } from '@bebopjs/bebop-response-parser';\n     2→import { createSydneyResponseMapper } from '@bebopjs/bebop-response-mapping';\n     3→import { markEvent } from '~/core/telemetry/perfTracker';\n     4→import { createConfiguredSydneyClient } from './createConfiguredSydneyClient';\n     5→import { WarmClientMissReason, findWarmSydneyClientForRequest } from './sydneyWarmupRequestCache';\n     6→import { parseMessages } from './parseMessages';\n     7→import { emitConversationState, emitResultToStream, emitServerMetrics, emitTraceResults } from './emitResultToStream';\n     8→import type { SimpleTracer } from '@bebopjs/bebop-performance';\n     9→import type { PerfTracker } from '~/core/telemetry/perfTracker';\n    10→import type {\n    11→  ChatReference,\n    12→  GetMessagesResponse,\n    13→  SydneyTimestampType,\n    14→  ValidatedBebopApiChatRequestWithAuth\n    15→} from '@bebopjs/bebop-shared-types';\n    16→import type { SydneyClient } from '@bebopjs/bebop-sydney-client';\n    17→\n    18→export interface GetSydneyStreamParams {\n    19→  request: ValidatedBebopApiChatRequestWithAuth;\n    20→  warmupRequestKey?: string;\n    21→  signal?: AbortSignal;\n    22→  perfTracker: PerfTracker;\n    23→  tracer?: SimpleTracer;\n    24→  timeToFirstContentSpan?: { end: (attributes?: Record<string, string | number | boolean>) => void };\n    25→}\n    26→\n    27→const addSydneyPrefix = (name: string): string => {\n    28→  if (name.toLocaleLowerCase().startsWith('sydney')) {\n    29→    return name;\n    30→  }\n    31→\n    32→  return `sydney_${name}`;\n    33→};\n    34→\n    35→export const getSydneyStream = (params: GetSydneyStreamParams): ReadableStream<string> => {\n    36→  const { request, warmupRequestKey, signal, perfTracker, tracer, timeToFirstContentSpan } = params;\n    37→  const { tenantId, objectId, authHeader, message, traceId, conversationId, queryAnnotations } = request;\n    38→\n    39→  return new ReadableStream<string>({\n    40→    start(controller) {\n    41→      markEvent(perfTracker, 'stream_start_callback_entered');\n    42→      const parserSpan = tracer?.start('create_parser');\n    43→      const componentRegistry = initializeComponentRegistry();\n    44→      const parse = makeMarkdownToHtmlParser(\n    45→        {\n    46→          componentRegistry\n    47→        },\n    48→        true,\n    49→        false, // enableSsrPlugin\n    50→        true // disableEmitThrottle — writeAtCursor provides natural ~100ms spacing\n    51→      );\n    52→      parserSpan?.end();\n    53→      markEvent(perfTracker, 'parser_created');\n    54→      const mapperSpan = tracer?.start('create_response_mapper');\n    55→      const mapResponse = createSydneyResponseMapper();\n    56→      mapperSpan?.end();\n    57→      markEvent(perfTracker, 'response_mapper_created');\n    58→\n    59→      if (signal?.aborted) {\n    60→        controller.close();\n    61→        return;\n    62→      }\n    63→\n    64→      let lastPendingUpdate = Promise.resolve();\n    65→      let firstOnUpdateReceived = false;\n    66→      let firstChunkEmitted = false;\n    67→      let assignedConversationId = conversationId;\n    68→\n    69→      // Per-token streaming state. writeAtCursor tokens accumulate here and\n    70→      // own the parser after the initial seed. Snapshots only sync metadata.\n    71→      let hasAuthoritativeSeed = false;\n    72→      let accumulatedMarkdown = '';\n    73→      let currentMessageId = '';\n    74→      let lastReferences: Array<ChatReference> = [];\n    75→\n    76→      const waitingForSydneySpan = tracer?.start('waiting_for_sydney');\n    77→      let searchingAndReasoningSpan:\n    78→        | { end: (attributes?: Record<string, string | number | boolean>) => void }\n    79→        | undefined;\n    80→      let parserBufferingSpan: { end: (attributes?: Record<string, string | number | boolean>) => void } | undefined;\n    81→      let streamingSpan: { end: (attributes?: Record<string, string | number | boolean>) => void } | undefined;\n    82→      let firstChatTextReceived = false;\n    83→      let preRenderUpdateCount = 0;\n    84→      let preRenderTotalChars = 0;\n    85→\n    86→      const processResponse = async (response: GetMessagesResponse, isComplete: boolean) => {\n    87→        await mapResponse({\n    88→          response,\n    89→          scenario: { endpoint: 'streaming' },\n    90→          onMappingResult: (mappingResult) => {\n    91→            const { uxMessages } = mappingResult;\n    92→            if (uxMessages.length === 0) {\n    93→              return;\n    94→            }\n    95→\n    96→            uxMessages.forEach((uxMessage) => {\n    97→              if (uxMessage.type === 'copilot' && uxMessage.copilotMessageType === 'markdown') {\n    98→                const { markdownContent, references } = uxMessage;\n    99→                if (tracer && !firstChunkEmitted && !firstChatTextReceived) {\n   100→                  searchingAndReasoningSpan?.end({ nonRenderableUpdates: preRenderUpdateCount });\n   101→                  parserBufferingSpan = tracer.start('parser_buffering_markdown');\n   102→                  firstChatTextReceived = true;\n   103→                }\n   104→\n   105→                // Always sync metadata from the authoritative snapshot.\n   106→                currentMessageId = uxMessage.messageId;\n   107→                lastReferences = references;\n   108→\n   109→                if (hasAuthoritativeSeed && !isComplete) {\n   110→                  // After the initial seed, writeAtCursor owns the parser.\n   111→                  // Don't rewind accumulatedMarkdown or call parse() — the\n   112→                  // writeAtCursor path has advanced the parser state beyond\n   113→                  // this snapshot and re-parsing shorter markdown would cause\n   114→                  // duplicate emissions.\n   115→                  return;\n   116→                }\n   117→\n   118→                // For completion, always use the authoritative snapshot markdown.\n   119→                // It may be shorter if Sydney truncated or corrected the answer.\n   120→                // The parser's mutation detection will reconcile the DOM.\n   121→                const mdToParse = markdownContent;\n   122→\n   123→                if (!hasAuthoritativeSeed) {\n   124→                  hasAuthoritativeSeed = true;\n   125→                }\n   126→                accumulatedMarkdown = mdToParse;\n   127→\n   128→                const parsedContent = parse(mdToParse, {\n   129→                  references,\n   130→                  isComplete,\n   131→                  messageId: uxMessage.messageId\n   132→                });\n   133→                emitResultToStream(parsedContent, controller);\n   134→                if (!firstChunkEmitted && parsedContent?.html) {\n   135→                  timeToFirstContentSpan?.end();\n   136→                  parserBufferingSpan?.end({ charsBeforeRender: preRenderTotalChars });\n   137→                  streamingSpan = tracer?.start('streaming_chunks');\n   138→                  markEvent(perfTracker, 'first_chunk_emitted');\n   139→                  firstChunkEmitted = true;\n   140→                }\n   141→              }\n   142→            });\n   143→          }\n   144→        });\n   145→      };\n   146→\n   147→      const onUpdate = (response: GetMessagesResponse) => {\n   148→        if (!firstOnUpdateReceived) {\n   149→          waitingForSydneySpan?.end();\n   150→          searchingAndReasoningSpan = tracer?.start('sydney_searching_and_reasoning');\n   151→          markEvent(perfTracker, 'first_on_update_received');\n   152→          firstOnUpdateReceived = true;\n   153→        }\n   154→        if (tracer && !firstChunkEmitted) {\n   155→          preRenderUpdateCount += 1;\n   156→          const messages = response.messages ?? [];\n   157→          preRenderTotalChars += messages.reduce((sum, currentMessage) => sum + currentMessage.text.length, 0);\n   158→        }\n   159→        // writeAtCursor: process synchronously to preserve ~100ms temporal spacing\n   160→        // from Sydney. The parser's 48ms emit throttle requires real time between\n   161→        // calls — promise-chain scheduling compresses them into a single tick.\n   162→        // hasAuthoritativeSeed prevents the pre-seed race (tokens before the first\n   163→        // snapshot are safely dropped). After seeding, processResponse only syncs\n   164→        // metadata (never calls parse), so there's no parser state conflict.\n   165→        const { writeAtCursor } = response;\n   166→        if (writeAtCursor && hasAuthoritativeSeed) {\n   167→          accumulatedMarkdown += writeAtCursor;\n   168→          try {\n   169→            const parsedContent = parse(accumulatedMarkdown, {\n   170→              references: lastReferences,\n   171→              isComplete: false,\n   172→              messageId: currentMessageId\n   173→            });\n   174→            emitResultToStream(parsedContent, controller);\n   175→            if (!firstChunkEmitted && parsedContent?.html) {\n   176→              timeToFirstContentSpan?.end();\n   177→              parserBufferingSpan?.end({ charsBeforeRender: preRenderTotalChars });\n   178→              streamingSpan = tracer?.start('streaming_chunks');\n   179→              markEvent(perfTracker, 'first_chunk_emitted');\n   180→              firstChunkEmitted = true;\n   181→            }\n   182→          } catch {\n   183→            // Don't break streaming on parse errors — the next snapshot\n   184→            // or completion will provide authoritative content.\n   185→          }\n   186→          return;\n   187→        }\n   188→\n   189→        // Snapshot / non-writeAtCursor: process through the async promise chain.\n   190→        lastPendingUpdate = lastPendingUpdate\n   191→          .then(() => processResponse(response, false))\n   192→          .catch(() => {\n   193→            // Skip onUpdate errors to allow stream to continue.\n   194→          });\n   195→      };\n   196→\n   197→      const setSydneyTimestamp = (marker: SydneyTimestampType) => {\n   198→        if (typeof marker === 'string') {\n   199→          markEvent(perfTracker, addSydneyPrefix(marker));\n   200→        } else if (typeof marker.name === 'string') {\n   201→          markEvent(perfTracker, addSydneyPrefix(marker.name));\n   202→        }\n   203→      };\n   204→\n   205→      const clientSpan = tracer?.start('create_sydney_client');\n   206→      const warmupLookupResult =\n   207→        warmupRequestKey === undefined\n   208→          ? undefined\n   209→          : findWarmSydneyClientForRequest({\n   210→              clientRequestId: warmupRequestKey,\n   211→              authHeader,\n   212→              tenantId,\n   213→              objectId,\n   214→              onUpdate,\n   215→              setSydneyTimestamp\n   216→            });\n   217→\n   218→      const warmSydneyClientResult = warmupLookupResult?.found;\n   219→      const warmSydneyClient = warmSydneyClientResult?.client;\n   220→\n   221→      if (warmSydneyClient) {\n   222→        markEvent(perfTracker, 'warm_client_used');\n   223→        const now = Date.now();\n   224→        perfTracker.events['warm_client_age_ms'] = now - warmSydneyClientResult.warmupStartedTimestamp;\n   225→        perfTracker.events['warm_client_connection_established_before_chat'] =\n   226→          warmSydneyClientResult.connectionEstablishedTimestamp === undefined ? 0 : 1;\n   227→\n   228→        if (warmSydneyClientResult.connectionStartTimestamp !== undefined) {\n   229→          perfTracker.events['warm_client_connection_start_age_ms'] =\n   230→            now - warmSydneyClientResult.connectionStartTimestamp;\n   231→        }\n   232→\n   233→        if (warmSydneyClientResult.connectionEstablishedTimestamp !== undefined) {\n   234→          perfTracker.events['warm_client_connection_established_age_ms'] =\n   235→            now - warmSydneyClientResult.connectionEstablishedTimestamp;\n   236→        }\n   237→      } else if (warmupRequestKey === undefined) {\n   238→        markEvent(perfTracker, 'warm_client_not_requested');\n   239→      } else {\n   240→        markEvent(perfTracker, 'warm_client_missed');\n   241→        perfTracker.events['warm_client_connection_established_before_chat'] = 0;\n   242→        perfTracker.events['warm_client_miss_reason'] = warmupLookupResult?.missReason ?? WarmClientMissReason.notFound;\n   243→        if (warmupLookupResult?.warmupStartedTimestamp !== undefined) {\n   244→          perfTracker.events['warm_client_age_ms'] = Date.now() - warmupLookupResult.warmupStartedTimestamp;\n   245→        }\n   246→      }\n   247→\n   248→      const sydneyClient: SydneyClient =\n   249→        warmSydneyClient ??\n   250→        createConfiguredSydneyClient({\n   251→          authHeader,\n   252→          tenantId,\n   253→          objectId,\n   254→          onUpdate,\n   255→          setSydneyTimestamp\n   256→        });\n   257→      clientSpan?.end();\n   258→\n   259→      let connectionDestroyed = false;\n   260→      const destroyConnectionOnce = () => {\n   261→        if (!connectionDestroyed) {\n   262→          try {\n   263→            sydneyClient.destroyConnection();\n   264→          } catch (_error) {\n   265→            // best-effort cleanup\n   266→          }\n   267→          connectionDestroyed = true;\n   268→        }\n   269→      };\n   270→\n   271→      const abortHandler = () => {\n   272→        try {\n   273→          controller.close();\n   274→        } catch (_error) {\n   275→          // Controller may already be closed\n   276→        }\n   277→\n   278→        destroyConnectionOnce();\n   279→      };\n   280→\n   281→      signal?.addEventListener('abort', abortHandler);\n   282→\n   283→      const chatSpan = tracer?.start('sydney_chat');\n   284→      const enableSydneyWarmup = warmSydneyClient !== undefined;\n   285→      sydneyClient\n   286→        .chat({\n   287→          message,\n   288→          traceId,\n   289→          conversationId,\n   290→          queryAnnotations,\n   291→          enableSydneyWarmup,\n   292→          plugins: [{ Id: 'BingWebSearch', Source: 'BuiltIn' }]\n   293→        })\n   294→        .then(async (response) => {\n   295→          chatSpan?.end();\n   296→          await lastPendingUpdate;\n   297→\n   298→          if (response) {\n   299→            if (!assignedConversationId && response.conversationId) {\n   300→              assignedConversationId = response.conversationId;\n   301→              emitConversationState({ conversationId: response.conversationId }, controller);\n   302→            }\n   303→\n   304→            await processResponse({ messages: response.messages ?? [], requestId: response.requestId }, true);\n   305→            streamingSpan?.end();\n   306→            markEvent(perfTracker, 'last_chunk_emitted');\n   307→          }\n   308→          emitServerMetrics(perfTracker.events, controller);\n   309→          const traceResults = tracer?.finish();\n   310→          if (traceResults) {\n   311→            emitTraceResults(traceResults, controller);\n   312→          }\n   313→          controller.close();\n   314→        })\n   315→        .catch((error) => {\n   316→          chatSpan?.end({ error: error instanceof Error ? error.message : 'unknown' });\n   317→          emitResultToStream(\n   318→            parseMessages(\n   319→              [{ author: 'bot', text: `A problem occurred [${error?.message || 'unknown'}]\\n`, messageType: 'Chat' }],\n   320→              parse,\n   321→              true\n   322→            ),\n   323→            controller\n   324→          );\n   325→          markEvent(perfTracker, 'sydney_error_emitted');\n   326→          const traceResults = tracer?.finish();\n   327→          if (traceResults) {\n   328→            emitTraceResults(traceResults, controller);\n   329→          }\n   330→          controller.error(error);\n   331→        })\n   332→        .finally(() => {\n   333→          signal?.removeEventListener('abort', abortHandler);\n   334→\n   335→          destroyConnectionOnce();\n   336→\n   337→          markEvent(perfTracker, 'sydney_stream_completed');\n   338→          const logEntry = {\n   339→            timestamp: new Date().toISOString(),\n   340→            category: 'Performance',\n   341→            eventName: 'sydney_stream_complete',\n   342→            message: 'Sydney stream completed',\n   343→            traceId,\n   344→            conversationId,\n   345→            requestStartTime: perfTracker.requestStartTime,\n   346→            ...perfTracker.events\n   347→          };\n   348→\n   349→          // eslint-disable-next-line no-console -- temporary console log for Sydney stream completion and performance metrics, to be replaced with server-side telemetry when available\n   350→          console.log(logEntry);\n   351→        });\n   352→    }\n   353→  });\n   354→};\n   355→"}]},"parent_tool_use_id":"toolu_01XrfUS8UeV8YDsw48sFBkQR","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"787b8bb3-a61c-484c-b734-fd25bc9d72a9"}
