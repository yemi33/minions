{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ha7M9rCp8YM1HVLc2UKe8h","type":"tool_result","content":"     1→// router.ts\n     2→// INCOMING MESSAGE ROUTER - Routes incoming WebSocket messages to appropriate handlers\n     3→//\n     4→// Message Flow:\n     5→// 1. Client → WebSocket → server-handler.ts → THIS ROUTER → handler\n     6→// 2. handler → WebSocket → Client (handlers send responses directly)\n     7→//\n     8→// This router ONLY handles incoming message dispatch, not outgoing responses\n     9→\n    10→import WebSocket from 'ws';\n    11→import { isJsonRpcMessage } from '@officeagent/message-protocol';\n    12→import { logDebug, logError, logInfo, logWarn } from '../logging';\n    13→import { JsonRpcRouter } from './jsonrpc-router';\n    14→\n    15→// Message handler function type\n    16→export type MessageHandler = (message: any, ws: WebSocket) => boolean | Promise<boolean>;\n    17→\n    18→/**\n    19→ * Simple WebSocket message router for INCOMING messages only\n    20→ *\n    21→ * Purpose: Routes incoming messages to registered handlers based on message.type\n    22→ * Scope: INCOMING messages from clients to server\n    23→ *\n    24→ * Note: Handlers are responsible for sending responses back to clients directly\n    25→ *       This router does NOT handle outgoing message routing\n    26→ */\n    27→export class WebSocketRouter {\n    28→    private handlers: Map<string, MessageHandler> = new Map();\n    29→    private jsonRpcRouter: JsonRpcRouter = new JsonRpcRouter();\n    30→\n    31→    /**\n    32→     * Register a handler for a specific message type\n    33→     */\n    34→    registerHandler(messageType: string, handler: MessageHandler): void {\n    35→        this.handlers.set(messageType, handler);\n    36→        logInfo(0x1e0dc018 /* tag_4d2ay */, `📝 Registered WebSocket handler for: ${messageType}`);\n    37→    }\n    38→\n    39→    /**\n    40→     * Route an incoming message to the appropriate handler\n    41→     *\n    42→     * @param rawMessage - Raw message string from WebSocket client\n    43→     * @param ws - WebSocket connection (for handlers to send responses)\n    44→     */\n    45→    async routeMessage(rawMessage: string, ws: WebSocket): Promise<void> {\n    46→        let message: any;\n    47→\n    48→        try {\n    49→            message = JSON.parse(rawMessage);\n    50→        } catch {\n    51→            logError(0x1e0dc017 /* tag_4d2ax */, '❌ Invalid JSON in WebSocket message');\n    52→            return;\n    53→        }\n    54→\n    55→        if (typeof message !== 'object' || message === null) {\n    56→            logWarn(0x1e0dc016 /* tag_4d2aw */, '⚠️  Message is not a valid object');\n    57→            return;\n    58→        }\n    59→\n    60→        // Check if this is a JSON-RPC 2.0 message\n    61→        if (isJsonRpcMessage(message)) {\n    62→            // Delegate to JSON-RPC router\n    63→            try {\n    64→                const handled = await this.jsonRpcRouter.routeJsonRpcMessage(message);\n    65→                if (!handled) {\n    66→                    // 'id' only exists on request/response, not notification\n    67→                    const messageId = 'id' in message ? message.id : 'notification';\n    68→                    logWarn(0x1e0dc015 /* tag_4d2av */, `⚠️  JSON-RPC message was not handled, message id: ${messageId}`);\n    69→                }\n    70→            } catch (error) {\n    71→                logError(0x1e0dc014 /* tag_4d2au */, '❌ Error routing JSON-RPC message:', error);\n    72→            }\n    73→            return;\n    74→        }\n    75→\n    76→        if (!message.type) {\n    77→            logWarn(0x1e0dc013 /* tag_4d2at */, '⚠️  Message does not have a type:');\n    78→            return;\n    79→        }\n    80→\n    81→        const handler = this.handlers.get(message.type);\n    82→        if (handler) {\n    83→            try {\n    84→                const handled = await handler(message, ws);\n    85→                if (!handled) {\n    86→                    logWarn(0x1e0dc012 /* tag_4d2as */, `⚠️  Handler for ${message.type} returned false`);\n    87→                }\n    88→            } catch (error) {\n    89→                logError(0x1e0dc011 /* tag_4d2ar */, `❌ Error in handler for ${message.type}:`, error);\n    90→            }\n    91→        } else {\n    92→            logWarn(0x1e0dc010 /* tag_4d2aq */, `⚠️  No handler registered for message type: ${message.type}`);\n    93→            // Log full message payload locally only\n    94→            logDebug(`Unhandled message payload: ${JSON.stringify(message, null, 2)}`);\n    95→        }\n    96→    }\n    97→\n    98→    /**\n    99→     * Get all registered message types\n   100→     */\n   101→    getRegisteredTypes(): string[] {\n   102→        return Array.from(this.handlers.keys());\n   103→    }\n   104→\n   105→    /**\n   106→     * Get the JSON-RPC router instance for registering JSON-RPC handlers\n   107→     */\n   108→    getJsonRpcRouter(): JsonRpcRouter {\n   109→        return this.jsonRpcRouter;\n   110→    }\n   111→}\n   112→\n   113→// Export singleton instance\n   114→export const wsRouter = new WebSocketRouter();\n   115→"}]},"parent_tool_use_id":"toolu_01D1btGNgUTxKhKd2oyCp7xP","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"e946a567-2dd6-496a-83fc-d3f35870c28b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qh4XsvM1kr3fFgCSsmQK8v","type":"tool_result","content":"     1→import { readFile } from 'fs/promises';\n     2→import { relative, basename, extname, dirname } from 'path';\n     3→import { v4 as uuidv4 } from 'uuid';\n     4→import { logDebug, logError, logInfo, logWarn, wsManager, SendMessageResult } from '@officeagent/core';\n     5→import {\n     6→    MessageType,\n     7→    QueryErrorCode,\n     8→    QueryStatusMessage,\n     9→    QueryStatusType\n    10→} from '@officeagent/message-protocol';\n    11→import { sendHtmlSlideProgressNotification, sendChainOfThoughtNotification } from '../utils';\n    12→import { compressHtmlImages, MAX_HTML_CONTENT_SIZE } from './html-image-compressor';\n    13→\n    14→/**\n    15→ * WebSocketMessengerService\n    16→ *\n    17→ * Responsibility:\n    18→ * - Send WebSocket messages to clients\n    19→ * - Handle QueryStatus messages (file created, document generated, errors, interrupts)\n    20→ * - Manage message serialization and sending\n    21→ *\n    22→ * Design Principles:\n    23→ * - Single Responsibility: Only handles WebSocket communication\n    24→ * - Type-safe: Uses message protocol types\n    25→ * - Testable: No external dependencies beyond WebSocket\n    26→ * - Size-aware: Prevents sending large files inline\n    27→ */\n    28→export class WebSocketMessengerService {\n    29→    constructor(\n    30→        private readonly sessionId: string,\n    31→        private readonly enableJsonRpc: boolean,\n    32→        private readonly enableImageCompression: boolean = true,\n    33→    ) { }\n    34→\n    35→    /**\n    36→     * Process and compress HTML slide content with size validation\n    37→     * @returns The compressed HTML content\n    38→     */\n    39→    private async processHtmlSlideContent(content: string, fileName: string): Promise<string> {\n    40→        const compressedContent = await compressHtmlImages(content);\n    41→        const contentSizeBytes = Buffer.byteLength(compressedContent, 'utf8');\n    42→\n    43→        const originalSizeBytes = Buffer.byteLength(content, 'utf8');\n    44→        logInfo(0x1e09648d /* tag_4cwsn */, `[WebSocketMessenger] HTML slide content size: original ${(originalSizeBytes / 1024).toFixed(2)} KB, compressed ${(contentSizeBytes / 1024).toFixed(2)} KB`);\n    45→\n    46→        // Log warning if still too large after compression (but still send it)\n    47→        if (contentSizeBytes > MAX_HTML_CONTENT_SIZE) {\n    48→            const contentSizeKB = (contentSizeBytes / 1024).toFixed(2);\n    49→            const maxSizeKB = (MAX_HTML_CONTENT_SIZE / 1024).toFixed(0);\n    50→            logWarn(\n    51→                0x1e097101 /* tag_4cxeb */,\n    52→                `[WebSocketMessenger] HTML slide content too large after compression: ${fileName} (${contentSizeKB} KB > ${maxSizeKB} KB limit). Sending anyway.`\n    53→            );\n    54→        } else {\n    55→            logDebug(`[WebSocketMessenger] Sending compressed HTML slide (${(contentSizeBytes / 1024).toFixed(2)} KB)`);\n    56→        }\n    57→\n    58→        return compressedContent;\n    59→    }\n    60→\n    61→    /**\n    62→     * Send a file content created notification\n    63→     */\n    64→    async sendFileCreatedContent(content: string, filePath: string, basePath: string): Promise<void> {\n    65→        if (!wsManager.isConnected()) {\n    66→            logWarn(0x1e085244 /* tag_4cfje */, '[WebSocketMessenger] SendFileCreatedContent: No WebSocket client available for sendFileCreatedContent');\n    67→            return;\n    68→        }\n    69→\n    70→        try {\n    71→            const fileName = basename(filePath);\n    72→            const fileExtension = extname(filePath).toLowerCase();\n    73→\n    74→            if (fileName === 'chainOfThought.txt' && this.enableJsonRpc) {\n    75→                logDebug(`[WebSocketMessenger] SendFileCreatedContent: Sending JSON RPC for chain of thought: ${filePath}`);\n    76→                sendChainOfThoughtNotification(this.sessionId, content);\n    77→            } else if (fileExtension === '.html' && this.enableJsonRpc) {\n    78→                let finalContent = content;\n    79→\n    80→                if (this.enableImageCompression) {\n    81→                    finalContent = await this.processHtmlSlideContent(content, fileName);\n    82→                } else {\n    83→                    logDebug(`[WebSocketMessenger] SendFileCreatedContent: Sending HTML slide (compression disabled): ${filePath}`);\n    84→                }\n    85→\n    86→                // Extract slide ID from filename (e.g., \"01.html\" -> \"01\")\n    87→                const slideId = basename(filePath, '.html');\n    88→\n    89→                sendHtmlSlideProgressNotification(this.sessionId, {\n    90→                    slideHtml: finalContent,\n    91→                    slideId: slideId\n    92→                });\n    93→            } else {\n    94→                logDebug(`[WebSocketMessenger] SendFileCreatedContent: Processing file change for: ${filePath}`);\n    95→\n    96→                // Compress HTML content even in non-JSON-RPC mode\n    97→                let finalContent = content;\n    98→                if (fileExtension === '.html' && this.enableImageCompression) {\n    99→                    finalContent = await this.processHtmlSlideContent(content, fileName);\n   100→                }"}]},"parent_tool_use_id":"toolu_01D1btGNgUTxKhKd2oyCp7xP","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"755cc6c8-5ee6-42e9-b4b8-c70b8fc654f4"}
