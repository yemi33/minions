{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PC75AUStdmYay5mhTKqdQx","type":"tool_result","content":"     1→import { createServerFn } from '@tanstack/react-start';\n     2→import { getRequest } from '@tanstack/react-start/server';\n     3→import { z } from 'zod';\n     4→import { errorsResponses } from '~/core/server/responses/errors';\n     5→import { getSydneyAuthHeader } from '~/core/auth/getSydneyAuthHeader';\n     6→import { createRecordingStream } from '../server/recorder/createRecordingStream';\n     7→import { getReplayStream } from '../server/recorder/getReplayStream';\n     8→import { writeFixture } from '../server/recorder/writeFixture';\n     9→import { SYDNEY_ENDPOINT_URL } from './constants';\n    10→import { getRateLimiterStream } from './utils/getRateLimiterStream';\n    11→import { getSydneyStream } from './utils/getSydneyStream';\n    12→import type { QueryAnnotation, ValidatedBebopApiChatRequestWithAuth } from '@bebopjs/bebop-shared-types';\n    13→\n    14→/** Schema defined inline to avoid zod v3/v4 type inference conflicts */\n    15→const chatRequestSchema = z.object({\n    16→  clientRequestId: z.uuid(),\n    17→  message: z.string().min(1),\n    18→  traceId: z.uuid(),\n    19→  conversationId: z.string().optional(),\n    20→  queryAnnotations: z.array(z.custom<QueryAnnotation>()).optional(),\n    21→  sydneyReplayFixture: z.string().optional(),\n    22→  sydneyRecordMode: z.boolean().optional()\n    23→});\n    24→\n    25→export const requestChat = createServerFn({ method: 'POST' })\n    26→  .inputValidator(chatRequestSchema)\n    27→  .handler(async ({ data, context }) => {\n    28→    try {\n    29→      const {\n    30→        clientRequestId,\n    31→        message,\n    32→        queryAnnotations,\n    33→        traceId,\n    34→        conversationId,\n    35→        sydneyReplayFixture,\n    36→        sydneyRecordMode\n    37→      } = data;\n    38→\n    39→      let sydneyStream: ReadableStream<string>;\n    40→\n    41→      const recorderEnabled = import.meta.env.DEV || process.env.BEBOP_ENABLE_RECORDER === 'true';\n    42→\n    43→      if (sydneyReplayFixture && recorderEnabled) {\n    44→        // REPLAY MODE (dev/test only): serve recorded fixture, skip auth and Sydney entirely\n    45→        sydneyStream = await getReplayStream(sydneyReplayFixture);\n    46→      } else {\n    47→        // LIVE MODE: normal Sydney flow\n    48→        const { auth, serverTokenProvider, perfTracker } = context;\n    49→        const { objectId, tenantId } = auth.identity;\n    50→\n    51→        const request = getRequest();\n    52→        const warmupRequestKey = clientRequestId;\n    53→\n    54→        const authHeader = await getSydneyAuthHeader(\n    55→          serverTokenProvider,\n    56→          `${SYDNEY_ENDPOINT_URL}/${objectId}@${tenantId}`\n    57→        );\n    58→\n    59→        if (!authHeader) {\n    60→          return errorsResponses['Unauthorized']();\n    61→        }\n    62→\n    63→        const chatRequestWithAuth: ValidatedBebopApiChatRequestWithAuth = {\n    64→          message,\n    65→          objectId,\n    66→          tenantId,\n    67→          traceId,\n    68→          queryAnnotations,\n    69→          authHeader,\n    70→          conversationId\n    71→        };\n    72→\n    73→        const signal = request.signal;\n    74→        sydneyStream = getSydneyStream({\n    75→          request: chatRequestWithAuth,\n    76→          warmupRequestKey,\n    77→          signal,\n    78→          perfTracker\n    79→        });\n    80→\n    81→        if (sydneyRecordMode && recorderEnabled) {\n    82→          // RECORD MODE (dev/test only): wrap live stream to capture chunks + timing\n    83→          sydneyStream = sydneyStream.pipeThrough(\n    84→            createRecordingStream(message, (session) => {\n    85→              void writeFixture(session);\n    86→            })\n    87→          );\n    88→        }\n    89→      }\n    90→\n    91→      const rateLimiterStream = getRateLimiterStream();\n    92→      const responseStream = sydneyStream.pipeThrough(rateLimiterStream);\n    93→\n    94→      // Return ReadableStream directly - TanStack Start handles the Response wrapping\n    95→      return responseStream;\n    96→    } catch (error) {\n    97→      // todo move error handling to api level\n    98→      // eslint-disable-next-line no-console -- Error logging for streaming pipeline failures\n    99→      console.error('Error in streaming pipeline:', error);\n   100→      return errorsResponses['InternalServerError']();\n   101→    }\n   102→  });\n   103→"}]},"parent_tool_use_id":"toolu_01XrfUS8UeV8YDsw48sFBkQR","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"71e41221-4512-4eb0-8cfa-48d764dd19e3"}
