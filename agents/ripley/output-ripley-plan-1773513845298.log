{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GbuEgSYUHZdWGpfW6Y3wyk","type":"tool_result","content":"     1→// Global variable set on the index.html page that will tell us the folder where script files are deployed for this application\n     2→/* eslint-disable @typescript-eslint/naming-convention --\n     3→   We use double underscores to denote the global injected variables */\n     4→declare let __loop_script_base_url__: string;\n     5→declare let __loop_script_source__: string;\n     6→/* eslint-enable @typescript-eslint/naming-convention */\n     7→\n     8→// Before doing anything else: set the webpack public path to load relative to the current chunk and add retry logic to the chunk loading.\n     9→import {\n    10→  addRetryToChunkLoader,\n    11→  defaultLocale,\n    12→  getUIDirection,\n    13→  setLocalizationAttributes,\n    14→  setWebpackPublicPath\n    15→} from '@fluidx/utilities';\n    16→addRetryToChunkLoader();\n    17→setWebpackPublicPath(__loop_script_base_url__);\n    18→\n    19→import { prefetchLoopAppUxStrings } from '@fluidx/loop-app-ux';\n    20→import { getLastKnownLocale, AppLogger, logPageLoadPerf, registerGlobalErrorHandlers } from '@fluidx/loop-app-services';\n    21→import { sendTelemetryEvent, wrapInActivity } from '@fluidx/telemetry';\n    22→import { prefetchRoute } from './Routes/prefetchRoute';\n    23→import { getAudience } from './App/Audience';\n    24→\n    25→import { AppLoggerTelemetryContext } from './Telemetry/AppLoggerTelemetryContext';\n    26→import { getScriptBaseUrl } from './App/buildTimeConstants';\n    27→\n    28→const HoopNamespaceForTelemetry = 'LoopRecentsInHosts';\n    29→\n    30→const loadApp = () => {\n    31→  // creating an appSessionId to be used across the app and passed to the AppLoggerTelemetryContext\n    32→  const appSessionId = crypto.randomUUID();\n    33→\n    34→  const fluidLogger = new AppLogger(\n    35→    {\n    36→      audience: getAudience(),\n    37→      hostTelemetryContext: new AppLoggerTelemetryContext(appSessionId),\n    38→      persistentProps: undefined,\n    39→      namespace: HoopNamespaceForTelemetry,\n    40→      delayLoadLogger: true\n    41→    },\n    42→    getScriptBaseUrl(),\n    43→    false /* enableTelemetrySinkFallback — default is false. The fallback mechanism will first be tested in the main Loop App. */\n    44→  );\n    45→\n    46→  // Send the AppStart signal as early as possible, so even if we crash due to some error, we do log the AppStart signal\n    47→  sendTelemetryEvent(fluidLogger, { eventName: 'AppStarted' });\n    48→\n    49→  registerGlobalErrorHandlers(fluidLogger);\n    50→  logPageLoadPerf(fluidLogger);\n    51→\n    52→  // Prefetch the route we expect to load for the current URL\n    53→  prefetchRoute(location.pathname);\n    54→\n    55→  const appModulePromise = import(/* webpackChunkName: \"HoopApp\" */ './App');\n    56→\n    57→  // Prefetch the string table in parallel to the other modules\n    58→  const lastKnownLocale = getLastKnownLocale();\n    59→  if (lastKnownLocale) {\n    60→    prefetchLoopAppUxStrings(lastKnownLocale, fluidLogger);\n    61→  }\n    62→\n    63→  // For web compliance\n    64→  setLocalizationAttributes({\n    65→    lang: lastKnownLocale || defaultLocale,\n    66→    dir: getUIDirection(lastKnownLocale || defaultLocale)\n    67→  });\n    68→\n    69→  const renderApp = async () => {\n    70→    const hostingDiv = document.createElement('div');\n    71→    document.body.appendChild(hostingDiv);\n    72→\n    73→    const appModule = await wrapInActivity(() => appModulePromise, 'HoopLoadApp', fluidLogger, {\n    74→      addUserTiming: true,\n    75→      additionalPropsToLog: { scriptSource: __loop_script_source__ || 'unknown' }\n    76→    });\n    77→    await appModule.renderApp(fluidLogger, appSessionId, hostingDiv);\n    78→  };\n    79→\n    80→  return renderApp;\n    81→};\n    82→\n    83→const queryParams = new URLSearchParams(window.location.search);\n    84→\n    85→if (queryParams.has('mockApp')) {\n    86→  // Whenever we run the app locally, we don't have either a scriptVersion nor a PR id that we can use to fetch the files from.\n    87→  // We also don't want to put the mock files directly under versioned on the build artifact to avoid deploying these files alongside the app's in Production.\n    88→  // Because of this, we use `.loop-app/lib/` to go back a folder, and go into the mocks directory.\n    89→  const scriptVersion = Number(queryParams.get('scriptVersion') || queryParams.get('pr')) || '..';\n    90→\n    91→  const mocksUrl = `${__loop_script_base_url__.replace('hashed/', '')}versioned/${scriptVersion}/mocks/mocks.js`;\n    92→\n    93→  const head = document.getElementsByTagName('head')[0];\n    94→  const script = document.createElement('script');\n    95→  script.type = 'text/javascript';\n    96→\n    97→  /* eslint-disable-next-line @fluidx/ffx-rules/require-trusted-script-url-in-html-script-element --\n    98→    TODO: Known issue, need to wrap the mocksUrl with trusted types policy, create bug item for tracking - https://office.visualstudio.com/OC/_workitems/edit/8872863\n    99→  */\n   100→  script.src = mocksUrl;\n   101→\n   102→  // Ensure mocks were properly loaded before loading the rest of the app\n   103→  script.onload = async () => {\n   104→    const renderApp = loadApp();\n   105→    await renderApp();\n   106→  };\n   107→\n   108→  head.appendChild(script);\n   109→} else {\n   110→  const renderApp = loadApp();\n   111→\n   112→  const readyState = document.readyState;\n   113→  if (readyState === 'interactive' || readyState === 'complete') {\n   114→    renderApp();\n   115→  } else {\n   116→    window.addEventListener('DOMContentLoaded', renderApp);\n   117→  }\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_01LamMSZH4D3xtZzNhF4Uoq8","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"9a51e0d0-7169-4f3d-bf40-a32601e12914"}
