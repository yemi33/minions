{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BKjp3veo8W5haC36BYogmo","type":"tool_result","content":"     1→import { SYDNEY_CONFIG } from '@bebopjs/bebop-shared-config';\n     2→import { createSydneyClient } from '@bebopjs/bebop-sydney-client';\n     3→import { getWebSocketConstructor } from './getWebSocketConstructor';\n     4→import { mergeCommaSeparated } from './mergeCommaSeparated';\n     5→import type { GetMessagesResponse, SydneyTimestampType } from '@bebopjs/bebop-shared-types';\n     6→\n     7→interface SydneyClientConfig {\n     8→  authHeader: string;\n     9→  tenantId: string;\n    10→  objectId: string;\n    11→  onUpdate: (response: GetMessagesResponse) => void;\n    12→  addSydneyOptions?: string;\n    13→  addSydneyVariants?: string;\n    14→  setSydneyTimestamp?: (marker: SydneyTimestampType) => void;\n    15→}\n    16→\n    17→export const createConfiguredSydneyClient = (config: SydneyClientConfig) => {\n    18→  const { addSydneyOptions, addSydneyVariants } = config;\n    19→\n    20→  return createSydneyClient({\n    21→    ...SYDNEY_CONFIG,\n    22→    sydneyToken: config.authHeader,\n    23→    useAuthHeader: true,\n    24→    substrateToken: '',\n    25→    accountInfo: {\n    26→      tenantId: config.tenantId,\n    27→      objectId: config.objectId\n    28→    },\n    29→    onUpdate: config.onUpdate,\n    30→    webSocketConstructor: getWebSocketConstructor(),\n    31→    // Merge additional options/variants if provided\n    32→    optionsSets: addSydneyOptions\n    33→      ? mergeCommaSeparated(SYDNEY_CONFIG.optionsSets, addSydneyOptions)\n    34→      : SYDNEY_CONFIG.optionsSets,\n    35→    variants: addSydneyVariants\n    36→      ? mergeCommaSeparated(SYDNEY_CONFIG.variants, addSydneyVariants)\n    37→      : SYDNEY_CONFIG.variants,\n    38→    setSydneyTimestamp: config.setSydneyTimestamp\n    39→  });\n    40→};\n    41→"}]},"parent_tool_use_id":"toolu_01LamMSZH4D3xtZzNhF4Uoq8","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"950b1370-9701-4eb0-8138-e5b69152d619"}
