{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012zVUh6dVyBDGYjHSHCA1Pb","type":"tool_result","content":"     1→import { useState } from 'react';\n     2→import { conversationIdAtom, useChatOrchestration, useLoAFSpan, useReplayFixturePrompt } from '@bebopjs/bebop-ux';\n     3→import { useAtomValue } from 'jotai';\n     4→import { ChatPrompt } from './ChatPrompt';\n     5→import type { Status } from '@bebopjs/bebop-response-mapping';\n     6→import type { FC } from 'react';\n     7→\n     8→/*\n     9→ * Prompter component using Jotai atoms for message state management.\n    10→ * Uses useChatOrchestration for the prompt/response flow with Jotai message atoms.\n    11→ * This contrasts with DirectDOMPrompter which uses streaming HTML rendering.\n    12→ **/\n    13→export const JotaiChatPromptWrapper: FC = () => {\n    14→  const { startSpan, endSpan } = useLoAFSpan();\n    15→  const [responseStatus, setResponseStatus] = useState<Status | null>(null);\n    16→  const conversationId = useAtomValue(conversationIdAtom);\n    17→  const initialPrompt = useReplayFixturePrompt();\n    18→\n    19→  const { submitPrompt, abortControllerRef } = useChatOrchestration({\n    20→    onResponseComplete: () => {\n    21→      endSpan();\n    22→      setResponseStatus('complete');\n    23→    }\n    24→  });\n    25→\n    26→  return (\n    27→    <ChatPrompt\n    28→      startSpan={startSpan}\n    29→      endSpan={endSpan}\n    30→      responseStatus={responseStatus}\n    31→      setResponseStatus={setResponseStatus}\n    32→      submitPrompt={submitPrompt}\n    33→      abortControllerRef={abortControllerRef}\n    34→      conversationId={conversationId}\n    35→      initialPrompt={initialPrompt}\n    36→    />\n    37→  );\n    38→};\n    39→"}]},"parent_tool_use_id":"toolu_01XrfUS8UeV8YDsw48sFBkQR","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"1802b7cb-3794-4664-873e-2845ce72d9e4"}
