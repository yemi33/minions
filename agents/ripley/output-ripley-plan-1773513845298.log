{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VTTeC32K4dmRMEWBshudEe","type":"tool_result","content":"     1→import { createConfiguredSydneyClient } from './createConfiguredSydneyClient';\n     2→import type { SydneyClient } from '@bebopjs/bebop-sydney-client';\n     3→import type { GetMessagesResponse, SydneyTimestampType } from '@bebopjs/bebop-shared-types';\n     4→\n     5→interface SydneyClientHandlers {\n     6→  onUpdate: (response: GetMessagesResponse) => void;\n     7→  setSydneyTimestamp?: (marker: SydneyTimestampType) => void;\n     8→}\n     9→\n    10→interface WarmupConnectionTimestamps {\n    11→  connectionStartTimestamp?: number;\n    12→  connectionEstablishedTimestamp?: number;\n    13→}\n    14→\n    15→interface WarmupCacheEntry {\n    16→  client: SydneyClient;\n    17→  handlers: SydneyClientHandlers;\n    18→  authHeader: string;\n    19→  tenantId: string;\n    20→  objectId: string;\n    21→  createdTimestamp: number;\n    22→  warmupStartedTimestamp: number;\n    23→  timestamps: WarmupConnectionTimestamps;\n    24→}\n    25→\n    26→interface WarmUpSydneyClientForRequestParams {\n    27→  clientRequestId: string;\n    28→  authHeader: string;\n    29→  tenantId: string;\n    30→  objectId: string;\n    31→  traceId: string;\n    32→  conversationId?: string;\n    33→}\n    34→\n    35→interface FindWarmSydneyClientForRequestParams {\n    36→  clientRequestId: string;\n    37→  authHeader: string;\n    38→  tenantId: string;\n    39→  objectId: string;\n    40→  onUpdate: (response: GetMessagesResponse) => void;\n    41→  setSydneyTimestamp?: (marker: SydneyTimestampType) => void;\n    42→}\n    43→\n    44→/**\n    45→ * Reason codes for why a warm client lookup failed.\n    46→ * Encoded as numbers for compatibility with PerfTracker events.\n    47→ */\n    48→export const WarmClientMissReason = {\n    49→  /** Entry was not found in cache and was never created for this request */\n    50→  notFound: 1,\n    51→  /** Auth credentials (authHeader, tenantId, objectId) changed between warmup and chat */\n    52→  identityMismatch: 2,\n    53→  /** warmup() threw during initialization and the entry was removed */\n    54→  warmupInitFailed: 3,\n    55→  /** Entry existed but was removed by TTL cleanup before the chat request arrived */\n    56→  expired: 4\n    57→} as const;\n    58→\n    59→export type WarmClientMissReasonValue = (typeof WarmClientMissReason)[keyof typeof WarmClientMissReason];\n    60→\n    61→export interface WarmSydneyClientForRequestResult {\n    62→  client: SydneyClient;\n    63→  warmupStartedTimestamp: number;\n    64→  connectionStartTimestamp?: number;\n    65→  connectionEstablishedTimestamp?: number;\n    66→}\n    67→\n    68→export interface WarmSydneyClientLookupResult {\n    69→  found: WarmSydneyClientForRequestResult | undefined;\n    70→  missReason?: WarmClientMissReasonValue;\n    71→  /** Available on both hit and miss paths (when trackable) to measure warmup-to-chat delay */\n    72→  warmupStartedTimestamp?: number;\n    73→}\n    74→\n    75→interface ExpiredOrFailedEntry {\n    76→  recordedAt: number;\n    77→  warmupStartedTimestamp: number;\n    78→}\n    79→\n    80→const WARMUP_REQUEST_TTL_MS = 60 * 1000;\n    81→/** How long to retain miss-reason metadata after a warmup entry is removed */\n    82→const MISS_REASON_RETENTION_MS = 10 * 60 * 1000;\n    83→const warmupRequestCache = new Map<string, WarmupCacheEntry>();\n    84→const failedWarmupRequests = new Map<string, ExpiredOrFailedEntry>();\n    85→const expiredWarmupRequests = new Map<string, ExpiredOrFailedEntry>();\n    86→\n    87→const safelyDestroyClient = (client: SydneyClient): void => {\n    88→  try {\n    89→    client.destroyConnection();\n    90→  } catch (_error) {\n    91→    // best-effort cleanup\n    92→  }\n    93→};\n    94→\n    95→const getTimestampMarkerName = (marker: SydneyTimestampType): string | undefined => {\n    96→  if (typeof marker === 'string') {\n    97→    return marker;\n    98→  }\n    99→\n   100→  if (typeof marker.name === 'string') {\n   101→    return marker.name;\n   102→  }\n   103→\n   104→  return undefined;\n   105→};\n   106→\n   107→const cleanupExpiredEntries = (): void => {\n   108→  const now = Date.now();\n   109→\n   110→  for (const [key, entry] of warmupRequestCache.entries()) {\n   111→    if (now - entry.createdTimestamp > WARMUP_REQUEST_TTL_MS) {\n   112→      safelyDestroyClient(entry.client);\n   113→      warmupRequestCache.delete(key);\n   114→      expiredWarmupRequests.set(key, { recordedAt: now, warmupStartedTimestamp: entry.warmupStartedTimestamp });\n   115→    }\n   116→  }\n   117→\n   118→  for (const [key, { recordedAt }] of failedWarmupRequests.entries()) {\n   119→    if (now - recordedAt > MISS_REASON_RETENTION_MS) {\n   120→      failedWarmupRequests.delete(key);\n   121→    }\n   122→  }\n   123→\n   124→  for (const [key, { recordedAt }] of expiredWarmupRequests.entries()) {\n   125→    if (now - recordedAt > MISS_REASON_RETENTION_MS) {\n   126→      expiredWarmupRequests.delete(key);\n   127→    }\n   128→  }\n   129→};\n   130→\n   131→export const warmUpSydneyClientForRequest = (params: WarmUpSydneyClientForRequestParams): void => {\n   132→  cleanupExpiredEntries();\n   133→\n   134→  const { clientRequestId, authHeader, tenantId, objectId, traceId, conversationId } = params;\n   135→  const existing = warmupRequestCache.get(clientRequestId);\n   136→  if (existing) {\n   137→    safelyDestroyClient(existing.client);\n   138→    warmupRequestCache.delete(clientRequestId);\n   139→  }\n   140→\n   141→  const handlers: SydneyClientHandlers = {\n   142→    onUpdate: () => {\n   143→      // Warmup path doesn't need incremental updates.\n   144→    }\n   145→  };\n   146→\n   147→  const warmupStartedTimestamp = Date.now();\n   148→  const timestamps: WarmupConnectionTimestamps = {};\n   149→\n   150→  const client = createConfiguredSydneyClient({\n   151→    authHeader,\n   152→    tenantId,\n   153→    objectId,\n   154→    onUpdate: (response: GetMessagesResponse) => {\n   155→      handlers.onUpdate(response);\n   156→    },\n   157→    setSydneyTimestamp: (marker: SydneyTimestampType) => {\n   158→      const markerName = getTimestampMarkerName(marker);\n   159→      const markerTimestamp = Date.now();\n   160→      if (markerName === 'ConnectionStart' && timestamps.connectionStartTimestamp === undefined) {\n   161→        timestamps.connectionStartTimestamp = markerTimestamp;\n   162→      }\n   163→      if (markerName === 'ConnectionEstablished' && timestamps.connectionEstablishedTimestamp === undefined) {\n   164→        timestamps.connectionEstablishedTimestamp = markerTimestamp;\n   165→      }\n   166→      handlers.setSydneyTimestamp?.(marker);\n   167→    }\n   168→  });\n   169→\n   170→  warmupRequestCache.set(clientRequestId, {\n   171→    client,\n   172→    handlers,\n   173→    authHeader,\n   174→    tenantId,\n   175→    objectId,\n   176→    createdTimestamp: Date.now(),\n   177→    warmupStartedTimestamp,\n   178→    timestamps\n   179→  });\n   180→\n   181→  try {\n   182→    client.warmup(undefined, traceId, conversationId);\n   183→  } catch (_error) {\n   184→    safelyDestroyClient(client);\n   185→    warmupRequestCache.delete(clientRequestId);\n   186→    failedWarmupRequests.set(clientRequestId, { recordedAt: Date.now(), warmupStartedTimestamp });\n   187→  }\n   188→};\n   189→\n   190→export const findWarmSydneyClientForRequest = (\n   191→  params: FindWarmSydneyClientForRequestParams\n   192→): WarmSydneyClientLookupResult => {\n   193→  const { clientRequestId, authHeader, tenantId, objectId, onUpdate, setSydneyTimestamp } = params;\n   194→\n   195→  // Retrieve the entry before cleanup so a request arriving just past the TTL\n   196→  // boundary doesn't destroy the connection it is about to consume.\n   197→  const entry = warmupRequestCache.get(clientRequestId);\n   198→  if (entry) {\n   199→    warmupRequestCache.delete(clientRequestId);\n   200→  }\n   201→\n   202→  cleanupExpiredEntries();\n   203→\n   204→  if (!entry) {\n   205→    let reason: WarmClientMissReasonValue;\n   206→    let warmupStartedTimestamp: number | undefined;\n   207→    if (failedWarmupRequests.has(clientRequestId)) {\n   208→      reason = WarmClientMissReason.warmupInitFailed;\n   209→      warmupStartedTimestamp = failedWarmupRequests.get(clientRequestId)?.warmupStartedTimestamp;\n   210→      failedWarmupRequests.delete(clientRequestId);\n   211→    } else if (expiredWarmupRequests.has(clientRequestId)) {\n   212→      reason = WarmClientMissReason.expired;\n   213→      warmupStartedTimestamp = expiredWarmupRequests.get(clientRequestId)?.warmupStartedTimestamp;\n   214→      expiredWarmupRequests.delete(clientRequestId);\n   215→    } else {\n   216→      reason = WarmClientMissReason.notFound;\n   217→    }\n   218→    return { found: undefined, missReason: reason, warmupStartedTimestamp };\n   219→  }\n   220→\n   221→  const isMismatchedIdentity =\n   222→    entry.authHeader !== authHeader || entry.tenantId !== tenantId || entry.objectId !== objectId;\n   223→\n   224→  if (isMismatchedIdentity) {\n   225→    safelyDestroyClient(entry.client);\n   226→    return {\n   227→      found: undefined,\n   228→      missReason: WarmClientMissReason.identityMismatch,\n   229→      warmupStartedTimestamp: entry.warmupStartedTimestamp\n   230→    };\n   231→  }\n   232→\n   233→  entry.handlers.onUpdate = onUpdate;\n   234→  entry.handlers.setSydneyTimestamp = setSydneyTimestamp;\n   235→\n   236→  if (setSydneyTimestamp) {\n   237→    if (entry.timestamps.connectionStartTimestamp !== undefined) {\n   238→      setSydneyTimestamp('ConnectionStart');\n   239→    }\n   240→    if (entry.timestamps.connectionEstablishedTimestamp !== undefined) {\n   241→      setSydneyTimestamp('ConnectionEstablished');\n   242→    }\n   243→  }\n   244→\n   245→  return {\n   246→    found: {\n   247→      client: entry.client,\n   248→      warmupStartedTimestamp: entry.warmupStartedTimestamp,\n   249→      connectionStartTimestamp: entry.timestamps.connectionStartTimestamp,\n   250→      connectionEstablishedTimestamp: entry.timestamps.connectionEstablishedTimestamp\n   251→    }\n   252→  };\n   253→};\n   254→"}]},"parent_tool_use_id":"toolu_01LamMSZH4D3xtZzNhF4Uoq8","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"4d381bfc-5fd3-4311-bb95-792d8d4f53a9"}
