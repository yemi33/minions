50→        }\n    51→    };\n    52→\n    53→    const completionNotification = new OfficeAgentTaskUpdateNotification(updateMessage);\n    54→    wsManager.sendMessage(completionNotification);\n    55→    logInfo(0x1e0dc3ce /* tag_4d2po */, '📤 Sent task completion notification via JSON-RPC');\n    56→}\n    57→\n    58→/**\n    59→ * Sends an artifact generation notification via JSON-RPC WebSocket\n    60→ * @param requestId - Request ID for tracking the task\n    61→ * @param artifactInfo - Information about the generated artifact\n    62→ */\n    63→export function sendArtifactGenerationNotification(\n    64→    requestId: string,\n    65→    artifactInfo: {\n    66→        filename: string;\n    67→        path: string;\n    68→        type: ArtifactType | string;\n    69→    }\n    70→): void {\n    71→    const progressMessage: SydneyProgressMessage = {\n    72→        messageType: SydneyMessageType.Progress,\n    73→        author: SydneyMessageAuthorType.Bot,\n    74→        text: `Generated ${artifactInfo.filename}`,\n    75→        requestId: requestId,\n    76→        contentGenerationProgressList: [{\n    77→            artifacts: {\n    78→                path: artifactInfo.path,\n    79→                filename: artifactInfo.filename,\n    80→                type: artifactInfo.type\n    81→            }\n    82→        }]\n    83→    };\n    84→\n    85→    const message: OfficeAgentSydneyTaskUpdateMessage = {\n    86→        type: TaskUpdateType.ArtifactGenerated,\n    87→        progressMessage\n    88→    };\n    89→\n    90→    const artifactNotification = new OfficeAgentTaskUpdateNotification(message);\n    91→    wsManager.sendMessage(artifactNotification);\n    92→    logInfo(0x1e0dc3cd /* tag_4d2pn */, `📤 Sent artifact generation notification via JSON-RPC: ${artifactInfo.type}`);\n    93→}\n    94→\n    95→/**\n    96→ * Sends a chat message via JSON-RPC WebSocket\n    97→ * @param requestId - Request ID for tracking the message\n    98→ * @para