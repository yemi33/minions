S,\n    49→  TEXT_MATCH_TRANSFORMERS,\n    50→  Tooltip,\n    51→  VoiceButton,\n    52→  lazyVoiceOverlayImport,\n    53→  useAttachments,\n    54→  useFileDragDrop,\n    55→  usePastedUrlAttachments,\n    56→  useSydneyQueryAnnotations\n    57→} from '@bebopjs/bebop-ux';\n    58→import { useWebRTCControls } from '@bebopjs/bebop-webrtc';\n    59→import { useAtom, useSetAtom } from 'jotai';\n    60→import { $createParagraphNode, $createTextNode, $getRoot } from 'lexical';\n    61→import { useOnComponentInteractive } from '~/core/performance/hooks/useOnComponentInteractive';\n    62→import { Prefetch } from '~/core/performance/utils/prefetch/components';\n    63→import { showVoiceOverlayAtom } from '../../atoms/voiceInteractionAtoms';\n    64→import { ChatInputTools } from './ChatInputTools';\n    65→import styles from './ChatInput.module.css';\n    66→import type { EditorState, LexicalEditor } from 'lexical';\n    67→import type { FunctionComponent, ReactNode, RefObject } from 'react';\n    68→import type { PromptParameters } from '@bebopjs/bebop-ux';\n    69→import type { Status } from '@bebopjs/bebop-response-mapping';\n    70→\n    71→// Custom transformers list that excludes MULTILINE_ELEMENT_TRANSFORMERS (CODE)\n    72→// to avoid pulling in @lexical/code and prismjs (~100KB+ of syntax highlighting grammars)\n    73→const CHAT_TRANSFORMERS = [...ELEMENT_TRANSFORMERS, ...TEXT_FORMAT_TRANSFORMERS, ...TEXT_MATCH_TRANSFORMERS];\n    74→\n    75→interface ChatInputProps {\n    76→  onInteractionStart?: () => void;\n    77→  onSubmitPromptStart?: () => void;\n    78→  onUpdateInput?: () => void;\n    79→  onClearInput?: () => void;\n    80→  submitPrompt: (parameters: PromptParameters) => void;\n    81→  responseStatus?: Status | null;\n    82→  setResponseStatus?: (status: Status | null) => void;\n    83→  abortControllerRef?: RefObject<AbortController | null>;\n    84→  conversationId?: string;\n    85→  initialPrompt?: string;\n    86→}\n    87→\n    88→export const ChatInput: FunctionComponent<ChatInputProps> = ({\n    89→  onInteractionStart,\n    90→  onSubmitPromptStart,\n    91→  onUpdateInput,\n    92→  onClearInput,\n    93→  submitPrompt,\n    94→  responseStatus,\n    95→  setResponseStatus,\n    96→  abortControllerRef,\n    97→  conversationId,\n    98→  initialPrompt\n    99→}) => {\n   100→  const logger = useLogger();\n   101→\n   102→  useOnComponentInteractive(() => {\n   103→    performance.mark('chatInputInteractive');\n   104→    saveToPageTimings('chatInputInteractive');\n   105→    logger.initialize();\n   106→  });\n   107→\n   108→  const [selectedText, setSelectedText] = useAtom(selectedTextAtom);\n   109→  const setShowVoiceOverlay = useSetAtom(showVoiceOverlayAtom);\n   110→  const { translate } = useTranslations(['CopilotChatInput']);\n   111→  const { isFileHovered } = useFileDragDrop();\n   112→  const { load: loadWebRTC } = useWebRTCControls();\n   113→\n   114→  const editorRef = useRef<LexicalEditor | null>(null);\n   115→  const promptRef = useRef<string>('');\n   116→  const hasTriggeredWarmupRef = useRef(false);\n   117→  const clientRequestIdRef = useRef<string | undefined>(undefined);\n   118→  const filePickerRef = useRef<HTMLInputElement>(null);\n   119→  const [hasContent, setHasContent] = useState(() => Boolean(initialPrompt));\n   120→  const initialPromptApplied = useRef(false);\n   121→\n   122→  // Pre-populate editor with initialPrompt (e.g. from replay fixture)\n   123→  useEffect(() => {\n   124→    if (!initialPrompt || initialPromptApplied.current || !editorRef.current) {\n   125→      return;\n   126→    }\n   127→    initialPromptApplied.current = true;\n   128→    const editor = editorRef.current;\n   129→    editor.update(() => {\n   130→      const root = $getRoot();\n   131→      root.clear();\n   132→      const paragraph = $createParagraphNode();\n   133→      paragraph.append($createTextNode(initialPrompt));\n   134→      root.append(paragraph);\n   135→    });\n   136→    promptRef.current = initialPrompt;\n   137→  }, [initialPrompt]);\n   138→\n   139→  const openVoiceOverlay = () => setShowVoiceOverlay(true);\n   140→\n   141→  // Pasted URL files state management + lazy rendering\n   142→  const { pastedFiles, hasPastedFiles, clearPastedFiles, onUrlsDetected, renderPastedFileAttachments } =\n   143→    usePastedUrlAttachments({ logger });\n   144→\n   145→  // Render attachments with SelectedTextPill and pasted files inside AttachmentList for proper focus group\n   146→  const renderAttachments = useCallback(\n   147→    (fileAttachments: Array<ReactNode>) => (\n   148→      <AttachmentList>\n   149→        <SelectedTextPill />\n   150→        {renderPastedFileAttachments()}\n   151→        {fileAttachments}\n   152→      </AttachmentList>\n   153→    ),\n   154→    [renderPastedFileAttachments]\n   155→  );\n   156→\n   157→  const { attachments, fileUploadList, onFileSelect, loadFileUpload, clearAttachments, messageBar } = useAttachments({\n   158→    triggerFileUpload: () => filePickerRef.current?.click(),\n   159→    renderAttachments\n   160→  });\n   161→  const { getQueryAnnotations } = useSydneyQueryAnnotations({ fileUploadList, pastedFiles, selectedText });\n   162→\n   163→  const warmupBebopChat = useCallback(\n   164→    async (clientRequestId: string): Promise<void> => {\n   165→      try {\n   166→        await fetch(CONVERSATION_API_ENDPOINT, {\n   167→          method: 'POST',\n   168→          headers: {\n   169→            'Content-Type': 'application/json'\n   170→          },\n   171→          body: JSON.stringify({\n   172→            clientRequestId,\n   173→            traceId: crypto.randomUUID(),\n   174→            isWarmup: true,\n   175→            conversationId\n   176→          })\n   177→        });\n   178→      } catch (_error) {\n   179→        // Best-effort optimization; ignore failures to avoid user-facing impact.\n   180→      }\n   181→    },\n   182→    [conversationId]\n   183→  );\n   184→\n   185→  const handleChange = (editorState: EditorState) => {\n   186→    editorState.read(() => {\n   187→      if (editorRef.current) {\n   188→        const md = $convertToMarkdownString(CHAT_TRANSFORMERS);\n   189→        const trimmedMd = md.trim();\n   190→        promptRef.current = md;\n   191→        setHasContent(trimmedMd.length > 0);\n   192→\n   193→        if (trimmedMd.length > 0) {\n   194→          onUpdateInput?.();\n   195→\n   196→          if (!hasTriggeredWarmupRef.current) {\n   197→            clientRequestIdRef.current ??= crypto.randomUUID();\n   198→            hasTriggeredWarmupRef.current = true;\n   199→            void warmupBebopChat(clientRequestIdRef.current);\n   200→          }\n   201→        } else {\n   202→          onClearInput?.();\n   203→        }\n   204→      }\n   205→    });\n   206→  };\n   207→\n   208→  // When files are detected in pasted content, trigger file selection flow. We need to load\n   209→  // the file upload module to make sure they don't get stuck in the pending state.\n   210→  const onFilesDetected = (files: FileList) => {\n   211→    loadFileUpload();\n   212→    onFileSelect([...files]);\n   213→  };\n   214→\n   215→  // Load FileUploadManager when files are dragged over the window\n   216→  useEffect(() => {\n   217→    if (isFileHovered) {\n   218→      loadFileUpload();\n   219→    }\n   220→  }, [isFileHovered, loadFileUpload]);\n   221→\n   222→  // Check if there's any content to submit (text, files, pasted URLs, or selected text)\n   223→  const hasSubmittableContent = hasContent || hasPastedFiles || selectedText;\n   224→\n   225→  const onSubmit = () => {\n   226→    if (editorRef.current && hasSubmittableContent) {\n   227→      onInteractionStart?.();\n   228→\n   229→      // Set inProgress immediately to show stop button before async work starts\n   230→      setResponseStatus?.('inProgress');\n   231→\n   232→      // Run optional 'start submitting prompt' function to trigger dependant actions\n   233→      onSubmitPromptStart?.();\n   234→\n   235→      const clientRequestId = clientRequestIdRef.current ?? crypto.randomUUID();\n   236→\n   237→      submitPrompt({\n   238→        clientRequestId,\n   239→        prompt: promptRef.current,\n   240→        queryAnnotations: getQueryAnnotations(),\n   241→        attachments: fileUploadList,\n   242→        pastedFiles,\n   243→        selectedText,\n   244→        signal: abortControllerRef?.current?.signal\n   245→      });\n   246→      clearAttachments();\n   247→      clearPastedFiles();\n   248→      setSelectedText(null);\n   249→      setHasContent(false);\n   250→      hasTriggeredWarmupRef.current = false;\n   251→      clientRequestIdRef.current = undefined;\n   252→      promptRef.current = '';\n   253→      editorRef.current.update(() => $setSelection(null));\n   254→      editorRef.current.dispatchCommand(CLEAR_EDITOR_COMMAND, undefined);\n   255→      editorRef.current.getRootElement()?.blur();\n   256→    }\n   257→  };\n   258→\n   259→  const onStopGenerating = () => {\n   260→    abortControllerRef?.current?.abort(ChatAbortReason.StopGeneratingButtonClick);\n   261→  };\n   262→\n   263→  const handleFileDrop = (files: Array<File>) => {\n   264→    onFileSelect(files);\n   265→  };\n   266→\n   267→  const lazyLoadRealtimeVoice = async () => {\n   268→    await Promise.all([lazyVoiceOverlayImport(), loadWebRTC()]);\n   269→  };\n   270→\n   271→  return (\n   272→    <Suspense>\n   273→      <LexicalInput>\n   274→        <div className={styles.chatInput}>\n   275→          <div className={styles.controlsLeft}>\n   276→            <Tooltip content={translate('CopilotChatInput', 'tooltipCapabilities')} relationship=\"label\">\n   277→              <Button appearance=\"subtle\" size=\"large\" shape=\"circular\" icon={<CircleLink20Icon />} />\n   278→            </Tooltip>\n   279→            <Menu>\n   280→              <MenuTrigger>\n   281→                <Tooltip content={translate('CopilotChatInput', 'tooltipAddContent')} relationship=\"label\">\n   282→                  <Button\n   283→                    appearance=\"subtle\"\n   284→                    aria-label={translate('CopilotChatInput', 'ariaLabelUploadButton')}\n   285→                    size=\"large\"\n   286→                    shape=\"circular\"\n   287→                    icon={<Add20Icon />}\n   288→                  />\n   289→                </Tooltip>\n   290→              </MenuTrigger>\n   291→              <MenuPopover className={styles.menuPopover}>\n   292→                <MenuList>\n   293→                  <MenuItem\n   294→                    media={{ children: <ArrowUpload20Icon /> }}\n   295→                    onClick={() => {\n   296→                      loadFileUpload();\n   297→                      filePickerRef.current?.click();\n   298→                    }}\n   299→                  >\n   300→                    {translate('CopilotChatInput', 'labelUploadMenuItem')}\n   301→                  </MenuItem>\n   302→                </MenuList>\n   303→              </MenuPopover>\n   304→            </Menu>\n   305→          </div>\n   306→          <FilePicker ref={filePickerRef} onFileSelect={onFileSelect} acceptedFileTypes={getAcceptedFileTypes()} />\n   307→          <FileDragDrop\n   308→            isOpen={isFileHovered}\n   309→            onFileDrop={handleFileDrop}\n   310→            dropText={translate('CopilotChatInput', 'dropFilesToUpload')}\n   311→          />\n   312→          <div className={styles.controlsMiddle}>\n   313→            <div className={styles.editor}>\n   314→              <div className={styles.attachments}>\n   315→                {messageBar}\n   316→                {/* Show AttachmentList with SelectedTextPill and pasted files when FileUploadManager isn't loaded yet */}\n   317→                {!attachments && (selectedText || hasPastedFiles) && (\n   318→                  <AttachmentList>\n   319→                    <SelectedTextPill />\n   320→                    {renderPastedFileAttachments()}\n   321→                  </AttachmentList>\n   322→                )}\n   323→                {/* FileUploadManager renders AttachmentList with SelectedTextPill, pasted files, and file attachments */}\n   324→                {attachments}\n   325→              </div>\n   326→              <div className={styles.input}>\n   327→                <EditorRefPlugin editorRef={editorRef} />\n   328→                <RichTextPlugin\n   329→                  placeholder={translate('CopilotChatInput', 'placeholderText', { copilotName: 'Copilot' })}\n   330→                />\n   331→                <HistoryPlugin />\n   332→                <ListPlugin />\n   333→                <ClearEditorPlugin />\n   334→                <SoftBreakMarkdownPlugin />\n   335→                <OnChangePlugin onChange={handleChange} />\n   336→                <MarkdownShortcutPlugin transformers={CHAT_TRANSFORMERS} />\n   337→                <ReturnKeyPlugin handleSubmit={onSubmit} />\n   338→                <AutoFocusPlugin />\n   339→                <PasteExtractionPlugin onUrlsDetected={onUrlsDetected} onFilesDetected={onFilesDetected} />\n   340→              </div>\n   341→            </div>\n   342→            <div className={styles.micInput}>\n   343→              <Tooltip content={translate('CopilotChatInput', 'tooltipDictate')} relationship=\"label\">\n   344→                <Button appearance=\"subtle\" shape=\"circular\" size=\"medium\" icon={<Mic20Icon />} />\n   345→              </Tooltip>\n   346→            </div>\n   347→          </div>\n   348→          <div className={styles.controlsRight}>\n   349→            {responseStatus === 'inProgress' ? (\n   350→              <Tooltip content={translate('CopilotChatInput', 'tooltipStopGenerating')} relationship=\"label\">\n   351→                <Button\n   352→                  appearance=\"primary\"\n   353→                  aria-label={translate('CopilotChatInput', 'ariaLabelStopButton')}\n   354→                  shape=\"circular\"\n   355→                  size=\"large\"\n   356→                  onClick={onStopGenerating}\n   357→                  icon={<Stop20Icon />}\n   358→                />\n   359→              </Tooltip>\n   360→            ) : (\n   361→              hasSubmittableContent && (\n   362→                <Tooltip content={translate('CopilotChatInput', 'ariaLabelSendButton')} relationship=\"label\">\n   363→                  <Button\n   364→                    appearance=\"primary\"\n   365→                    aria-label={translate('CopilotChatInput', 'ariaLabelSendButton')}\n   366→                    shape=\"circular\"\n   367→                    size=\"large\"\n   368→                    onClick={onSubmit}\n   369→                    icon={<Submit36Icon />}\n   370→                  />\n   371→                </Tooltip>\n   372→              )\n   373→            )}\n   374→            {!hasSubmittableContent && responseStatus !== 'inProgress' && (\n   375→              <Prefetch id=\"voice-realtime\" on=\"hover\" loader={lazyLoadRealtimeVoice}>\n   376→                <span>\n   377→                  <Tooltip content={translate('CopilotChatInput', 'tooltipVoiceMode')} relationship=\"label\">\n   378→                    <VoiceButton\n   379→                      appearance=\"secondary\"\n   380→                      shape=\"circular\"\n   381→                      size=\"large\"\n   382→                      icon={<DeviceEQ20Icon />}\n   383→                      onClick={openVoiceOverlay}\n   384→                      aria-haspopup=\"dialog\"\n   385→                      aria-controls=\"voice-popover\"\n   386→                    />\n   387→                  </Tooltip>\n   388→                </span>\n   389→              </Prefetch>\n   390→            )}\n   391→          </div>\n   392→        </div>\n   393→        <ChatInputTools />\n   394→      </LexicalInput>\n   39