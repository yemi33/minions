{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CwPwVPsLnwF6Zmoj2HcjLB","type":"tool_result","content":"     1→/**\n     2→ * Office Agent Request Types\n     3→ *\n     4→ * Types specific to the office-agent workflow\n     5→ */\n     6→\n     7→import type { ChatRequest as SydneyChatRequest, Message as SydneyMessage, ProgressMessage as SydneyProgressMessage } from '@augloop-types/sydney';\n     8→import { JsonRpcRequestMessage, JsonRpcNotificationMessage } from '../../base-message';\n     9→import { JsonRpcMethod } from '../../methods';\n    10→import { TaskUpdateType, TaskStatus, TaskError } from './tasks';\n    11→\n    12→/**\n    13→ * Identifies the type/origin of an OfficeAgent request.\n    14→ * Used to distinguish between different request pipelines and enable type-safe handling.\n    15→ */\n    16→export enum OfficeAgentRequestType {\n    17→    /** Request from Sydney/BizChat orchestration layer (via AugLoop) */\n    18→    Sydney = 'sydney',\n    19→}\n    20→\n    21→/**\n    22→ * Base type for office-agent request.\n    23→ * All request types must specify their type for proper routing and handling.\n    24→ */\n    25→export interface OfficeAgentBaseRequest {\n    26→    /**\n    27→     * Identifies the type/origin of this request.\n    28→     * Enables type-safe handling of different request pipelines.\n    29→     */\n    30→    type: OfficeAgentRequestType;\n    31→}\n    32→\n    33→/**\n    34→ * Request originating from BizChat client or Declarative Agent (DA++).\n    35→ * Contains the full Sydney chat request with conversation context.\n    36→ */\n    37→export interface OfficeAgentSydneyRequest extends OfficeAgentBaseRequest {\n    38→    /** Discriminant: Always 'sydney' for BizChat-originated requests */\n    39→    type: OfficeAgentRequestType.Sydney;\n    40→    /** The underlying Sydney chat request */\n    41→    request: SydneyChatRequest;\n    42→}\n    43→\n    44→/**\n    45→ * Type guard to check if a request is from Sydney origin\n    46→ */\n    47→export function isSydneyRequest(request: OfficeAgentBaseRequest): request is OfficeAgentSydneyRequest {\n    48→    return request.type === OfficeAgentRequestType.Sydney;\n    49→}\n    50→\n    51→/**\n    52→ * Base type for chat messages in multi-turn conversations.\n    53→ * All chat types must specify their type for proper handling.\n    54→ */\n    55→export interface OfficeAgentBaseChat {\n    56→}\n    57→\n    58→/**\n    59→ * Chat messages from Sydney-originated conversations.\n    60→ */\n    61→export interface OfficeAgentSydneyChat extends OfficeAgentBaseChat {\n    62→    messages: SydneyMessage[];\n    63→}\n    64→\n    65→export class OfficeAgentRequestMessage extends JsonRpcRequestMessage {\n    66→    constructor(payload: OfficeAgentBaseRequest, id: string) {\n    67→        super(JsonRpcMethod.MessageSend, payload, id);\n    68→    }\n    69→}\n    70→\n    71→export interface OfficeAgentBaseTaskUpdateMessage {\n    72→    /** Type of task update */\n    73→    type: TaskUpdateType;\n    74→\n    75→    /** The current status of the task */\n    76→    status?: TaskStatus;\n    77→\n    78→    error?: TaskError;\n    79→}\n    80→\n    81→export interface OfficeAgentSydneyTaskUpdateMessage extends OfficeAgentBaseTaskUpdateMessage {\n    82→    /** The Sydney progress message */\n    83→    progressMessage: SydneyProgressMessage;\n    84→}\n    85→\n    86→/**\n    87→ * Task update notification - sends updates about a running task to the client\n    88→ * Supports multiple types of task updates (chain of thought, HTML streaming, completion, etc.)\n    89→ */\n    90→export class OfficeAgentTaskUpdateNotification extends JsonRpcNotificationMessage {\n    91→    constructor(params: OfficeAgentBaseTaskUpdateMessage) {\n    92→        super(JsonRpcMethod.TaskUpdate, params);\n    93→    }\n    94→}\n    95→\n    96→export class OfficeAgentChatMessage extends JsonRpcRequestMessage {\n    97→    constructor(payload: OfficeAgentBaseChat, id: string) {\n    98→        super(JsonRpcMethod.MessageSend, payload, id);\n    99→    }\n   100→}"}]},"parent_tool_use_id":"toolu_01LamMSZH4D3xtZzNhF4Uoq8","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"0f2544d5-e437-4a60-83af-6904e7fd033c"}
