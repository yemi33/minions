{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X9GQ2T5cdmEdvThXrayNfK","type":"tool_result","content":"     1→/**\n     2→ * Task Update Types for JSON-RPC Task Notifications\n     3→ * Defines the various types of updates that can be sent about running tasks\n     4→ */\n     5→\n     6→import type { OfficeAgentBaseTaskUpdateMessage } from './types';\n     7→\n     8→/**\n     9→ * Defines the lifecycle states of a Task.\n    10→ */\n    11→export enum TaskState {\n    12→    /** The task has been submitted and is awaiting execution. */\n    13→    Submitted = 'submitted',\n    14→    /** The agent is actively working on the task. */\n    15→    Working = 'working',\n    16→    /** The task is paused and waiting for input from the user. */\n    17→    InputRequired = 'input-required',\n    18→    /** The task has been successfully completed. */\n    19→    Completed = 'completed',\n    20→    /** The task has been canceled by the user. */\n    21→    Canceled = 'canceled',\n    22→    /** The task failed due to an error during execution. */\n    23→    Failed = 'failed',\n    24→}\n    25→\n    26→/**\n    27→ * Task status interface\n    28→ */\n    29→export interface TaskStatus {\n    30→    /** The current state of the task's lifecycle. */\n    31→    state: TaskState;\n    32→    /** An optional, human-readable message providing more details about the current status. */\n    33→    message?: string;\n    34→}\n    35→\n    36→/**\n    37→ * Enumeration of different task update types\n    38→ */\n    39→export enum TaskUpdateType {\n    40→    /** Task state updates */\n    41→    StateUpdate = 'state_update',\n    42→    /** Chain of thought updates - agent's thinking process */\n    43→    ChainOfThought = 'chain_of_thought',\n    44→    /** File generation updates */\n    45→    ArtifactGenerated = 'artifact_generated',\n    46→    /** HTML slide progress updates */\n    47→    HtmlSlideProgress = 'html_slide_progress',\n    48→}\