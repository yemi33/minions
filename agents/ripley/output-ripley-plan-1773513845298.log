{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CrN1bZKHMgXaMS7BBYojdS","type":"tool_result","content":"     1→import WebSocket from 'ws';\n     2→import { ErrorResponse, Message, MessageType } from '@officeagent/message-protocol';\n     3→import { logError, logInfo } from '../logging';\n     4→import { wsRouter } from './router';\n     5→import { v4 as uuidv4 } from 'uuid';\n     6→import type { OfficeAgentSettingsManager } from './settings';\n     7→\n     8→/**\n     9→ * Failure reasons for sendMessage operations\n    10→ */\n    11→export enum SendMessageFailureReason {\n    12→    NoClient = 'no_client',\n    13→    NotConnected = 'not_connected',\n    14→    PayloadTooLarge = 'payload_too_large',\n    15→    JsonTooLarge = 'json_too_large',\n    16→    Error = 'error'\n    17→}\n    18→\n    19→/**\n    20→ * Result of a sendMessage operation\n    21→ */\n    22→export interface SendMessageResult {\n    23→    success: boolean;\n    24→    failureReason?: SendMessageFailureReason;\n    25→}\n    26→\n    27→/**\n    28→ * Singleton class to manage WebSocket connections and messaging\n    29→ * Provides a centralized interface for sending messages to connected clients\n    30→ */\n    31→class WebSocketManager {\n    32→    private wss: WebSocket.Server;\n    33→    private currentWsSession: WebSocketSession | undefined = undefined;\n    34→    private connectedClientsMap = new Map<string, WebSocketSession>();\n    35→    private settingsManager?: OfficeAgentSettingsManager;\n    36→    private readonly maxFileSizeMB: number;\n    37→    private readonly MAX_FILE_SIZE: number;\n    38→\n    39→    /**\n    40→     * Constructor to initialize WebSocketManager with a WebSocket server\n    41→     * @param wss - The WebSocket server instance\n    42→     * @param settingsManager - Optional settings manager for changeGate and settings access\n    43→     */\n    44→    constructor(wss: WebSocket.Server, settingsManager?: OfficeAgentSettingsManager) {\n    45→        this.wss = wss;\n    46→        this.settingsManager = settingsManager;\n    47→        // Get max size limits once at initialization (default to 99 MB to provide safety margin with max WebSocket payload size of 100 MB)\n    48→        this.maxFileSizeMB = settingsManager?.getIntSetting?.('MaxJSONMessageSizeContainerMB', 99) ?? 99;\n    49→        this.MAX_FILE_SIZE = this.maxFileSizeMB * 1024 * 1024;\n    50→        this.setupConnectionHandlers();\n    51→    }\n    52→\n    53→    /**\n    54→     * Setup connection and disconnection handlers\n    55→     */\n    56→    private setupConnectionHandlers(): void {\n    57→        this.wss.on('connection', (ws) => {\n    58→            logInfo(0x1e0dc006 /* tag_4d2ag */, '🔌 New WebSocket client connected');\n    59→            new WebSocketSession(ws, this);\n    60→        });\n    61→    }\n    62→\n    63→    /**\n    64→     * Send a message to the currently connected WebSocket client\n    65→     * @param message - The message object to send (will be JSON stringified)\n    66→     * @returns SendMessageResult with success status and optional failure reason\n    67→     */\n    68→    public sendMessage(message: unknown): SendMessageResult {\n    69→        if (!this.currentWsSession) {\n    70→            logError(0x1e0dc003 /* tag_4d2ad */, '❌ Cannot send message: No WebSocket client connected');\n    71→            return { success: false, failureReason: SendMessageFailureReason.NoClient };\n    72→        }\n    73→\n    74→        if (!this.isConnected()) {\n    75→            logError(0x1e0dc002 /* tag_4d2ac */, '❌ Cannot send message: WebSocket connection is not open');\n    76→            return { success: false, failureReason: SendMessageFailureReason.NotConnected };\n    77→        }\n    78→\n    79→        try {\n    80→            // Extract file metadata once for reuse in validation and logging\n    81→            const fileMetadata = this.extractFileMetadata(message as any);\n    82→\n    83→            // Pre-validate buffer size to prevent JSON.stringify crash\n    84→            // JavaScript arrays have a max length limit, and Buffer.toJSON() creates an array\n    85→            // For buffers larger than ~100MB, JSON.stringify will fail with \"Invalid array length\"\n    86→            if (this.settingsManager?.changeGate?.('ValidateBufferSizeBeforeStringify') && fileMetadata) {\n    87→                if (fileMetadata.binarySize >= this.MAX_FILE_SIZE) {\n    88→                    logError(\n    89→                        0x1e085180 /* tag_4cfga */,\n    90→                        `[WebSocketManager] Buffer too large for JSON serialization: ${fileMetadata.messageType} message, binarySize=${fileMetadata.binarySizeKB}KB, ext=${fileMetadata.ext}, limit=${this.maxFileSizeMB}MB. Message will not be transmitted.`\n    91→                    );\n    92→                    return { success: false, failureReason: SendMessageFailureReason.PayloadTooLarge };\n    93→                }\n    94→            }\n    95→\n    96→            const jsonString = JSON.stringify(message);\n    97→\n    98→            // Log serialized message size for messages with binary content (gated by changeGate)\n    99→            if (this.settingsManager?.changeGate?.('EnableWsSerializationLogging') && fileMetadata) {\n   100→                const jsonSize = Buffer.byteLength(jsonString, 'utf8');\n   101→                const jsonSizeKB = (jsonSize / 1024).toFixed(2);\n   102→\n   103→                logInfo(\n   104→                    0x1e08a04e /* tag_4ckbo */,\n   105→                    `[WebSocketManager] ${fileMetadata.messageType} message: binary=${fileMetadata.binarySizeKB}KB, json=${jsonSizeKB}KB, ext=${fileMetadata.ext}`\n   106→                );\n   107→\n   108→                // Validate JSON message size before transmission\n   109→                if (this.settingsManager?.changeGate?.('ValidateJSONMessageSize')) {\n   110→                    if (jsonSize >= this.MAX_FILE_SIZE) {\n   111→                        logError(\n   112→                            0x1e089346 /* tag_4cjng */,\n   113→                            `[WebSocketManager] JSON message too large to send: jsonSize=${jsonSizeKB}KB, limit=${this.maxFileSizeMB}MB, ext=${fileMetadata.ext}, binarySize=${fileMetadata.binarySizeKB}KB. Message will not be transmitted.`\n   114→                        );\n   115→                        return { success: false, failureReason: SendMessageFailureReason.JsonTooLarge };\n   116→                    }\n   117→                }\n   118→            }\n   119→\n   120→            // Validate JSON message size for base64-encoded content (HandleStringEncodedZipFilesIsEnabledV2 path)\n   121→            // When HandleStringEncodedZipFilesIsEnabledV2 is enabled, fileMetadata will be null because content is string-encoded but we still need to validate JSON size for messages\n   122→            if (this.settingsManager?.changeGate?.('HandleStringEncodedZipFilesIsEnabledV2')\n   123→                && this.settingsManager?.changeGate?.('ValidateJSONMessageSize')) {\n   124→                const jsonSize = Buffer.byteLength(jsonString, 'utf8');\n   125→                if (jsonSize >= this.MAX_FILE_SIZE) {\n   126→                    const jsonSizeKB = (jsonSize / 1024).toFixed(2);\n   127→                    logError(\n   128→                        0x1e01f222 /* tag_4a5i8 */,\n   129→                        `[WebSocketManager] JSON message too large to send: jsonSize=${jsonSizeKB}KB, limit=${this.maxFileSizeMB}MB, base64-encoded content. Message will not be transmitted.`\n   130→                    );\n   131→                    return { success: false, failureReason: SendMessageFailureReason.JsonTooLarge };\n   132→                }\n   133→            }\n   134→\n   135→            this.currentWsSession.sendMessage(jsonString);\n   136→            return { success: true };\n   137→        } catch (error) {\n   138→            logError(0x1e0dc001 /* tag_4d2ab */, '❌ Error sending WebSocket message:', error);\n   139→            return { success: false, failureReason: SendMessageFailureReason.Error };\n   140→        }\n   141→    }\n   142→\n   143→    /**\n   144→     * Check if a client is currently connected\n   145→     * @returns true if a client is connected, false otherwise\n   146→     */\n   147→    public isConnected(): boolean {\n   148→        return this.currentWsSession !== undefined && this.currentWsSession.isConnected();\n   149→    }\n   150→\n   151→    /**\n   152→     * Extract file metadata from message content\n   153→     * @returns Object containing binarySize, filename, fileExt, ext, and messageType, or null if not applicable\n   154→     */\n   155→    private extractFileMetadata(message: any): {\n   156→        content: any;\n   157→        binarySize: number;\n   158→        binarySizeKB: string;\n   159→        filename: string;\n   160→        fileExt: string;\n   161→        ext: string;\n   162→        messageType: string;\n   163→    } | null {\n   164→        if (message?.type === MessageType.QueryStatus && message?.payload?.fileInfo?.content) {\n   165→            const content = message.payload.fileInfo.content;\n   166→            // Check if content is a Buffer (has length property and is not a string)\n   167→            if (content.length !== undefined && typeof content !== 'string') {\n   168→                const binarySize = content.length;\n   169→                const binarySizeKB = (binarySize / 1024).toFixed(2);\n   170→                const filename = message.payload.fileInfo.filename || message.payload.fileInfo.path || '';\n   171→                const fileExt = filename ? filename.substring(filename.lastIndexOf('.')).toLowerCase() : '';\n   172→                const ext = fileExt.startsWith('.') ? fileExt.substring(1) : fileExt;\n   173→                const messageType = message.payload.type || 'unknown';\n   174→\n   175→                return { content, binarySize, binarySizeKB, filename, fileExt, ext, messageType };\n   176→            }\n   177→        }\n   178→        return null;\n   179→    }\n   180→\n   181→    /**\n   182→     * Cleanup all WebSocket resources and handlers\n   183→     * Should be called on server shutdown\n   184→     */\n   185→    public cleanup(): void {\n   186→        logInfo(0x1e0dc000 /* tag_4d2aa */, '🧹 Cleaning up WebSocketManager resources...');\n   187→\n   188→        // Close all connected clients\n   189→        if (this.wss) {\n   190→            this.wss.clients.forEach((ws: WebSocket) => {\n   191→                ws.close(1000, 'Close is called.');\n   192→            });\n   193→        }\n   194→\n   195→        this.connectedClientsMap.clear();\n   196→        this.currentWsSession = undefined;\n   197→        logInfo(0x1e0db8e3 /* tag_4d199 */, '✅ WebSocketManager cleanup completed');\n   198→    }\n   199→\n   200→    public onSessionInitialized(wsSession: WebSocketSession) {\n   201→        const sessionId = wsSession.getSessionId();\n   202→        if (!sessionId) {\n   203→            logError(0x1e0d3522 /* tag_4dtu8 */, '❌ WebSocket sessionId is undefined');\n   204→            return;\n   205→        }\n   206→\n   207→        this.connectedClientsMap.set(sessionId, wsSession);\n   208→        // If this is the first session or the current sessions id is same as the new one (indicates a reconnect from client), set it as active\n   209→        if (!this.currentWsSession || this.currentWsSession.getSessionId() === sessionId) {\n   210→            this.currentWsSession = wsSession;\n   211→        }\n   212→    }\n   213→\n   214→    public onSessionClosed(sessionId?: string) {\n   215→        if (!sessionId) {\n   216→            return;\n   217→        }\n   218→\n   219→        if (this.currentWsSession?.getSessionId() === sessionId) {\n   220→            this.currentWsSession = undefined;\n   221→        }\n   222→        this.connectedClientsMap.delete(sessionId);\n   223→    }\n   224→\n   225→    public setActiveSession(sessionId: string) {\n   226→        const ws = this.connectedClientsMap.get(sessionId);\n   227→        if (!ws) {\n   228→            logError(0x1e0d3521 /* tag_4dtu7 */, `❌ No WebSocket client found for sessionId: ${sessionId}`);\n   229→            return;\n   230→        }\n   231→        this.currentWsSession = ws;\n   232→    }\n   233→}\n   234→\n   235→class WebSocketSession {\n   236→    private sessionId?: string;\n   237→\n   238→    public constructor(private ws: WebSocket, private wsManager: WebSocketManager) {\n   239→        ws.on('close', (code, reason) => {\n   240→            logInfo(0x1e0dc005 /* tag_4d2af */, `🔌 WebSocket client disconnected: (code: ${code}, reason: ${reason})`);\n   241→            this.wsManager.onSessionClosed(this.sessionId);\n   242→        });\n   243→\n   244→        ws.on('error', (error) => {\n   245→            logError(0x1e0dc004 /* tag_4d2ae */, '❌ WebSocket error:', error);\n   246→            this.wsManager.onSessionClosed(this.sessionId);\n   247→        });\n   248→\n   249→        ws.on('message', (data: WebSocket.Data) => {\n   250→            let message: Message;\n   251→            const rawMessage = data.toString();\n   252→            try {\n   253→                message = JSON.parse(rawMessage);\n   254→            } catch {\n   255→                logError(0x1e0d3520 /* tag_4dtu6 */, '❌ Error parsing websocket message');\n   256→                sendErrorResponse(ws, 'Error parsing websocket message');\n   257→                return;\n   258→            }\n   259→\n   260→            if (message.type === MessageType.Ping) {\n   261→                ws.send(JSON.stringify({\n   262→                    type: MessageType.Pong,\n   263→                    message: `received ${message.payload || ''}`,\n   264→                }));\n   265→                return;\n   266→            }\n   267→\n   268→            if (message.type === MessageType.SessionInit) {\n   269→                this.sessionId = message.sessionId;\n   270→                this.wsManager.onSessionInitialized(this);\n   271→            }\n   272→\n   273→            if (!this.sessionId) {\n   274→                logError(0x1e0d351f /* tag_4dtu5 */, '❌ Error sessionInit not called');\n   275→                sendErrorResponse(ws, 'SessionInit was not called');\n   276→                return;\n   277→            }\n   278→\n   279→            try {\n   280→                // Route INCOMING message to appropriate handler\n   281→                // Handler is responsible for sending response back through 'ws'\n   282→\n   283→                wsRouter.routeMessage(rawMessage, ws);\n   284→            } catch (error) {\n   285→                logError(0x1e0d351e /* tag_4dtu4 */, '❌ Error processing incoming message:', error);\n   286→                // Send error response following protocol contract\n   287→                sendErrorResponse(ws, `Error processing message: ${(error as Error).message}`);\n   288→            }\n   289→        });\n   290→    }\n   291→\n   292→    public getSessionId(): string | undefined {\n   293→        return this.sessionId;\n   294→    }\n   295→\n   296→    public sendMessage(message: string): void {\n   297→        this.ws.send(message);\n   298→    }\n   299→\n   300→    public isConnected(): boolean {\n   301→        return this.ws.readyState === WebSocket.OPEN;\n   302→    }\n   303→}\n   304→\n   305→/**\n   306→ * Send error response following protocol contract\n   307→ */\n   308→export function sendErrorResponse(ws: WebSocket, errorMsg: string, requestId?: string, sessionId?: string): void {\n   309→    if (ws.readyState === WebSocket.OPEN) {\n   310→        const errorResponse: ErrorResponse = {\n   311→            type: MessageType.Error,\n   312→            id: uuidv4(),\n   313→            sessionId: sessionId || 'unknown',\n   314→            payload: {\n   315→                errorMsg\n   316→            },\n   317→            requestId\n   318→        };\n   319→        ws.send(JSON.stringify(errorResponse));\n   320→    }\n   321→}\n   322→\n   323→// Export the class for instantiation\n   324→export { WebSocketManager };\n   325→\n   326→// Export a placeholder that will be set by the application\n   327→export let wsManager: WebSocketManager;\n   328→\n   329→/**\n   330→ * Initialize the global wsManager instance\n   331→ * This should be called once when the WebSocket server is created\n   332→ * @param wss - The WebSocket server instance\n   333→ * @param settingsManager - Optional settings manager for changeGate and settings access\n   334→ */\n   335→export function initializeWebSocketManager(wss: WebSocket.Server, settingsManager?: OfficeAgentSettingsManager): WebSocketManager {\n   336→    if (wsManager) {\n   337→        logInfo(0x1e0db8e2 /* tag_4d198 */, '⚠️ WebSocketManager already initialized, returning existing instance');\n   338→        return wsManager;\n   339→    }\n   340→\n   341→    wsManager = new WebSocketManager(wss, settingsManager);\n   342→    return wsManager;\n   343→}\n   344→"}]},"parent_tool_use_id":"toolu_01D1btGNgUTxKhKd2oyCp7xP","session_id":"8a2fc4e6-c1a3-49e6-ae99-e4ee481c1eee","uuid":"e8d15492-6513-4d2d-90d3-5e063b0eec2a"}
