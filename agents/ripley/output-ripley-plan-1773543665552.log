\n   384→                // Fallback to gptIdentifier source if no explicit requestSource\n   385→                const [gptIdentifier] = gptIdentifiers;\n   386→                requestContext.requestSource = gptIdentifier?.source;\n   387→            }\n   388→        }\n   389→\n   390→        logInfo(0x1e0dc1a1 /* tag_4d2g7 */, `[GENERATE-DOCUMENT] Grounding source toggles received from AL: ${JSON.stringify({\n   391→            webSearch: webSearch,\n   392→            enterpriseSearch: enterpriseSearch\n   393→        })}`);\n   394→\n   395→        // Log queryAnnotations if present\n   396→        if (requestContext.queryAnnotations && requestContext.queryAnnotations.length > 0) {\n   397→            logInfo(0x1e0dc19d /* tag_4d2g3 */, `[GENERATE-DOCUMENT] Query annotations attached: ${requestContext.queryAnnotations.length} entities`);\n   398→        }\n   399→\n   400→        // Log provisionedFileMetadata if present\n   401→        if (requestContext.provisionedFileMetadata && requestContext.provisionedFileMetadata.length > 0) {\n   402→            logInfo(0x1e08b799 /* tag_4cl4z */, `[GENERATE-DOCUMENT] Provisioned file metadata attached: ${requestContext.provisionedFileMetadata.length} files`);\n   403→        }\n   404→\n   405→        // Hack to update the sessionId in the agent context so it can be used to set the active WebSocket session\n   406→        // This will be removed once we migrate to JSON+RPC for agent communication\n   407→        if (sessionId !== undefined && (createAgent as any).context) {\n   408→            (createAgent as any).context.sessionId = sessionId;\n   409→        }\n   410→\n   411→        // Call run with the processed user query (flag already stripped if present)\n   412→        await (createAgent as any).run(processedUserQuery, requestContext, turnNumber);\n   413→\n   414→        // Get the generated file information\n   415→        const fileInfo = (createAgent as any).getGeneratedFileInfo();\n   416→\n   417→        // Mark conversation as inactive\n   418→        activeConversations.delete(finalConversationId);\n   419→\n   420→        if (!returnAsync) {\n   421→            if (fileInfo) {\n   422→                // Get relative path for the response\n   423→                const relativeFilePath = fileInfo.filePath;\n   424→\n   425→                res.json({\n   426→                    success: true,\n   427→                    filename: fileInfo.filename,\n   428→                    filePath: relativeFilePath,\n   429→                    size: fileInfo.size,\n   430→                    requestId: finalRequestId,\n   431→                    conversationId: finalConversationId,\n   432→                });\n   433→            } else {\n   434→                // No file generated - return success without file info\n   435→                res.json({\n   436→                    success: true,\n   437→                    requestId: finalRequestId,\n   438→                    conversationId: finalConversationId,\n   439→                });\n   440→            }\n   441→        }\n   442→\n   443→        return;\n   444→    } catch (error) {\n   445→        logError(0x1e0da752 /* tag_4d03s */, '[GENERATE-DOCUMENT] Error in new CreateAgent workflow:', error);\n   446→        // Mark conversation as inactive\n   447→        activeConversations.delete(finalConversationId);\n   448→        throw error;\n   449→    }\n   450→}));\n   451→\n   452→// Use error handling middleware, must be after all route registrations\n   453→externalApp.use(errorHandler);\n   454→\n   455→// Function to warmup the system by creating directories and returning request ID\n   456→async function warmupSystem(conversationId: any) {\n   457→    try {\n   458→        logInfo(0x1e0da751 /* tag_4d03r */, '🔥 Warming up system...');\n   459→\n   460→        const requestId = uuidv4();\n   461→        conversationId = conversationId || uuidv4();\n   462→\n   463→        logInfo(0x1e0da750 /* tag_4d03q */, `🆔 Requ