{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CVqmnfhCW5CtaQ2JNyArcF","type":"tool_result","content":"     1→/**\n     2→ * Describes a mutation operation for updating streamed HTML.\n     3→ * Used by both the response parser (producer) and streaming context (consumer).\n     4→ */\n     5→export interface MutationDescriptor {\n     6→  /**\n     7→   * Type of mutation operation.\n     8→   * - replace: Replace target node(s) with new HTML\n     9→   * - delete: Remove target node(s)\n    10→   * - append: Append HTML content inside the target element\n    11→   */\n    12→  type: 'replace' | 'delete' | 'append';\n    13→\n    14→  /**\n    15→   * For range-based mutations: copilot-ID of the first affected node (data-start).\n    16→   * For append: target element hash (data-target).\n    17→   */\n    18→  startHash?: string;\n    19→\n    20→  /**\n    21→   * For range-based mutations: copilot-ID of the last affected node (data-end).\n    22→   * For append: new hash after appending (data-new-hash).\n    23→   */\n    24→  endHash?: string;\n    25→\n    26→  /**\n    27→   * For single-element replace: target element hash (data-target).\n    28→   * When present, startHash/endHash are not used for targeting.\n    29→   */\n    30→  targetHash?: string;\n    31→\n    32→  /**\n    33→   * For single-element replace: new hash of the replacement element (data-new-hash).\n    34→   * Used with targetHash.\n    35→   */\n    36→  newHash?: string;\n    37→\n    38→  /**\n    39→   * HTML content to insert/render.\n    40→   * Empty string for delete operations.\n    41→   */\n    42→  replacementHtml?: string;\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_01DLPgnTkmGzXzsDrb5HSUSt","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"cfda42e3-22e5-41a0-b631-199f5f11bff7"}
