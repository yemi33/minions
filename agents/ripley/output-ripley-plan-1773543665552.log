{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011X4wPWayRKGPHUpo2WviWB","type":"tool_result","content":"     1→/**\n     2→ * Grounding Service Types\n     3→ *\n     4→ * Shared request/response contracts for internal agent-to-agent communication\n     5→ * with the grounding service. Used by both the GroundingHttpServer (provider)\n     6→ * and the GroundingClient (consumer).\n     7→ */\n     8→\n     9→import { IQueryAnnotation } from '@officeagent/message-protocol';\n    10→\n    11→// ============================================================================\n    12→// Request\n    13→// ============================================================================\n    14→\n    15→/** Configuration options for a grounding request. */\n    16→export interface GroundingRequestConfigs {\n    17→    /** Whether to include enterprise search results. */\n    18→    enterpriseSearch?: boolean;\n    19→    /** Whether to include web search results. */\n    20→    webSearch?: boolean;\n    21→}\n    22→\n    23→/** Request payload for the grounding HTTP endpoint. */\n    24→export interface GroundingHttpRequest {\n    25→    /** The user query to ground. */\n    26→    query: string;\n    27→    /** Optional grounding configuration overrides. */\n    28→    configs?: GroundingRequestConfigs;\n    29→    /** Conversation ID for correlation with the calling agent's session. */\n    30→    conversationId?: string;\n    31→    /** Session ID for correlation with the container session. */\n    32→    sessionId?: string;\n    33→    /** Unique request ID for tracing. */\n    34→    requestId?: string;\n    35→    /** Query annotations (user-attached entities). */\n    36→    queryAnnotations?: IQueryAnnotation[];\n    37→}\n    38→\n    39→// ============================================================================\n    40→// Response\n    41→// ============================================================================\n    42→\n    43→/** Status of a grounding response. */\n    44→export type GroundingResponseStatus = 'completed' | 'failed';\n    45→\n    46→/** Metadata about the grounding run. */\n    47→export interface GroundingResponseMetadata {\n    48→    /** Request ID echoed back for correlation. */\n    49→    requestId: string;\n    50→    /** Duration of the grounding run in milliseconds. */\n    51→    durationMs: number;\n    52→    /** Sources that contributed to the grounding output. */\n    53→    sourcesUsed: string[];\n    54→}\n    55→\n    56→/** Response payload from the grounding HTTP endpoint. */\n    57→export interface GroundingHttpResponse {\n    58→    /** Whether the grounding run completed successfully. */\n    59→    status: GroundingResponseStatus;\n    60→    /** The grounding content (parsed from grounding.md). */\n    61→    groundingContent: string;\n    62→    /** Metadata about the grounding run. */\n    63→    metadata?: GroundingResponseMetadata;\n    64→    /** Error message if status is 'failed'. */\n    65→    error?: string;\n    66→}\n    67→\n    68→// ============================================================================\n    69→// Server Configuration\n    70→// ============================================================================\n    71→\n    72→/** Configuration for the grounding HTTP server. */\n    73→export interface GroundingHttpServerConfig {\n    74→    /** Port to listen on. Default: 7010. */\n    75→    port?: number;\n    76→    /** Request body size limit. Default: '10mb'. */\n    77→    bodyLimit?: string;\n    78→    /** Request timeout in milliseconds. Default: 300000 (5 min). */\n    79→    requestTimeoutMs?: number;\n    80→}\n    81→\n    82→/** Default port for the grounding HTTP server. */\n    83→export const DEFAULT_GROUNDING_HTTP_PORT = 7010;\n    84→\n    85→/** Default request timeout in milliseconds (10 minutes). */\n    86→export const DEFAULT_GROUNDING_REQUEST_TIMEOUT_MS = 600_000;\n    87→\n    88→// ============================================================================\n    89→// Client Configuration\n    90→// ============================================================================\n    91→\n    92→/** Configuration for the grounding HTTP client. */\n    93→export interface GroundingClientConfig {\n    94→    /** Base URL of the grounding HTTP server. Default: http://localhost:7010. */\n    95→    baseUrl?: string;\n    96→    /** Request timeout in milliseconds. Default: 300000 (5 min). */\n    97→    timeoutMs?: number;\n    98→    /** Number of retry attempts on transient failures. Default: 1. */\n    99→    retries?: number;\n   100→    /** Delay between retries in milliseconds. Default: 1000. */\n   101→    retryDelayMs?: number;\n   102→    /** API version prefix for endpoints. Default: 'v1'. */\n   103→    apiVersion?: string;\n   104→    /** Lifecycle hooks for observability (telemetry, logging, metrics). */\n   105→    hooks?: GroundingClientHooks;\n   106→}\n   107→\n   108→/** Lifecycle hooks for the grounding client. */\n   109→export interface GroundingClientHooks {\n   110→    /** Called before the HTTP request is sent. */\n   111→    onRequestStart?: (request: GroundingHttpRequest) => void;\n   112→    /** Called after a successful response. */\n   113→    onRequestEnd?: (request: GroundingHttpRequest, response: GroundingHttpResponse, durationMs: number) => void;\n   114→    /** Called when the request fails (after all retries). */\n   115→    onRequestError?: (request: GroundingHttpRequest, error: Error, durationMs: number) => void;\n   116→    /** Called on each retry attempt. */\n   117→    onRetry?: (request: GroundingHttpRequest, attempt: number, error: Error) => void;\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"92134057-65b9-4596-8a57-cd22ede91758"}
