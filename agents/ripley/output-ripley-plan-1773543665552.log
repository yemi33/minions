{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RBjtypBXPDcCsfo5ohtcNs","type":"tool_result","content":"     1→import { useEffect, useRef } from 'react';\n     2→import { useSetAtom, useStore } from 'jotai';\n     3→import {\n     4→  addMessagesAtom,\n     5→  assignCurrentChatTurnCountAtom,\n     6→  conversationIdAtom,\n     7→  messagesAtom,\n     8→  setSubmitPromptTimeByMessageIdAtom\n     9→} from '../../atoms/messageAtoms';\n    10→import type { MessageEntry, Persona, AttachmentData } from '@bebopjs/bebop-response-mapping';\n    11→import type { SubmitPromptParameters as BaseSubmitPromptParameters } from '@bebopjs/bebop-shared-types';\n    12→import type { UploadingFile, PastedFile } from '@bebopjs/bebop-local-files';\n    13→import { ChatAbortReason } from '../../utils/ChatAbortReason';\n    14→\n    15→export interface SubmitPromptParameters extends BaseSubmitPromptParameters {\n    16→  pastedFiles?: ReadonlyArray<PastedFile>;\n    17→}\n    18→\n    19→interface UseChatOrchestrationOptions {\n    20→  onResponseComplete: () => void;\n    21→}\n    22→\n    23→export function useChatOrchestration({ onResponseComplete }: UseChatOrchestrationOptions) {\n    24→  const addMessages = useSetAtom(addMessagesAtom);\n    25→  const assignCurrentChatTurnCount = useSetAtom(assignCurrentChatTurnCountAtom);\n    26→  const setSubmitPromptTimeByMessageId = useSetAtom(setSubmitPromptTimeByMessageIdAtom);\n    27→  const store = useStore();\n    28→  const abortControllerRef = useRef<AbortController | null>(null);\n    29→\n    30→  // Keep the callback ref stable to avoid stale closures in subscriptions\n    31→  const onResponseCompleteRef = useRef(onResponseComplete);\n    32→  onResponseCompleteRef.current = onResponseComplete;\n    33→\n    34→  // Holds the cleanup function for the active messagesAtom subscription\n    35→  const unsubscribeRef = useRef<(() => void) | null>(null);\n    36→\n    37→  const submitPrompt = (parameters: SubmitPromptParameters) => {\n    38→    const submitPromptTime = performance.now();\n    39→    const promptEntryId = parameters.clientRequestId;\n    40→    const responseId = crypto.randomUUID();\n    41→    const conversationId = store.get(conversationIdAtom);\n    42→\n    43→    abortControllerRef.current = new AbortController();\n    44→\n    45→    const promptEntry: MessageEntry = {\n    46→      messageId: promptEntryId,\n    47→      parsedContent: parameters.prompt,\n    48→      persona: 'user' as Persona,\n    49→      requestId: promptEntryId,\n    50→      status: 'complete',\n    51→      references: [],\n    52→      attachments: (() => {\n    53→        const localAttachments: AttachmentData[] =\n    54→          parameters.attachments?.map(\n    55→            (file: UploadingFile): AttachmentData => ({\n    56→              id: file.id,\n    57→              name: file.name,\n    58→              url: file.status === 'success' ? file.entity.url : undefined,\n    59→              mimeType: file.file.type\n    60→            })\n    61→          ) ?? [];\n    62→        const pastedAttachments: AttachmentData[] =\n    63→          parameters.pastedFiles?.map(\n    64→            (file): AttachmentData => ({\n    65→              id: file.id,\n    66→              name: file.fileName,\n    67→              url: file.webUrl ?? file.url,\n    68→              mimeType: file.mimeType\n    69→            })\n    70→          ) ?? [];\n    71→        const allAttachments = [...localAttachments, ...pastedAttachments];\n    72→        return allAttachments.length > 0 ? allAttachments : undefined;\n    73→      })(),\n    74→      selectedText: parameters.selectedText ?? undefined,\n    75→      queryAnnotations: parameters.queryAnnotations,\n    76→      conversationId\n    77→    };\n    78→\n    79→    const responseEntry: MessageEntry = {\n    80→      messageId: responseId,\n    81→      parsedContent: null,\n    82→      persona: 'bot' as Persona,\n    83→      requestId: promptEntryId,\n    84→      status: 'pending',\n    85→      references: [],\n    86→      conversationId\n    87→    };\n    88→\n    89→    // Tear down any previous subscription before starting a new one\n    90→    unsubscribeRef.current?.();\n    91→\n    92→    // Subscribe to messagesAtom and watch for the response to complete\n    93→    unsubscribeRef.current = store.sub(messagesAtom, () => {\n    94→      const messages = store.get(messagesAtom);\n    95→      const responseMessage = messages[responseId];\n    96→      if (responseMessage.status === 'complete') {\n    97→        onResponseCompleteRef.current();\n    98→        unsubscribeRef.current?.();\n    99→        unsubscribeRef.current = null;\n   100→        abortControllerRef.current = null;"}]},"parent_tool_use_id":"toolu_01DLPgnTkmGzXzsDrb5HSUSt","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"f086fa04-c5c3-4721-abf8-4d707905d179"}
