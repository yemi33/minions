{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D58QUp9bs2LTwzLjatJrgd","type":"tool_result","content":"     1→import { RequestContext } from '@officeagent/message-protocol';\n     2→import { ResolvedAgentConfig, SessionContext, AgentRegistryConfig } from './types';\n     3→import { AgentWorkspaceManager } from './agent-workspace-manager';\n     4→import { SystemPromptBuilder, PromptContext } from './system-prompt-builder';\n     5→import { ConfigResolver } from './config-resolver';\n     6→import { logDebug, logInfo } from '../logging';\n     7→\n     8→\n     9→/**\n    10→ * Base class for all Office agents\n    11→ * Provides common functionality for workspace setup, configuration loading, and system prompt building\n    12→ */\n    13→export abstract class BaseAgent {\n    14→    protected config?: ResolvedAgentConfig;\n    15→    protected workspaceManager?: AgentWorkspaceManager;\n    16→    protected promptBuilder?: SystemPromptBuilder;\n    17→    private readonly registry?: AgentRegistryConfig;\n    18→\n    19→    /**\n    20→     * Creates a new agent instance with optional registry-based configuration\n    21→     * Configuration resolution is delayed until initialize() is called with runtime SessionContext\n    22→     *\n    23→     * @param registry - Optional agent registry configuration with all versions and flights\n    24→     */\n    25→    protected constructor(registry?: AgentRegistryConfig) {\n    26→        this.registry = registry;\n    27→\n    28→        if (registry) {\n    29→            logDebug(`[BaseAgent] Created agent with registry: ${registry.packageName}`);\n    30→        } else {\n    31→            logDebug('[BaseAgent] Created agent without registry configuration');\n    32→        }\n    33→    }\n    34→\n    35→    /**\n    36→     * Resolve configuration from registry with runtime flight overrides and grounding source toggles\n    37→     * Should be called in initialize() method to apply SessionContext flights and grounding filters\n    38→     *\n    39→     * @param context - Optional SessionContext containing settings manager and grounding source toggles\n    40→     */\n    41→    protected resolveConfig(context?: SessionContext): void {\n    42→        if (!this.registry) {\n    43→            logDebug('[BaseAgent] No registry - skipping config resolution');\n    44→            return;\n    45→        }\n    46→\n    47→        // Build flights map from settings manager if available\n    48→        let flights: Record<string, boolean> | undefined;\n    49→        if (context?.settingsManager && this.registry.flights) {\n    50→            flights = {};\n    51→            for (const flightOverride of this.registry.flights) {\n    52→                const flightValue = context.settingsManager.getBooleanSetting(flightOverride.flightKey, false);\n    53→                flights[flightOverride.flightKey] = flightValue;\n    54→            }\n    55→        }\n    56→\n    57→        this.config = ConfigResolver.resolve(this.registry, flights, context);\n    58→\n    59→        // Log final resolved config details\n    60→        logInfo(0x1e08465b /* tag_4cez1 */, `[BaseAgent] Resolved config: ${this.config.id} (v${this.config.version}) - Model: ${this.config.model}, Skills: [${this.config.skills.join(', ')}], Subagents: [${this.config.subagents.join(', ')}], Scripts: [${(this.config.scripts ?? []).join(', ')}]`);\n    61→        if (this.config.appliedFlights?.length) {\n    62→            logInfo(0x1e0dc023 /* tag_4d2a9 */, `[BaseAgent] Applied flights: ${this.config.appliedFlights.join(', ')}`);\n    63→        }\n    64→        if (this.config.appliedFilters?.length) {\n    65→            logInfo(0x1e0dc022 /* tag_4d2a8 */, `[BaseAgent] Applied filters: ${this.config.appliedFilters.join(', ')}`);\n    66→        }\n    67→    }\n    68→\n    69→    /**\n    70→     * Get the agent ID from registry or config\n    71→     *\n    72→     * @returns The unique identifier for this agent\n    73→     */\n    74→    public get agentId(): string {\n    75→        return this.registry?.id ?? 'unknown';\n    76→    }\n    77→\n    78→    /**\n    79→     * Get the agent name from registry or config\n    80→     *\n    81→     * @returns The display name of this agent\n    82→     */\n    83→    public get name(): string {\n    84→        return this.registry?.name ?? 'Unknown Agent';\n    85→    }\n    86→\n    87→    /**\n    88→     * Get the agent version from config\n    89→     *\n    90→     * @returns The version string of this agent\n    91→     */\n    92→    public get version(): string {\n    93→        return this.config?.version ?? '0.0.0';\n    94→    }\n    95→\n    96→    /**\n    97→     * Get the agent description from config\n    98→     *\n    99→     * @returns The description of this agent, if available\n   100→     */\n   101→    public get description(): string | undefined {\n   102→        return this.registry?.description;\n   103→    }\n   104→\n   105→    /**\n   106→     * Get the full resolved agent configuration\n   107→     *\n   108→     * @returns The complete resolved agent configuration including model settings, skills, and subagents\n   109→     */\n   110→    public getConfig(): ResolvedAgentConfig | undefined {\n   111→        return this.config;\n   112→    }\n   113→\n   114→    /**\n   115→     * Initialize the agent for a new session\n   116→     * Implement this method to set up workspace, register message handlers, and prepare the agent\n   117→     *\n   118→     * @param context - Session context containing request/session IDs, wsRouter, wsClient, and settings manager\n   119→     */\n   120→    public abstract initialize(context: SessionContext): Promise<void>;\n   121→\n   122→    /**\n   123→     * Run the agent with a user query\n   124→     * Implement this method to handle user queries and generate responses\n   125→     *\n   126→     * @param userQuery - The user's query string\n   127→     * @param context - Optional application context with additional information\n   128→     * @returns Promise that resolves when the query processing is complete\n   129→     */\n   130→    public abstract run(userQuery: string, context?: RequestContext): Promise<void>;\n   131→\n   132→    /**\n   133→     * Set up the agent's workspace structure\n   134→     * Creates directory structure (.claude/skills, .claude/agents, turn folders) and copies enabled skills/subagents\n   135→     * Template settings for EJS rendering in skills/subagents/scripts are read from config.templateSettings\n   136→     * Should be called in your initialize() method\n   137→     *\n   138→     * @throws Error if workspace setup fails\n   139→     */\n   140→    protected async setupWorkspace(): Promise<void> {\n   141→        if (!this.workspaceManager) {\n   142→            this.workspaceManager = new AgentWorkspaceManager();\n   143→        }\n   144→\n   145→        // Only setup workspace if config is available\n   146→        if (this.config) {\n   147→            await this.workspaceManager.setupWorkspace(this.config);\n   148→        }\n   149→    }\n   150→\n   151→    /**\n   152→     * Load and build the system prompt using EJS templating\n   153→     * Renders the system prompt template with the provided context variables\n   154→     * Should be called in your initialize() method after setupWorkspace()\n   155→     *\n   156→     * @param sessionContext - Session context containing user and session information\n   157→     * @param promptContext - Context object providing variables for EJS template (skills paths, workspace dirs, etc.)\n   158→     * @returns The rendered system prompt string\n   159→     */\n   160→    protected async loadSystemPrompt(\n   161→        sessionContext: SessionContext,\n   162→        promptContext: PromptContext | undefined\n   163→    ): Promise<string> {\n   164→        if (!this.promptBuilder) {\n   165→            this.promptBuilder = new SystemPromptBuilder();\n   166→        }\n   167→\n   168→        // Require config for system prompt building\n   169→        if (!this.config) {\n   170→            throw new Error('Agent configuration is required to build system prompt');\n   171→        }\n   172→\n   173→        return await this.promptBuilder.buildPrompt(\n   174→            this.config,\n   175→            sessionContext,\n   176→            promptContext\n   177→        );\n   178→    }\n   179→}\n   180→"}]},"parent_tool_use_id":"toolu_01AJXnfzeHR2byH3TcFHovhb","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"8cb757e1-d648-4c34-8718-13d876260316"}
