{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FUnNCoGa78fCsgXVt6uW41","type":"tool_result","content":"     1→import { ChainOfThoughtContentHandler } from './content-handler';\n     2→\n     3→/**\n     4→ * A single content block inside a ChainOfThoughtMessage.\n     5→ * Matches the shape produced by Claude Agent SDK messages and the orchestrator\n     6→ * cot-adapter — using structural typing so any provider's messages satisfy\n     7→ * this contract without SDK imports.\n     8→ */\n     9→export interface ChainOfThoughtContentBlock {\n    10→    type: string;\n    11→    /** Text content (present when type === 'text') */\n    12→    text?: string;\n    13→    /** Tool name (present when type === 'tool_use') */\n    14→    name?: string;\n    15→    /** Tool input (present when type === 'tool_use') */\n    16→    input?: any;\n    17→    /** Unique ID for tool_use blocks */\n    18→    id?: string;\n    19→}\n    20→\n    21→/**\n    22→ * Provider-agnostic message type for chain-of-thought tracking.\n    23→ *\n    24→ * Replaces the former `SDKAssistantMessage | SDKResultMessage` alias.\n    25→ * Defined as a structural interface so that:\n    26→ * - Claude SDK messages (SDKAssistantMessage, SDKResultMessage) satisfy it\n    27→ * - Orchestrator cot-adapter output satisfies it\n    28→ *\n    29→ * Only the fields actually read by MessageProcessor are included.\n    30→ */\n    31→export interface ChainOfThoughtMessage {\n    32→    /** Message type — 'assistant' for content/tool messages, 'result' for terminal messages */\n    33→    type: string;\n    34→    /** Nested message with content blocks (assistant messages) */\n    35→    message?: {\n    36→        content?: ChainOfThoughtContentBlock[];\n    37→        [key: string]: unknown;\n    38→    };\n    39→    /** Result subtype — 'success', 'error_max_turns', 'error_during_execution' (result messages) */\n    40→    subtype?: string;\n    41→    /** Result content string (result messages) */\n    42→    result?: string;\n    43→    /** Parent tool use ID — identifies messages from sub-agents */\n    44→    parent_tool_use_id?: string | null;\n    45→}\n    46→\n    47→export interface ChainOfThoughtState {\n    48→    fileDescriptor: number | null;\n    49→    filePath: string | null;\n    50→    debugLogDescriptor: number | null;\n    51→    debugLogPath: string | null;\n    52→    outputDir: string | null;\n    53→    logDir: string | null;\n    54→    enabled: boolean | null;\n    55→    messageQueue: ChainOfThoughtMessage[];\n    56→    pendingTasks: (() => Promise<void>)[];\n    57→    isProcessing: boolean;\n    58→    processingPromise: Promise<void> | null;\n    59→    contentHandler: ChainOfThoughtContentHandler | null;\n    60→    workspaceDir: string | null;\n    61→}\n    62→\n    63→export interface ChainOfThoughtFlights {\n    64→    useContentHandler?: boolean;\n    65→    sendOnlyNewUpdates?: boolean;\n    66→    useEnhancedHeuristics?: boolean;\n    67→    requireToolUseForQueueFallback?: boolean;\n    68→}\n    69→"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"a88443d1-b561-4f86-a2ae-6783ad38e3d6"}
