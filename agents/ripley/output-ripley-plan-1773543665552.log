{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vdts8RC3MrRU5RsmNpSF3D","type":"tool_result","content":"     1→/**\n     2→ * @officeagent/message-protocol/types\n     3→ *\n     4→ * WebSocket message protocol contract\n     5→ */\n     6→\n     7→import { MessageType } from './message-type';\n     8→import type { Message as SydneyMessage } from '@augloop-types/sydney';\n     9→\n    10→// Re-export MessageType for convenience\n    11→export { MessageType };\n    12→export { Message as SydneyMessage } from '@augloop-types/sydney';\n    13→\n    14→/**\n    15→ * Base schema interface for all messages\n    16→ */\n    17→export interface Schema {\n    18→    /** What this message is */\n    19→    type: MessageType;\n    20→    /** Message ID */\n    21→    id: string;\n    22→}\n    23→\n    24→/**\n    25→ * Base message interface for all WebSocket messages\n    26→ * @template T - The type of the payload\n    27→ */\n    28→export interface Message<T = unknown> extends Schema {\n    29→    /** Session which message is for */\n    30→    sessionId: string;\n    31→    /** Message payload - can be any object */\n    32→    payload: T;\n    33→}\n    34→\n    35→/**\n    36→ * Response message interface that extends base Message\n    37→ * Used for messages that are responses to previous requests\n    38→ */\n    39→export interface ResponseMessage<T = unknown> extends Message<T> {\n    40→    /** ID of the request this is responding to */\n    41→    requestId: string;\n    42→}\n    43→\n    44→/**\n    45→ * OfficePy Settings\n    46→ * Contains configuration settings to be passed to the OfficePy container\n    47→ * Each setting is a key-value pair where the value can be boolean, string, or number\n    48→ */\n    49→export interface OfficePySettings {\n    50→    /** Settings as key-value pairs */\n    51→    [key: string]: boolean | string | number | object;\n    52→}\n    53→\n    54→/**\n    55→ * Scenario type enum for differentiating between enterprise and consumer contexts\n    56→ * Used to filter themes, layouts, and other scenario-specific features\n    57→ */\n    58→export enum ScenarioType {\n    59→    /** Consumer/personal use scenarios */\n    60→    Consumer = 'consumer',\n    61→    /** Enterprise/business use scenarios */\n    62→    Enterprise = 'enterprise'\n    63→}\n    64→\n    65→/**\n    66→ * Grounding Source flags to enable or disable specific grounding sources\n    67→ * Contains OCPS (Office Copilot Service) policy settings and user sources preferences that control feature availability\n    68→ */\n    69→export interface IGroundingSourceToggles {\n    70→    /** Flag to enable/disable web search functionality */\n    71→    webSearch: boolean;\n    72→\n    73→    /** Flag to enable/disable enterprise search */\n    74→    enterpriseSearch: boolean;\n    75→}\n    76→\n    77→/**\n    78→ * Client metadata containing details about the client calling Agents\n    79→ */\n    80→export interface ClientMetadata {\n    81→    /** Name of the application (e.g., \"Word\", \"Excel\", \"PowerPoint\", \"BizChat\") */\n    82→    appName: string;\n    83→    /** Platform the application is running on (e.g., \"Windows\", \"Mac\", \"Web\", \"iOS\", \"Android\") */\n    84→    appPlatform: string;\n    85→    /** Name of client facing agent (e.g., \"WordAgent\", \"OfficeAgent\") */\n    86→    agentName?: string;\n    87→}\n    88→\n    89→// the value will actually be a ListToolsResult type (from mcp sdk), but we don't want to take a dependency on that package here, so we use unknown\n    90→export type McpServers = Record<string, unknown>;\n    91→\n    92→export interface IMcpToolConfiguration {\n    93→    mcpTools: string[];\n    94→    mcpToolsFilePath: string | null;\n    95→    localMcpServerName: string;\n    96→}\n    97→\n    98→/**\n    99→ * Session Initialization Message Payload\n   100→ * Payload sent to initialize a session with the OfficePy container\n   101→ * Contains configuration settings for the session\n   102→ */\n   103→export interface SessionInitMessagePayload {\n   104→    /** OfficePy container settings */\n   105→    settings: OfficePySettings;\n   106→    /** Client metadata containing client details */\n   107→    clientMetadata?: ClientMetadata;\n   108→    /** List of disabled change gates */\n   109→    disabledChangeGates?: string[];\n   110→    /** Grounding source toggles */\n   111→    groundingSourceToggles?: IGroundingSourceToggles;\n   112→    /** Optional agent ID to initialize specific agent*/\n   113→    agentId?: string;\n   114→    /** UTC timestamp when session init message is sent from client */\n   115→    timestamp?: string;\n   116→    /** Optional MCP servers definition */\n   117→    mcpServers?: McpServers;\n   118→    /** Optional conversation ID for tracking multi-turn conversations */\n   119→    conversationId?: string;\n   120→}\n   121→\n   122→/**\n   123→ * Session Initialization Response Message Payload\n   124→ */\n   125→export interface SessionInitResponseMessagePayload {\n   126→    /** Container Instance ID - must be same for multiple requests to a container instance */\n   127→    containerInstanceId: string;\n   128→    /** OfficeAgent build version for telemetry correlation */\n   129→    officeAgentVersion?: string;\n   130→    success?: boolean;\n   131→    error?: any;\n   132→}\n   133→\n   134→/**\n   135→ * Welcome message payload\n   136→ */\n   137→export interface WelcomePayload {\n   138→    /** Welcome message text */\n   139→    message: string;\n   140→}\n   141→\n   142→/**\n   143→ * Error message payload\n   144→ */\n   145→export interface ErrorPayload {\n   146→    /** Error message or description */\n   147→    errorMsg: string;\n   148→}\n   149→\n   150→/**\n   151→ * LLM Response sub-types for different delivery mechanisms\n   152→ */\n   153→export enum LLMResponseType {\n   154→    /** Final complete response (non-streaming) */\n   155→    Final = 'final',\n   156→    /** Streaming response start with headers */\n   157→    Start = 'start',\n   158→    /** Streaming data chunk */\n   159→    Chunk = 'chunk',\n   160→    /** Streaming response complete */\n   161→    Complete = 'complete'\n   162→}\n   163→\n   164→// Re-export LLMResponseType as OpenAIModelResponseType for semantic clarity\n   165→// The values are identical: 'final', 'start', 'chunk', 'complete'\n   166→export { LLMResponseType as OpenAIModelResponseType };\n   167→\n   168→/**\n   169→ * LLM Request Payload\n   170→ */\n   171→export interface LLMRequestPayload {\n   172→    /** Request body to forward to LLM API */\n   173→    body: any;\n   174→}\n   175→\n   176→/**\n   177→ * LLM Response Payload\n   178→ */\n   179→export interface LLMResponsePayload {\n   180→    /** Sub-type of LLM response indicating delivery mechanism */\n   181→    responseType: LLMResponseType;\n   182→    /** Response body from LLM API (for Final responses) */\n   183→    body?: any;\n   184→    /** Raw chunk data (for Chunk responses) */\n   185→    chunk?: string;\n   186→    /** Response headers (for Start responses) */\n   187→    headers?: any;\n   188→    /** Status code */\n   189→    status?: number;\n   190→    /** Error information */\n   191→    error?: any;\n   192→}\n   193→\n   194→/**\n   195→ * OpenAI LLM Request Payload\n   196→ * For OpenAI model requests (Azure/Substrate backends)\n   197→ * Supports chat/completions, responses APIs\n   198→ * Note: LLMRequest/LLMResponse are for Claude/Anthropic models\n   199→ */\n   200→export interface OpenAILLMRequestPayload {\n   201→    /** OpenAI API path (e.g., 'chat/completions', 'responses', 'embeddings') */\n   202→    api: string;\n   203→    /** Backend to use ('azure' or 'substrate') */\n   204→    backend: string;\n   205→    /** Request body to forward to OpenAI API */\n   206→    body: any;\n   207→    /** Custom headers to forward */\n   208→    customHeaders?: Record<string, string>;\n   209→}\n   210→\n   211→/**\n   212→ * OpenAI LLM Response Payload\n   213→ * For OpenAI model responses (Azure/Substrate backends)\n   214→ */\n   215→export interface OpenAILLMResponsePayload {\n   216→    /** Sub-type of response indicating delivery mechanism */\n   217→    responseType: LLMResponseType;\n   218→    /** Response body from OpenAI API (for Final responses) */\n   219→    body?: any;\n   220→    /** Raw chunk data (for Chunk responses) */\n   221→    chunk?: string;\n   222→    /** Response headers (for Start responses) */\n   223→    headers?: any;\n   224→    /** Status code */\n   225→    status?: number;\n   226→    /** Error information */\n   227→    error?: any;\n   228→}\n   229→\n   230→/**\n   231→ * MCP Request Payload\n   232→ */\n   233→export interface MCPRequestPayload {\n   234→    /** MCP method name */\n   235→    method: string;\n   236→    /** MCP parameters */\n   237→    params?: any;\n   238→}\n   239→\n   240→/**\n   241→ * MCP Response Payload\n   242→ */\n   243→export interface MCPResponsePayload {\n   244→    /** MCP result */\n   245→    result?: any;\n   246→    /** MCP error */\n   247→    error?: any;\n   248→}\n   249→\n   250→/**\n   251→ * Error response interface\n   252→ * Extends the base Message interface to include payload\n   253→ * @template T - The type of the error payload (extends ErrorPayload)\n   254→ * @template Type - The specific MessageType for this error\n   255→ */\n   256→export interface ErrorResponse<T extends ErrorPayload = ErrorPayload, Type extends MessageType = MessageType.Error> extends Message<T> {\n   257→    /** ID of the request this is responding to (for error responses to requests) */\n   258→    requestId?: string;\n   259→\n   260→    type: Type;\n   261→}\n   262→\n   263→/**\n   264→ * Chain of thought message payload\n   265→ */\n   266→export interface ChainOfThoughtPayload {\n   267→    /** Chain of thought content */\n   268→    content: string;\n   269→}\n   270→\n   271→/**\n   272→ * Message type enum for all supported message types\n   273→ */\n   274→export enum QueryStatusType {\n   275→    FileCreated = 'file_created',\n   276→    DocumentGenerationAttempted = 'document_generation_attempted',\n   277→    FileDeleted = 'file_deleted',\n   278→    DocumentGenerated = 'document_generated',\n   279→    DocumentGenerationFailed = 'document_generation_failed',\n   280→    QueryInterrupted = 'query_interrupted',\n   281→    PptxSlideCountDetermined = 'pptx_slide_count_determined',\n   282→}\n   283→\n   284→export enum QueryErrorCode {\n   285→    UnknownError = 'unknown_error',\n   286→    ConversationExpired = 'conversation_expired',\n   287→    QueryAborted = 'query_aborted',\n   288→}\n   289→\n   290→type Encoding =\n   291→    | 'base64'\n   292→    | 'binary'\n   293→\n   294→/**\n   295→ * FileInfo data for file-related Query statuses\n   296→ */\n   297→export interface FileInfo {\n   298→    /** Absolute path to the file */\n   299→    path: string;\n   300→    /** Content of the file */\n   301→    content?: string | Buffer;\n   302→    /** Filename */\n   303→    filename?: string;\n   304→    /** Size of the file in bytes */\n   305→    size?: number;\n   306→    /** Flag indicating if the file is an edited existing file */\n   307→    isEdit?: boolean;\n   308→    /** Encoding of the content (e.g., 'base64') */\n   309→    encoding?: Encoding;\n   310→    /** Optional drive ID for files stored in a service like OneDrive */\n   311→    driveId?: string;\n   312→    /** Optional drive item ID for files stored in a service like OneDrive */\n   313→    driveItemId?: string;\n   314→}\n   315→\n   316→/**\n   317→ * Slide count info for PPTX-related Query statuses\n   318→ */\n   319→export interface SlideCountInfo {\n   320→    /** Total number of slides that will be created */\n   321→    slideCount: number;\n   322→    /** Timestamp when the slide count was determined */\n   323→    timestamp: string;\n   324→}\n   325→\n   326→/**\n   327→ * Document statistics info for DOCX-related Query statuses\n   328→ */\n   329→export interface DocxStatisticsInfo {\n   330→    /** Document statistics in JSON format */\n   331→    statistics: {\n   332→        word_count: number;\n   333→        section_count: number;\n   334→        table_count: number;\n   335→        image_count: number;\n   336→        list_count: number;\n   337→        heading_count: number;\n   338→        chart_count: number;\n   339→        paragraph_count: number;\n   340→        code_block_count: number;\n   341→        quote_count: number;\n   342→        textbox_count: number;\n   343→        hyperlink_count: number;\n   344→        break_count: number;\n   345→        chart_types?: Record<string, number>;\n   346→    };\n   347→}\n   348→\n   349→/**\n   350→ * Locale info for language detection Query statuses\n   351→ */\n   352→export interface LocaleInfo {\n   353→    /** Language locale detected from the prompt (e.g., 'en-US', 'es-ES') */\n   354→    locale: string;\n   355→}\n   356→\n   357→/**\n   358→ * Query status message payload\n   359→ */\n   360→export interface QueryStatusPayload {\n   361→    /** Query status type */\n   362→    type: QueryStatusType;\n   363→    // Optional file info for file-related statuses\n   364→    fileInfo?: FileInfo;\n   365→    // Optional slide count info for PPTX-related statuses\n   366→    slideCountInfo?: SlideCountInfo;\n   367→    /** Error message for failed operations */\n   368→    error?: string;\n   369→    /** Error code for failed operations */\n   370→    errorCode?: QueryErrorCode;\n   371→}\n   372→\n   373→export interface UserContextResponsePayload {\n   374→    contextPrompt: string;\n   375→    success: boolean;\n   376→    errorMessage?: string;\n   377→}\n   378→\n   379→export interface UserContextResponsePayloadV2 {\n   380→    userProfile: any;\n   381→    focusAreas: any[];\n   382→    recentContext: any;\n   383→    success: boolean;\n   384→    errorMessage?: string;\n   385→}\n   386→\n   387→/**\n   388→ * Citation Injection Request Payload\n   389→ * Sent to AL to populate citation metadata in content\n   390→ */\n   391→export interface CitationInjectionRequestPayload {\n   392→    /** Content with citation placeholders */\n   393→    content: string;\n   394→    /** Identifier for tracking */\n   395→    id?: string;\n   396→    /** Content type: html, json, officeJS */\n   397→    contentType?: 'html' | 'json' | 'officeJS';\n   398→}\n   399→\n   400→/**\n   401→ * Citation Injection Response Payload\n   402→ * Returned from AL with populated citation metadata\n   403→ */\n   404→export interface CitationInjectionResponsePayload {\n   405→    /** Content with populated citations */\n   406→    content: string;\n   407→    /** Number of citations populated */\n   408→    citationCount: number;\n   409→    /** Identifier (echoed from request) */\n   410→    id?: string;\n   411→    /** Success indicator */\n   412→    success: boolean;\n   413→    /** Error message if failed */\n   414→    error?: string;\n   415→}\n   416→\n   417→/** Citation injection request message type */\n   418→export type CitationInjectionRequestMessage = Message<CitationInjectionRequestPayload>;\n   419→\n   420→/** Citation injection response message type */\n   421→export type CitationInjectionResponseMessage = ResponseMessage<CitationInjectionResponsePayload>;\n   422→\n   423→/**\n   424→ * Query Annotation Interface\n   425→ * Represents a user-attached entity (file, email, meeting, etc.) for document generation\n   426→ */\n   427→export interface IQueryAnnotation {\n   428→    /** Entity ID (e.g., \"SPO_MDhmNDE4NDctNmNm...\", \"xyz@microsoft.com\", etc) */\n   429→    id: string;\n   430→    /** Type of entity: \"File\", \"Email\", \"Meeting\", \"Chat\", \"Transcript\", \"People\" */\n   431→    QueryAnnotationType: string;\n   432→    /** Display name of the entity (e.g., \"Q4 Financial Report.xlsx\") */\n   433→    text: string;\n   434→    /** Additional metadata for the entity */\n   435→    queryAnnotationMetadata?: string;\n   436→}\n   437→\n   438→/**\n   439→ * Provisioned File Metadata Interface\n   440→ * Represents a file that has been pre-provisioned for the agent to access directly\n   441→ * Used primarily for Excel headless operations where files need to be downloaded from SharePoint/OneDrive\n   442→ */\n   443→export interface IProvisionedFileMetadata {\n   444→    /** File name (e.g., \"1_13-1_input.xlsx\") */\n   445→    fileName: string;\n   446→    /** SharePoint/OneDrive URL to the file */\n   447→    fileUrl: string;\n   448→}\n   449→\n   450→/**\n   451→ * Application Context\n   452→ */\n   453→export interface RequestContext {\n   454→    groundingSourceToggles?: IGroundingSourceToggles;\n   455→    /** User-attached entities for document generation */\n   456→    queryAnnotations?: IQueryAnnotation[];\n   457→    /** Pre-provisioned files for direct access (e.g., Excel files to download from SharePoint) */\n   458→    provisionedFileMetadata?: IProvisionedFileMetadata[];\n   459→    /** User Type */\n   460→    scenarioType?: string;\n   461→    /** Conversation ID for tracking multi-turn conversations */\n   462→    conversationId?: string;\n   463→    /** Optional grounding content for clarification questions\n   464→     *  Used to provide additional context when the initial query needs refinement\n   465→     */\n   466→    groundingContent?: string | null;\n   467→    /** Source of the request, e.g., \"MOS3\" for Agents DA */\n   468→    requestSource?: string;\n   469→}\n   470→\n   471→/**\n   472→ * Agent Request Payload\n   473→ * Payload for requesting creation of a new agent instance\n   474→ */\n   475→export interface AgentRequestPayload {\n   476→    query: string;\n   477→    context?: RequestContext;\n   478→    requestId?: string;\n   479→    /** Turn number coming from chat client, may be different from the one we have here in agent */\n   480→    turnNumber?: number;\n   481→}\n   482→\n   483→/**\n   484→ * Chat request payload\n   485→ */\n   486→export interface ChatRequestPayload {\n   487→    query: string;\n   488→}\n   489→\n   490→/**\n   491→ * Chat Response Payload\n   492→ * Immediate acknowledgment of ChatRequest processing\n   493→ */\n   494→export interface ChatResponsePayload {\n   495→    /** Whether request was accepted */\n   496→    success: boolean;\n   497→    /** Error code if failed */\n   498→    error?: string;\n   499→    /** Human-readable error message if failed */\n   500→    errorMessage?: string;\n   501→    /** Request ID for correlation */\n   502→    requestId: string;\n   503→    /** Conversation ID for tracking */\n   504→    conversationId: string;\n   505→}\n   506→\n   507→/**\n   508→ * Telemetry message payload\n   509→ * Used for tracking various telemetry events including skill usage\n   510→ */\n   511→export interface TelemetryPayload {\n   512→    /** Telemetry event type (e.g., 'skill_usage') */\n   513→    eventType: string;\n   514→\n   515→    data: {\n   516→        message?: string;\n   517→        /** Timestamp when event occurred */\n   518→        timestamp: string;\n   519→        /** Additional custom properties */\n   520→        [key: string]: any;\n   521→    };\n   522→}\n   523→\n   524→export interface ChatHistoryResponsePayload {\n   525→    messages: SydneyMessage[];\n   526→    success: boolean;\n   527→    error?: string;\n   528→}\n   529→\n   530→export interface AgentState {\n   531→    stateBuffer: Uint8Array;\n   532→}\n   533→\n   534→export interface AgentStateResponsePayload {\n   535→    state?: AgentState;\n   536→    success: boolean;\n   537→    error?: string;\n   538→}\n   539→\n   540→/**\n   541→ * PPTX Slide Count Notification Payload\n   542→ * Sent when the number of slides for a PowerPoint presentation is determined\n   543→ */\n   544→export type PptxSlideCountNotificationPayload = SlideCountInfo;\n   545→\n   546→// Type aliases for commonly used message types\n   547→\n   548→/** Welcome message type */\n   549→export type WelcomeMessage = Message<WelcomePayload>;\n   550→\n   551→/** Session initialization message type */\n   552→export type SessionInitMessage = Message<SessionInitMessagePayload>;\n   553→\n   554→/** Session initialization response message type */\n   555→export type SessionInitResponseMessage = ResponseMessage<SessionInitResponseMessagePayload>;\n   556→\n   557→/** LLM request message type */\n   558→export type LLMRequestMessage = Message<LLMRequestPayload>;\n   559→\n   560→/** LLM response message type */\n   561→export type LLMResponseMessage = ResponseMessage<LLMResponsePayload>;\n   562→\n   563→/** OpenAI LLM request message type (for Azure/Substrate OpenAI models) */\n   564→export type OpenAILLMRequestMessage = Message<OpenAILLMRequestPayload>;\n   565→\n   566→/** OpenAI LLM response message type (for Azure/Substrate OpenAI models) */\n   567→export type OpenAILLMResponseMessage = ResponseMessage<OpenAILLMResponsePayload>;\n   568→\n   569→// Backwards compatibility aliases\n   570→export type OpenAIRequestMessage = OpenAILLMRequestMessage;\n   571→export type OpenAIResponseMessage = OpenAILLMResponseMessage;\n   572→export type OpenAIRequestPayload = OpenAILLMRequestPayload;\n   573→export type OpenAIResponsePayload = OpenAILLMResponsePayload;\n   574→\n   575→/** MCP request message type */\n   576→export type MCPRequestMessage = Message<MCPRequestPayload>;\n   577→\n   578→/** MCP response message type */\n   579→export type MCPResponseMessage = ResponseMessage<MCPResponsePayload>;\n   580→\n   581→/** Error message type */\n   582→export type ErrorMessage = ErrorResponse;\n   583→\n   584→/** Query status message type */\n   585→export type QueryStatusMessage = Message<QueryStatusPayload>;\n   586→\n   587→/** Telemetry message type */\n   588→export type TelemetryMessage = Message<TelemetryPayload>;\n   589→\n   590→/** User context response message type */\n   591→export type UserContextResponseMessage = ResponseMessage<UserContextResponsePayload>;\n   592→\n   593→/** PPTX slide count notification message type */\n   594→export type PptxSlideCountNotificationMessage = Message<PptxSlideCountNotificationPayload>;\n   595→\n   596→/** Agent request message type */\n   597→export type AgentRequestMessage = Message<AgentRequestPayload>;\n   598→\n   599→/** FOR TESTING PURPOSES ONLY: Chat request message type */\n   600→export type TestChatRequestMessage = Message<ChatRequestPayload>;\n   601→\n   602→/** Chat response message type */\n   603→export type ChatResponseMessage = ResponseMessage<ChatResponsePayload>;\n   604→\n   605→/** Chat history response message type */\n   606→export type ChatHistoryResponseMessage = ResponseMessage<ChatHistoryResponsePayload>;\n   607→\n   608→/** Agent state response message type */\n   609→export type AgentStateResponseMessage = ResponseMessage<AgentStateResponsePayload>;\n   610→"}]},"parent_tool_use_id":"toolu_01AJXnfzeHR2byH3TcFHovhb","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"55c08a1e-3792-4c99-ab67-744706fad968"}
