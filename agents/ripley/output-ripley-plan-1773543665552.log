{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JzT1EMNHXDVG6GN2GaMFvx","type":"tool_result","content":"     1→import type { ISession, IAnnotationActivationResult } from '@augloop/runtime-client';\n     2→import { AddOperation } from '@augloop/types-core';\n     3→import type { IOperation } from '@augloop/types-core';\n     4→import { WorkspaceStatusLoopResponse, WorkspaceStatusLoopRequest } from '@augloop-types/workspace-status';\n     5→\n     6→import { EventCategory } from '@fluidx/1p-loop-types';\n     7→import type { ITelemetryNamespaceLogger } from '@fluidx/1p-loop-types';\n     8→import { tryLogEvent } from '@fluidx/telemetry';\n     9→import type { ActivityTracker } from '@fluidx/telemetry';\n    10→\n    11→import type { WorkspaceStatusTelemetryEvent } from '../telemetry';\n    12→import {\n    13→  getCachedLastUpdatedTime,\n    14→  getCachedWorkspaceActivities,\n    15→  getCachedWSSActivationToken,\n    16→  invalidateCachedActivitiesQuery,\n    17→  setCachedLastUpdatedTime,\n    18→  setCachedWSSActivationToken,\n    19→  setCachedWorkspaceActivities\n    20→} from './WorkspaceStatusCache';\n    21→import { calculateLastUpdatedTime } from './WorkspaceStatusUtils';\n    22→\n    23→/**\n    24→ * Function that activates* and adds request operations to a WorkspaceStatus Augloop WF. *- only activates a new annotation if there is no cached annotation\n    25→ * @param alSession current augLoop session\n    26→ * @param workspaceId workspaceId of the current workspace\n    27→ * @param collabMockEnabled flag to enable collabActions Mocked data\n    28→ * @param collabActionsDiagnosticsEnabled flag to enable collabActions Diagnostic Data\n    29→ * @param activityTracker activityTracker used for logging perf\n    30→ * @param logger logger for logging errors\n    31→ * @param sessionId the current session id to send AL for telemetry purposes\n    32→ * @param lookBackDays number of days we will use to construct the workspace status\n    33→ * @param pageSpoIds *Deprecated* array of workspace pageSpoIds we wish to collect data for\n    34→ */\n    35→export async function callAugLoop(\n    36→  alSession: ISession,\n    37→  workspaceId: string,\n    38→  collabMockEnabled: boolean,\n    39→  collabActionsDiagnosticsEnabled: boolean,\n    40→  activityTracker: ActivityTracker,\n    41→  logger: ITelemetryNamespaceLogger,\n    42→  sessionId: string,\n    43→  lookBackDays: number = 30,\n    44→  pageSpoIds?: string[],\n    45→  logNetworkTelemetry?: boolean\n    46→): Promise<void> {\n    47→  // log duration of workspaces first WF Call (tracking ends in Workspace Status Page Render)\n    48→  if (logNetworkTelemetry) {\n    49→    activityTracker.markSubActivityStart('WSInitialCall');\n    50→  }\n    51→\n    52→  // if augloop annotation has not been activated yet\n    53→  if (!getCachedWSSActivationToken()) {\n    54→    // activate the annotation and store the activation token in the cache\n    55→    try {\n    56→      setCachedWSSActivationToken(await activateWSAnnotation(alSession, logger, activityTracker));\n    57→    } catch (e) {\n    58→      const WorkspaceStatusALRequestError: WorkspaceStatusTelemetryEvent = 'WorkspaceStatusALRequestError';\n    59→      const message = `failed to activate Workspace Status workflow with error: ${e}`;\n    60→      tryLogEvent(\n    61→        EventCategory.Error,\n    62→        logger,\n    63→        {\n    64→          eventName: WorkspaceStatusALRequestError\n    65→        },\n    66→        { message }\n    67→      );\n    68→    }\n    69→  }\n    70→  try {\n    71→    requestWSAugLoop(\n    72→      alSession,\n    73→      workspaceId,\n    74→      collabMockEnabled,\n    75→      collabActionsDiagnosticsEnabled,\n    76→      sessionId,\n    77→      lookBackDays,\n    78→      pageSpoIds?.length ? pageSpoIds : undefined,\n    79→      activityTracker\n    80→    );\n    81→  } catch (e) {\n    82→    const WorkspaceStatusALRequestError: WorkspaceStatusTelemetryEvent = 'WorkspaceStatusALRequestError';\n    83→    const message = `failed to add Workspace Status workflow request with error: ${e}`;\n    84→    tryLogEvent(\n    85→      EventCategory.Error,\n    86→      logger,\n    87→      {\n    88→        eventName: WorkspaceStatusALRequestError\n    89→      },\n    90→      { message }\n    91→    );\n    92→  }\n    93→}\n    94→\n    95→/**\n    96→ * Activate the WS workflow annotation callback that will be called by AL once our request is processed\n    97→ * @param alSession current augLoop session\n    98→ * @param logger for error logging\n    99→ * @param activityTracker\n   100→ * @returns an IAnnotationActivationResult which contains the activation token corresponding to the activated annotation\n   101→ */\n   102→async function activateWSAnnotation(\n   103→  alSession: ISession,\n   104→  logger: ITelemetryNamespaceLogger,\n   105→  activityTracker: ActivityTracker\n   106→): Promise<IAnnotationActivationResult> {\n   107→  activityTracker.markSubActivityStart('ActivateWSAnnotation');\n   108→\n   109→  // callback function for WF activation that updates cache\n   110→  const handleWSAugLoopResponse = (data: IOperation) => {\n   111→    const response = data.items[0].body as WorkspaceStatusLoopResponse;\n   112→    const newUpdateTime = calculateLastUpdatedTime(\n   113→      response /* new Response */,\n   114→      getCachedWorkspaceActivities(response.workspaceStatusSignalData.workspaceId) /*cached Response*/,\n   115→      getCachedLastUpdatedTime(response.workspaceStatusSignalData.workspaceId) /*cached lastUpdatedTime*/\n   116→    );\n   117→\n   118→    // Telemetry Tracking for monitors\n   119→    const WorkspaceStatusSignalLengthBySession: WorkspaceStatusTelemetryEvent = 'WorkspaceStatusSignalLengthBySession';\n   120→\n   121→    tryLogEvent(EventCategory.Generic, logger, {\n   122→      eventName: WorkspaceStatusSignalLengthBySession,\n   123→      signalLength: response.workspaceStatusSignalData.validatedCollabActivities.length,\n   124→      workspaceId: response.workspaceStatusSignalData.workspaceId\n   125→    });\n   126→    // It's possible that status code is 200 but we have error message, so log the data if we have errorDataMessage\n   127→    if (\n   128→      response.collabActionsDiagnostic?.HttpStatusCode !== '200' ||\n   129→      // Response code string is converted to a number during JSON extraction -- casting for compiler\n   130→      (response.collabActionsDiagnostic.ResponseCode && Number(response.collabActionsDiagnostic.ResponseCode) === 10010)\n   131→    ) {\n   132→      const WorkspaceStatusCollabActionsError: WorkspaceStatusTelemetryEvent = 'WorkspaceStatusCollabActionsError';\n   133→\n   134→      tryLogEvent(EventCategory.Error, logger, {\n   135→        eventName: WorkspaceStatusCollabActionsError,\n   136→        statusCode: response.collabActionsDiagnostic?.HttpStatusCode,\n   137→        errorMessage: response.collabActionsDiagnostic?.ResponseCode\n   138→      });\n   139→\n   140→      // This code has us show the empty card instead of infinitely shimmering\n   141→      if (getCachedWorkspaceActivities(response.workspaceStatusSignalData.workspaceId) === undefined) {\n   142→        setCachedWorkspaceActivities(response.workspaceStatusSignalData.workspaceId, response);\n   143→        setCachedLastUpdatedTime(response.workspaceStatusSignalData.workspaceId, newUpdateTime);\n   144→        // invalidate cached useQuery to trigger re-render\n   145→        invalidateCachedActivitiesQuery(response.workspaceStatusSignalData.workspaceId, logger);\n   146→      }\n   147→    } else {\n   148→      // update cached activities and mark currently displayed activities as stale\n   149→      // only if response does not contain an error message\n   150→      setCachedWorkspaceActivities(response.workspaceStatusSignalData.workspaceId, response);\n   151→      setCachedLastUpdatedTime(response.workspaceStatusSignalData.workspaceId, newUpdateTime);\n   152→      // invalidate cached useQuery to trigger re-render\n   153→      invalidateCachedActivitiesQuery(response.workspaceStatusSignalData.workspaceId, logger);\n   154→    }\n   155→  };\n   156→\n   157→  const activationResponseToken = await alSession.activateAnnotation(WorkspaceStatusLoopResponse.getTypeName(), {\n   158→    callback: (operation: IOperation) => {\n   159→      handleWSAugLoopResponse(operation);\n   160→    }\n   161→  });\n   162→\n   163→  activityTracker.markSubActivityEnd('ActivateWSAnnotation');\n   164→  return activationResponseToken;\n   165→}\n   166→\n   167→/**\n   168→ * Function to send request for workspace status to augloop, the result is handled by the handleWSResponse callback\n   169→ * set in the AL annotation activation\n   170→ * @param alSession current augLoop session\n   171→ */\n   172→function requestWSAugLoop(\n   173→  alSession: ISession,\n   174→  workspaceId: string,\n   175→  collabMockEnabled: boolean,\n   176→  collabActionsDiagnosticsEnabled: boolean,\n   177→  sessionId: string,\n   178→  lookBackDays: number,\n   179→  pageSpoIds?: string[],\n   180→  activityTracker?: ActivityTracker\n   181→): void {\n   182→  activityTracker?.markSubActivityStart('RequestWSAugLoop');\n   183→  const operation: IOperation = {\n   184→    parentPath: ['session', 'doc'],\n   185→    items: [\n   186→      {\n   187→        id: crypto.randomUUID().toString(),\n   188→        body: new WorkspaceStatusLoopRequest({\n   189→          WorkspaceId: workspaceId,\n   190→          PageIds: pageSpoIds,\n   191→          WorkspaceStatusCollabDiagnosticsRequest: {\n   192→            ReturnWorkflowDiagnostics: collabActionsDiagnosticsEnabled,\n   193→            IsMock: collabMockEnabled,\n   194→            SessionId: sessionId\n   195→          },\n   196→          LookbackDays: lookBackDays\n   197→        })\n   198→      }\n   199→    ]\n   200→  };\n   201→\n   202→  alSession.submitOperation(new AddOperation(operation));\n   203→  activityTracker?.markSubActivityEnd('RequestWSAugLoop');\n   204→}\n   205→"}]},"parent_tool_use_id":"toolu_01JUCvAHSXRtjX93sY9sKE3i","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"27546b93-bcca-4dd2-838c-9e31e3b909ed"}
