{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DRUntUJ6vVtLRQTMQwEmCQ","type":"tool_result","content":"     1→/**\n     2→ * Base Hooks Provider - Shared hooks for all Office agents\n     3→ */\n     4→\n     5→import { HookProvider, SessionContext, AgentHooks, TurnContext, logInfo, logDebug, logWarn, AgentWorkspaceManager } from '@officeagent/core';\n     6→import { Options } from '@anthropic-ai/claude-agent-sdk';\n     7→import { createPerfTrackingHooks } from '../services/performance-tracker-service';\n     8→import { IProvisionedFileMetadata } from '@officeagent/message-protocol';\n     9→import { existsSync } from 'fs';\n    10→import { copyFile, mkdir } from 'fs/promises';\n    11→import { join, dirname } from 'path';\n    12→import { createTerminalHooks } from './terminal-hooks';\n    13→import { saveMetadata as saveExcelFileMetadata } from '../services/excel/excel-file-metadata';\n    14→import { fetchBatchedUserAttachedContent } from '@officeagent/grounding';\n    15→\n    16→/**\n    17→ * Base hook provider for common functionality across all Office agents\n    18→ *\n    19→ * Implements hooks that should run for all agents regardless of type:\n    20→ * - Performance tracking (PreToolUse, PostToolUse, SessionStart, SessionEnd)\n    21→ * - Chain of thought for subagent execution (PostToolUse)\n    22→ *\n    23→ * Change Gate: OfficeAgent.EnableBaseHooksProvider\n    24→ * - When enabled: Uses centralized base hooks provider\n    25→ * - When disabled: Returns empty hooks (caller should use legacy hook creation)\n    26→ */\n    27→export class BaseHooksProvider implements HookProvider {\n    28→    createHooks(context: SessionContext, _turnContext?: TurnContext): AgentHooks {\n    29→        // Check change gate to enable/disable base hooks provider\n    30→        const enableBaseHooksProvider = context.settingsManager?.changeGate('OfficeAgent.EnableBaseHooksProvider') ?? true;\n    31→\n    32→        if (!enableBaseHooksProvider) {\n    33→            logDebug('[BaseHooks] Base hooks provider disabled by change gate, returning empty hooks');\n    34→            return {\n    35→                claude: {}, // Return empty Claude hooks - caller should create legacy hooks\n    36→                startTurn: createBaseStartTurnHook(context), // Keep startTurn for user-attachment fetching\n    37→            };\n    38→        }\n    39→\n    40→        // Create performance tracking hooks\n    41→        const perfHooks = createPerfTrackingHooks(context.sessionId, context.settingsManager);\n    42→\n    43→        // Combine base hooks using Claude SDK format\n    44→        const claudeHooks: Options['hooks'] = {\n    45→            PreToolUse: [{ hooks: [perfHooks.PreToolUse] }],\n    46→            PostToolUse: [{ hooks: [perfHooks.PostToolUse] }],\n    47→            SessionStart: [{ hooks: [perfHooks.SessionStart] }],\n    48→            SessionEnd: [{ hooks: [perfHooks.SessionEnd] }],\n    49→        };\n    50→\n    51→        if (process.env.OFFICEPY_EXT_BUILD_SPEC === 'dev' && context.settingsManager?.changeGate('OfficeAgent.EnableTerminalHooks')) {\n    52→            // Terminal hooks are only enabled in dev builds for local testing/eval\n    53→            const terminalHooks = createTerminalHooks(context.settingsManager);\n    54→            claudeHooks.PostToolUse?.[0].hooks?.push(terminalHooks.PostToolUse);\n    55→            claudeHooks.PreToolUse?.[0].hooks?.push(terminalHooks.PreToolUse);\n    56→        }\n    57→\n    58→        return {\n    59→            claude: claudeHooks,\n    60→            startTurn: createBaseStartTurnHook(context),\n    61→        };\n    62→    }\n    63→}\n    64→\n    65→/**\n    66→ * Create the startTurn hook for base functionality\n    67→ * Runs at the beginning of each turn for all agents\n    68→ *\n    69→ * Use cases:\n    70→ * - Initialize turn-level logging and metrics\n    71→ * - Log turn start with context information\n    72→ * - Fetch user-attached content if queryAnnotations present\n    73→ * - Future: Turn-level feature gate initialization, A/B testing setup\n    74→ *\n    75→ * @param context - Session context with settings and metadata\n    76→ * @returns Async function that executes at turn start\n    77→ */\n    78→function createBaseStartTurnHook(context: SessionContext): (turnContext: TurnContext) => Promise<void> {\n    79→    return async (turnContext: TurnContext) => {\n    80→        const turnNumber = turnContext.workspaceManager.getCurrentTurnNumber();\n    81→        const sessionId = context.sessionId;\n    82→        const agentName = context.clientMetadata?.agentName || 'unknown';\n    83→\n    84→        logInfo(0x1e0dc661 /* tag_4d2z7 */, `[BaseHooks] Turn ${turnNumber} started for agent: ${agentName}`);\n    85→        logDebug(`[BaseHooks] Turn ${turnNumber} context:`, {\n    86→            sessionId,\n    87→            agentName,\n    88→            workspaceDir: turnContext.workspaceManager.getWorkspaceDir(),\n    89→            outputDir: turnContext.workspaceManager.getOutputDir(),\n    90→            logsDir: turnContext.workspaceManager.getLogsDir(),\n    91→        });\n    92→\n    93→        const queryAnnotations = turnContext.requestContext?.queryAnnotations;\n    94→\n    95→        // Copy entityMap.jsonl from previous turn and append any new attachments to it\n    96→        if (turnNumber > 1) {\n    97→            logInfo(0x1e090849 /* tag_4cq7j */, `[BaseHooks] Attempting to copy entityMap from turn: ${turnNumber - 1} to turn: ${turnNumber}`);\n    98→            await copyEntityMapFromPreviousTurn(turnNumber);\n    99→        }\n   100→"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"30038ba1-2115-473e-9fc3-75973bbbf3ab"}
