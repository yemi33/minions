{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FGY1Ppkbd8z6Haohhkdv8Y","type":"tool_result","content":"     1→/**\n     2→ * Claude Hook Adapter\n     3→ *\n     4→ * Translates provider-agnostic GenericToolHooks into the Claude Agent SDK\n     5→ * Options['hooks'] format ({ PreToolUse, PostToolUse, SessionStart, SessionEnd }).\n     6→ *\n     7→ * This adapter allows hook providers (ppt-hooks, word-hooks, etc.) to be\n     8→ * written once using GenericToolHooks and work with the Claude orchestrator.\n     9→ */\n    10→\n    11→import type { Options, HookCallback, HookInput, SyncHookJSONOutput } from '@anthropic-ai/claude-agent-sdk';\n    12→import type { GenericToolHooks, PreToolUseHook, PostToolUseHook } from '../types';\n    13→\n    14→/**\n    15→ * Adapt a GenericToolHooks instance into Claude SDK Options['hooks'] format.\n    16→ *\n    17→ * @param genericHooks - Provider-agnostic hook definitions\n    18→ * @returns Claude SDK hooks object ready to be passed to Options.hooks\n    19→ */\n    20→export function toClaudeHooks(genericHooks: GenericToolHooks): NonNullable<Options['hooks']> {\n    21→    const claudeHooks: NonNullable<Options['hooks']> = {};\n    22→\n    23→    // Adapt PreToolUse hooks\n    24→    if (genericHooks.preToolUse && genericHooks.preToolUse.length > 0) {\n    25→        claudeHooks.PreToolUse = [\n    26→            {\n    27→                hooks: genericHooks.preToolUse.map((hook) => wrapPreToolUseHook(hook)),\n    28→            },\n    29→        ];\n    30→    }\n    31→\n    32→    // Adapt PostToolUse hooks\n    33→    if (genericHooks.postToolUse && genericHooks.postToolUse.length > 0) {\n    34→        claudeHooks.PostToolUse = [\n    35→            {\n    36→                hooks: genericHooks.postToolUse.map((hook) => wrapPostToolUseHook(hook)),\n    37→            },\n    38→        ];\n    39→    }\n    40→\n    41→    // Adapt SessionStart hooks\n    42→    if (genericHooks.onSessionStart && genericHooks.onSessionStart.length > 0) {\n    43→        claudeHooks.SessionStart = genericHooks.onSessionStart.map((hook) => ({\n    44→            hooks: [(async (_input: HookInput, _toolUseID: string | undefined, _options: { signal: AbortSignal }): Promise<SyncHookJSONOutput> => {\n    45→                await hook();\n    46→                return {};\n    47→            }) as HookCallback],\n    48→        }));\n    49→    }\n    50→\n    51→    // Adapt SessionEnd hooks\n    52→    if (genericHooks.onSessionEnd && genericHooks.onSessionEnd.length > 0) {\n    53→        claudeHooks.SessionEnd = genericHooks.onSessionEnd.map((hook) => ({\n    54→            hooks: [(async (_input: HookInput, _toolUseID: string | undefined, _options: { signal: AbortSignal }): Promise<SyncHookJSONOutput> => {\n    55→                await hook();\n    56→                return {};\n    57→            }) as HookCallback],\n    58→        }));\n    59→    }\n    60→\n    61→    return claudeHooks;\n    62→}\n    63→\n    64→/**\n    65→ * Wrap a generic PreToolUseHook into a Claude SDK HookCallback.\n    66→ *\n    67→ * Claude PreToolUse hooks receive (input: HookInput, toolUseID, options) and return\n    68→ * a SyncHookJSONOutput with optional `decision` ('block'|'approve'), `reason`, and\n    69→ * `hookSpecificOutput` for input modifications.\n    70→ */\n    71→function wrapPreToolUseHook(hook: PreToolUseHook): HookCallback {\n    72→    return (async (input: HookInput, _toolUseID: string | undefined, _options: { signal: AbortSignal }): Promise<SyncHookJSONOutput> => {\n    73→        const preInput = input as { tool_name?: string; tool_input?: unknown };\n    74→        const toolName = preInput.tool_name ?? '';\n    75→        const toolInput = preInput.tool_input;\n    76→\n    77→        const result = await hook(toolName, toolInput);\n    78→\n    79→        if (!result.continue) {\n    80→            return {\n    81→                decision: 'block' as const,\n    82→                reason: result.reason ?? 'Blocked by generic hook',\n    83→            };\n    84→        }\n    85→\n    86→        if (result.modifiedInput !== undefined) {\n    87→            return {\n    88→                decision: 'approve' as const,\n    89→                hookSpecificOutput: {\n    90→                    hookEventName: 'PreToolUse' as const,\n    91→                    updatedInput: result.modifiedInput as Record<string, unknown>,\n    92→                },\n    93→            };\n    94→        }\n    95→\n    96→        return {};\n    97→    }) as HookCallback;\n    98→}\n    99→\n   100→/**\n   101→ * Wrap a generic PostToolUseHook into a Claude SDK HookCallback.\n   102→ *\n   103→ * Claude PostToolUse hooks receive (input: HookInput, toolUseID, options) and return\n   104→ * a SyncHookJSONOutput with optional `hookSpecificOutput` for output modifications.\n   105→ */\n   106→function wrapPostToolUseHook(hook: PostToolUseHook): HookCallback {\n   107→    return (async (input: HookInput, _toolUseID: string | undefined, _options: { signal: AbortSignal }): Promise<SyncHookJSONOutput> => {\n   108→        const postInput = input as { tool_name?: string; tool_response?: unknown };\n   109→        const toolName = postInput.tool_name ?? '';\n   110→        const output = postInput.tool_response;\n   111→\n   112→        const result = await hook(toolName, output);\n   113→\n   114→        if (result.modifiedOutput !== undefined) {\n   115→            return {\n   116→                hookSpecificOutput: {\n   117→                    hookEventName: 'PostToolUse' as const,\n   118→                    updatedMCPToolOutput: result.modifiedOutput,\n   119→                },\n   120→            };\n   121→        }\n   122→\n   123→        return {};\n   124→    }) as HookCallback;\n   125→}\n   126→\n   127→/**\n   128→ * Merge generic hooks with existing Claude SDK hooks.\n   129→ *\n   130→ * Useful during migration when some hooks are already in Claude format\n   131→ * and others are in the new generic format.\n   132→ */\n   133→export function mergeWithClaudeHooks(\n   134→    existingClaudeHooks: Options['hooks'],\n   135→    genericHooks: GenericToolHooks\n   136→): NonNullable<Options['hooks']> {\n   137→    const adaptedHooks = toClaudeHooks(genericHooks);\n   138→    const merged: NonNullable<Options['hooks']> = { ...(existingClaudeHooks ?? {}) };\n   139→\n   140→    // Concatenate PreToolUse arrays\n   141→    if (adaptedHooks.PreToolUse) {\n   142→        merged.PreToolUse = [...(merged.PreToolUse ?? []), ...adaptedHooks.PreToolUse];\n   143→    }\n   144→\n   145→    // Concatenate PostToolUse arrays\n   146→    if (adaptedHooks.PostToolUse) {\n   147→        merged.PostToolUse = [...(merged.PostToolUse ?? []), ...adaptedHooks.PostToolUse];\n   148→    }\n   149→\n   150→    // Concatenate SessionStart arrays"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"76c06462-6d36-44c1-949c-b574f083183c"}
