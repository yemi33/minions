{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011gc49JPRA7xH6d1JYEwp8X","type":"tool_result","content":"     1→import WebSocket from 'ws';\n     2→import { ErrorResponse, Message, MessageType } from '@officeagent/message-protocol';\n     3→import { logError, logInfo } from '../logging';\n     4→import { wsRouter } from './router';\n     5→import { v4 as uuidv4 } from 'uuid';\n     6→import type { OfficeAgentSettingsManager } from './settings';\n     7→\n     8→/**\n     9→ * Failure reasons for sendMessage operations\n    10→ */\n    11→export enum SendMessageFailureReason {\n    12→    NoClient = 'no_client',\n    13→    NotConnected = 'not_connected',\n    14→    PayloadTooLarge = 'payload_too_large',\n    15→    JsonTooLarge = 'json_too_large',\n    16→    Error = 'error'\n    17→}\n    18→\n    19→/**\n    20→ * Result of a sendMessage operation\n    21→ */\n    22→export interface SendMessageResult {\n    23→    success: boolean;\n    24→    failureReason?: SendMessageFailureReason;\n    25→}\n    26→\n    27→/**\n    28→ * Singleton class to manage WebSocket connections and messaging\n    29→ * Provides a centralized interface for sending messages to connected clients\n    30→ */\n    31→class WebSocketManager {\n    32→    private wss: WebSocket.Server;\n    33→    private currentWsSession: WebSocketSession | undefined = undefined;\n    34→    private connectedClientsMap = new Map<string, WebSocketSession>();\n    35→    private settingsManager?: OfficeAgentSettingsManager;\n    36→    private readonly maxFileSizeMB: number;\n    37→    private readonly MAX_FILE_SIZE: number;\n    38→\n    39→    /**\n    40→     * Constructor to initialize WebSocketManager with a WebSocket server\n    41→     * @param wss - The WebSocket server instance\n    42→     * @param settingsManager - Optional settings manager for changeGate and settings access\n    43→     */\n    44→    constructor(wss: WebSocket.Server, settingsManager?: OfficeAgentSettingsManager) {\n    45→        this.wss = wss;\n    46→        this.settingsManager = settingsManager;\n    47→        // Get max size limits once at initialization (default to 99 MB to provide safety margin with max WebSocket payload size of 100 MB)\n    48→        this.maxFileSizeMB = settingsManager?.getIntSetting?.('MaxJSONMessageSizeContainerMB', 99) ?? 99;\n    49→        this.MAX_FILE_SIZE = this.maxFileSizeMB * 1024 * 1024;\n    50→        this.setupConnectionHandlers();\n    51→    }\n    52→\n    53→    /**\n    54→     * Setup connection and disconnection handlers\n    55→     */\n    56→    private setupConnectionHandlers(): void {\n    57→        this.wss.on('connection', (ws) => {\n    58→            logInfo(0x1e0dc006 /* tag_4d2ag */, '🔌 New WebSocket client connected');\n    59→            new WebSocketSession(ws, this);\n    60→        });\n    61→    }\n    62→\n    63→    /**\n    64→     * Send a message to the currently connected WebSocket client\n    65→     * @param message - The message object to send (will be JSON stringified)\n    66→     * @returns SendMessageResult with success status and optional failure reason\n    67→     */\n    68→    public sendMessage(message: unknown): SendMessageResult {\n    69→        if (!this.currentWsSession) {\n    70→            logError(0x1e0dc003 /* tag_4d2ad */, '❌ Cannot send message: No WebSocket client connected');\n    71→            return { success: false, failureReason: SendMessageFailureReason.NoClient };\n    72→        }\n    73→\n    74→        if (!this.isConnected()) {\n    75→            logError(0x1e0dc002 /* tag_4d2ac */, '❌ Cannot send message: WebSocket connection is not open');\n    76→            return { success: false, failureReason: SendMessageFailureReason.NotConnected };\n    77→        }\n    78→\n    79→        try {\n    80→            // Extract file metadata once for reuse in validation and logging\n    81→            const fileMetadata = this.extractFileMetadata(message as any);\n    82→\n    83→            // Pre-validate buffer size to prevent JSON.stringify crash\n    84→            // JavaScript arrays have a max length limit, and Buffer.toJSON() creates an array\n    85→            // For buffers larger than ~100MB, JSON.stringify will fail with \"Invalid array length\"\n    86→            if (this.settingsManager?.changeGate?.('ValidateBufferSizeBeforeStringify') && fileMetadata) {\n    87→                if (fileMetadata.binarySize >= this.MAX_FILE_SIZE) {\n    88→                    logError(\n    89→                        0x1e085180 /* tag_4cfga */,\n    90→                        `[WebSocketManager] Buffer too large for JSON serialization: ${fileMetadata.messageType} message, binarySize=${fileMetadata.binarySizeKB}KB, ext=${fileMetadata.ext}, limit=${this.maxFileSizeMB}MB. Message will not be transmitted.`\n    91→                    );\n    92→                    return { success: false, failureReason: SendMessageFailureReason.PayloadTooLarge };\n    93→                }\n    94→            }\n    95→\n    96→            const jsonString = JSON.stringify(message);\n    97→\n    98→            // Log serialized message size for messages with binary content (gated by changeGate)\n    99→            if (this.settingsManager?.changeGate?.('EnableWsSerializationLogging') && fileMetadata) {\n   100→                const jsonSize = Buffer.byteLength(jsonString, 'utf8');"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"7f4bc8e8-420b-43c6-86ea-4a92a7db9fd5"}
