{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CR9ijArkuu9SFcPW4sQiAj","type":"tool_result","content":"     1→import { createMiddleware } from '@tanstack/react-start';\n     2→import { notFound } from '@tanstack/react-router';\n     3→import { createServerTokenProvider, extractAuthenticationFromRequest } from '@bebopjs/bebop-auth/server';\n     4→import { markEvent } from '../telemetry/perfTracker';\n     5→import type { PerfTracker } from '../telemetry/perfTracker';\n     6→import type { AuthContext, ServerTokenProvider } from '@bebopjs/bebop-auth/server';\n     7→\n     8→/**\n     9→ * Auth request context from server middleware.\n    10→ */\n    11→export interface AuthRequestContext {\n    12→  /**\n    13→   * Identity and auth options extracted from request headers.\n    14→   */\n    15→  auth: AuthContext;\n    16→  /**\n    17→   * Server token provider for downstream service calls.\n    18→   */\n    19→  serverTokenProvider: ServerTokenProvider;\n    20→}\n    21→\n    22→/**\n    23→ * Auth middleware that runs on the server to extract and validate identity.\n    24→ * Creates a ServerTokenProvider that can be reused across all server functions.\n    25→ * The context is passed to server functions and can be sent to the client.\n    26→ */\n    27→export const authMiddleware = createMiddleware({ type: 'request' }).server<AuthRequestContext>(\n    28→  ({ next, request, context }) => {\n    29→    const perfTracker = (context as Partial<{ perfTracker: PerfTracker }> | undefined)?.perfTracker;\n    30→\n    31→    const authResult = extractAuthenticationFromRequest({\n    32→      getHeader: (name) => request.headers.get(name)\n    33→    });\n    34→\n    35→    if (perfTracker) {\n    36→      markEvent(perfTracker, 'auth_extraction_complete');\n    37→    }\n    38→\n    39→    if (!authResult.success) {\n    40→      // Log error code for telemetry\n    41→      // eslint-disable-next-line no-console -- Temporary console log that is going to be replaced with real telemetry\n    42→      console.error('[Auth] Authentication extraction failed:', authResult.error);\n    43→\n    44→      // eslint-disable-next-line @typescript-eslint/only-throw-error -- Using TanStack Router's notFound helper to throw a 404\n    45→      throw notFound();\n    46→    }\n    47→\n    48→    const headers = {\n    49→      authorization: request.headers.get('Authorization'),\n    50→      cookie: request.headers.get('Cookie')\n    51→    };\n    52→\n    53→    // Create server token provider once per request for reuse across server functions\n    54→    const serverTokenProvider = createServerTokenProvider(headers);\n    55→\n    56→    if (perfTracker) {\n    57→      markEvent(perfTracker, 'auth_middleware_complete');\n    58→    }\n    59→\n    60→    // Pass auth context to routes and server functions\n    61→    // TanStack middleware does not type-chain upstream context; cast required to spread requestLoggingMiddleware's context (e.g. perfTracker)\n    62→    const upstreamContext = context as unknown as Record<string, unknown>;\n    63→    return next({\n    64→      context: {\n    65→        ...upstreamContext,\n    66→        auth: {\n    67→          identity: authResult.identity,\n    68→          authOptions: authResult.authOptions\n    69→        },\n    70→        serverTokenProvider\n    71→      }\n    72→    });\n    73→  }\n    74→);\n    75→"}]},"parent_tool_use_id":"toolu_01DLPgnTkmGzXzsDrb5HSUSt","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"86f9fbe5-ea92-4e1b-b594-8ad61981986b"}
