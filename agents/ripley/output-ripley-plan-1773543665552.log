{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kqz9x8ULbt4QDuArVSP6mV","type":"tool_result","content":"     1→'use client';\n     2→import 'client-only';\n     3→\n     4→import { getIdentity } from '../../utils/identityStore';\n     5→import { SYDNEY_CONFIG, SYDNEY_RESOURCE } from '@bebopjs/bebop-shared-config';\n     6→import { getToken } from '@bebopjs/bebop-auth';\n     7→import { getEndpointForSessions } from '@bebopjs/bebop-sydney-client';\n     8→import type { PropsWithChildren, JSX } from 'react';\n     9→import { WebRTCSessionProvider } from '@bebopjs/bebop-webrtc/WebRTCSessionProvider';\n    10→import { useLogger } from '@bebopjs/bebop-telemetry-react';\n    11→\n    12→// Generate a unique correlation ID per app session\n    13→const sessionCorrelationId = crypto.randomUUID();\n    14→const getCorrelationId = () => sessionCorrelationId;\n    15→\n    16→export const RealtimeVoiceProvider = ({ children }: PropsWithChildren): JSX.Element => {\n    17→  const sydneyConfig = {\n    18→    serviceEndpointInfra: SYDNEY_CONFIG.endpointInfra,\n    19→    serviceEndpointRing: SYDNEY_CONFIG.endpointRing,\n    20→    hostAppScenario: SYDNEY_CONFIG.scenarioName,\n    21→    hostAppSource: SYDNEY_CONFIG.sourceName,\n    22→    sessionsEndpointUrl: getEndpointForSessions({ ring: SYDNEY_CONFIG.endpointRing })\n    23→  };\n    24→\n    25→  const logger = useLogger();\n    26→\n    27→  const getSydneyToken = async () => {\n    28→    const result = await getToken(\n    29→      {\n    30→        resourceId: SYDNEY_RESOURCE,\n    31→        forceFetch: true\n    32→      },\n    33→      logger\n    34→    );\n    35→    if (result.success && result.token) {\n    36→      return result.token;\n    37→    } else {\n    38→      throw new Error('Could not fetch Sydney token');\n    39→    }\n    40→  };\n    41→\n    42→  const accountInfo = getIdentity();\n    43→\n    44→  return (\n    45→    <WebRTCSessionProvider\n    46→      sydneyConfig={sydneyConfig}\n    47→      accountInfo={accountInfo}\n    48→      sydneyTokenProvider={getSydneyToken}\n    49→      getCurrentClientCorrelationId={getCorrelationId}\n    50→      logger={logger}\n    51→    >\n    52→      {children}\n    53→    </WebRTCSessionProvider>\n    54→  );\n    55→};\n    56→"}]},"parent_tool_use_id":"toolu_01DLPgnTkmGzXzsDrb5HSUSt","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"f9f6a532-867a-467a-a9b1-500be427bd37"}
