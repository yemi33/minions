{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hd6akMwpkrwVMVue1DgWU6","type":"tool_result","content":"     1→import { createFileRoute } from '@tanstack/react-router';\n     2→import { ZodError } from 'zod';\n     3→import { requestChat } from '../../features/conversation/serverFunctions/chat';\n     4→import { getHistory } from '../../features/conversation/serverFunctions/history';\n     5→import { warmupConversation } from '../../features/conversation/serverFunctions/warmup';\n     6→import { errorsResponses } from '../../core/server/responses/errors';\n     7→\n     8→/**\n     9→ * Conversation API endpoint.\n    10→ *\n    11→ * GET  ?conversationId=xxx  — Streams conversation history HTML\n    12→ * POST { message, traceId, conversationId? } — Streams chat response HTML\n    13→ */\n    14→export const Route = createFileRoute('/api/conversation')({\n    15→  server: {\n    16→    handlers: {\n    17→      GET: async ({ request }) => {\n    18→        const url = new URL(request.url);\n    19→        const conversationId = url.searchParams.get('conversationId');\n    20→\n    21→        try {\n    22→          const stringStream = await getHistory({\n    23→            data: { conversationId: conversationId ?? '' }\n    24→          });\n    25→\n    26→          const encoder = new TextEncoder();\n    27→          const byteStream = stringStream.pipeThrough(\n    28→            new TransformStream({\n    29→              transform(chunk, controller) {\n    30→                controller.enqueue(encoder.encode(chunk));\n    31→              }\n    32→            })\n    33→          );\n    34→\n    35→          return new Response(byteStream, {\n    36→            status: 200,\n    37→            headers: {\n    38→              'Content-Type': 'text/html; charset=utf-8',\n    39→              'Cache-Control': 'private, max-age=60, stale-while-revalidate=30'\n    40→            }\n    41→          });\n    42→        } catch (error) {\n    43→          if (error instanceof ZodError) {\n    44→            return errorsResponses['BadRequest'](JSON.stringify(error.issues));\n    45→          }\n    46→          throw error;\n    47→        }\n    48→      },\n    49→\n    50→      POST: async ({ request }: { request: Request }) => {\n    51→        try {\n    52→          const body = await request.json();\n    53→\n    54→          if (typeof body !== 'object' || body === null) {\n    55→            return errorsResponses['BadRequest']('Request body must be a JSON object.');\n    56→          }\n    57→\n    58→          const clientRequestId = Reflect.get(body, 'clientRequestId');\n    59→\n    60→          if (typeof clientRequestId !== 'string' || clientRequestId.trim().length === 0) {\n    61→            return errorsResponses['BadRequest']('Missing required parameter: clientRequestId.');\n    62→          }\n    63→\n    64→          if ('isWarmup' in body && body.isWarmup === true && 'traceId' in body && typeof body.traceId === 'string') {\n    65→            return await warmupConversation({\n    66→              data: {\n    67→                clientRequestId,\n    68→                traceId: body.traceId,\n    69→                conversationId:\n    70→                  'conversationId' in body && typeof body.conversationId === 'string' ? body.conversationId : undefined\n    71→              }\n    72→            });\n    73→          }\n    74→\n    75→          const result = await requestChat({ data: body });\n    76→\n    77→          // Guard: requestChat may return a non-stream error response\n    78→          if (!(result instanceof ReadableStream)) {\n    79→            return result;\n    80→          }\n    81→\n    82→          const stringStream = result;\n    83→          const encoder = new TextEncoder();\n    84→          const byteStream = stringStream.pipeThrough(\n    85→            new TransformStream({\n    86→              transform(chunk, controller) {\n    87→                controller.enqueue(encoder.encode(chunk));\n    88→              }\n    89→            })\n    90→          );\n    91→\n    92→          return new Response(byteStream, {\n    93→            status: 200,\n    94→            headers: {\n    95→              'Content-Type': 'text/html; charset=utf-8',\n    96→              'Cache-Control': 'no-store'\n    97→            }\n    98→          });\n    99→        } catch (error) {\n   100→          if (error instanceof ZodError) {\n   101→            return new Response(JSON.stringify({ errors: error.issues }), {\n   102→              status: 400,\n   103→              headers: { 'Content-Type': 'application/json' }\n   104→            });\n   105→          }\n   106→          return new Response(JSON.stringify({ error: 'Internal Server Error' }), {\n   107→            status: 500,\n   108→            headers: { 'Content-Type': 'application/json' }\n   109→          });\n   110→        }\n   111→      }\n   112→    }\n   113→  }\n   114→});\n   115→"}]},"parent_tool_use_id":"toolu_01DLPgnTkmGzXzsDrb5HSUSt","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"58d703da-be67-4c9d-bf51-110c4101c16d"}
