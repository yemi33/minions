{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HxsEAHddV1bFdjVrJgT4cp","type":"tool_result","content":"     1→import type { IClientRuntime, ISession, AnnotationActivationOptions } from '@augloop/runtime-client';\n     2→import { createRuntime } from '@augloop/runtime-client';\n     3→import type { IOperation, ISchemaObject } from '@augloop/types-core';\n     4→import { AddOperation, Document, SignalOperation } from '@augloop/types-core';\n     5→import { v4 as uuidv4 } from 'uuid';\n     6→import { TokenEnvironment } from './token-server';\n     7→import { getAugLoopToken } from './token-server/tokenServerManager';\n     8→\n     9→\n    10→const AUGLOOP_ENDPOINTS: Record<TokenEnvironment, string> = {\n    11→    Dev: 'http://localhost:11040',\n    12→    Local: 'http://localhost:11040',\n    13→    Test: 'https://test.augloop.svc.cloud.dev.microsoft',\n    14→    Int: 'https://int.augloop.svc.cloud.dev.microsoft',\n    15→    Dogfood: 'https://dogfood.augloop.svc.cloud.microsoft',\n    16→    MSIT: 'https://msit.augloop.svc.cloud.microsoft',\n    17→    Prod: 'https://augloop.svc.cloud.microsoft',\n    18→    UsGov: 'https://augloop.gov.online.office365.us',\n    19→    Gallatin: 'https://augloop.microsoftonline.cn'\n    20→};\n    21→\n    22→/**\n    23→ * Get an authentication token for Augloop API requests\n    24→ * @param environment - The AugLoop environment to use\n    25→ * @returns The auth token or null if failed\n    26→ */\n    27→async function getAugLoopAuthToken(environment: TokenEnvironment): Promise<string | null> {\n    28→    try {\n    29→        const authToken = await getAugLoopToken({ environment });\n    30→        return authToken ?? null;\n    31→    } catch (error) {\n    32→        console.error('❌ Error fetching AugLoop auth token:', (error as Error).message);\n    33→        return null;\n    34→    }\n    35→}\n    36→\n    37→/**\n    38→ * AugLoop runtime client that encapsulates runtime and session state\n    39→ */\n    40→class AugLoopClient {\n    41→    private runtime: IClientRuntime | undefined;\n    42→    private session: ISession | undefined;\n    43→    private sessionId: string;\n    44→    private annotationCallbacks: Map<string, (annotation: any) => void>;\n    45→    private activatedAnnotationsByType: Map<string, string | undefined>;\n    46→\n    47→    constructor() {\n    48→        this.sessionId = uuidv4();\n    49→        this.annotationCallbacks = new Map();\n    50→        this.activatedAnnotationsByType = new Map();\n    51→    }\n    52→\n    53→    async initialize(\n    54→        environment: TokenEnvironment = TokenEnvironment.Dogfood,\n    55→        flights?: string\n    56→    ): Promise<void> {\n    57→        const endpointUrl = AUGLOOP_ENDPOINTS[environment];\n    58→        console.log(`🌐 Initializing AugLoop client for environment: ${environment} (${endpointUrl})`);\n    59→\n    60→        // Auth token callback\n    61→        const authTokenCallback = async () => {\n    62→            try {\n    63→                const authToken = await getAugLoopAuthToken(environment);\n    64→                return { Token: authToken || '' };\n    65→            } catch (error) {\n    66→                console.error('❌ Failed to get AugLoop access token in callback:', error);\n    67→                return { Token: '' };\n    68→            }\n    69→        };\n    70→\n    71→        return new Promise((resolve, reject) => {\n    72→            this.runtime = createRuntime();\n    73→\n    74→            if (!this.session) {\n    75→                this.runtime?.init(\n    76→                    endpointUrl,\n    77→                    {\n    78→                        appName: 'OfficeAgent',\n    79→                        appPlatform: 'TestClient',\n    80→                        flights,\n    81→                        uiLanguage: 'en-US',\n    82→                    },\n    83→                    {\n    84→                        onAnnotationResult: (op: IOperation) => {\n    85→                            // Process each item in the operation\n    86→                            for (const item of op.items) {\n    87→                                if (item.body) {\n    88→                                    const correlationId = op.parentPath[2]; // Correlation ID from the operation path\n    89→\n    90→                                    // Call specific callback if registered by correlation ID\n    91→                                    if (correlationId && this.annotationCallbacks.has(correlationId)) {\n    92→                                        const callback = this.annotationCallbacks.get(correlationId);\n    93→                                        if (callback) {\n    94→                                            callback(item.body);\n    95→                                        }\n    96→                                    }\n    97→                                }\n    98→                            }\n    99→                        },\n   100→                        sendTelemetryEvent: () => {"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"9d0c4bf6-3e72-4e2e-a41e-8a2a7fd3b240"}
