{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KT6f8M2nfpzkcupviVqHkJ","type":"tool_result","content":"     1→/**\n     2→ * Claude Agent SDK Hooks Framework\n     3→ */\n     4→\n     5→import { Options } from '@anthropic-ai/claude-agent-sdk';\n     6→import { SessionContext, TurnContext } from './types';\n     7→\n     8→/**\n     9→ * Agent hooks interface - combines Claude SDK hooks with lifecycle hooks\n    10→ */\n    11→export interface AgentHooks {\n    12→    /** Claude SDK hooks ready to be used in Options.hooks */\n    13→    claude: Options['hooks'];\n    14→    /** Optional hook called at the start of a new turn, after turn directory creation */\n    15→    startTurn?: (turnContext: TurnContext) => Promise<void>;\n    16→    /** Optional hook called before file watcher starts */\n    17→    preFileWatcherStart?: () => Promise<void>;\n    18→}\n    19→\n    20→/**\n    21→ * Hook provider interface - implemented by hook modules\n    22→ *\n    23→ * Returns agent hooks with Claude SDK hooks and lifecycle hooks.\n    24→ */\n    25→export interface HookProvider {\n    26→    /**\n    27→     * Create hooks for a specific session\n    28→     * @param context - Session context containing sessionId, metadata, settings, etc.\n    29→     * @param turnContext - Optional turn context containing workspace manager and turn-specific information\n    30→     * @returns AgentHooks with Claude SDK hooks and lifecycle hooks\n    31→     */\n    32→    createHooks(context: SessionContext, turnContext?: TurnContext): AgentHooks;\n    33→}\n    34→\n    35→/**\n    36→ * Generic registry for hook providers\n    37→ *\n    38→ * Maps arbitrary string keys to hook providers. Keys can be:\n    39→ * - Agent names: 'word', 'excel', 'powerpoint'\n    40→ * - Feature flags: 'feature-advanced-tracking'\n    41→ * - Custom identifiers: 'debug-mode', 'experiment-a'\n    42→ */\n    43→export class HookRegistry {\n    44→    private providers = new Map<string, HookProvider>();\n    45→\n    46→    /**\n    47→     * Register a hook provider with a key\n    48→     *\n    49→     * @param key - Arbitrary string key (case-sensitive)\n    50→     * @param provider - Hook provider implementation\n    51→     *\n    52→     * Example:\n    53→     * ```typescript\n    54→     * registry.register('word', new WordHooksProvider());\n    55→     * ```\n    56→     */\n    57→    register(key: string, provider: HookProvider): void {\n    58→        this.providers.set(key, provider);\n    59→    }\n    60→\n    61→    /**\n    62→     * Get hooks for a specific key and session\n    63→     *\n    64→     * @param key - Hook key\n    65→     * @param context - Session context\n    66→     * @param turnContext - Optional turn context containing workspace manager and turn-specific information\n    67→     * @returns AgentHooks with Claude SDK hooks and lifecycle hooks, or default empty structure if key not found\n    68→     */\n    69→    getHooks(key: string, context: SessionContext, turnContext?: TurnContext): AgentHooks {\n    70→        const provider = this.providers.get(key);\n    71→        return provider?.createHooks(context, turnContext) ?? { claude: {} };\n    72→    }\n    73→\n    74→    /**\n    75→     * Check if a key has registered hooks\n    76→     *\n    77→     * @param key - Hook key to check\n    78→     * @returns true if hooks are registered for this key\n    79→     */\n    80→    has(key: string): boolean {\n    81→        return this.providers.has(key);\n    82→    }\n    83→\n    84→    /**\n    85→     * Get all registered keys\n    86→     *\n    87→     * @returns Array of all registered hook keys\n    88→     */\n    89→    getKeys(): string[] {\n    90→        return Array.from(this.providers.keys());\n    91→    }\n    92→\n    93→    /**\n    94→     * Get the number of registered hook providers\n    95→     */\n    96→    get size(): number {\n    97→        return this.providers.size;\n    98→    }\n    99→\n   100→    /**"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"a2ff6216-74eb-4d52-9d21-37384893e538"}
