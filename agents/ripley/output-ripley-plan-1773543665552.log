{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015GpiTVcYT8YGAA93E6EKAY","type":"tool_result","content":"     1→/**\n     2→ * Claude Agent SDK orchestrator provider.\n     3→ *\n     4→ * Adapts the Claude Agent SDK's streaming query() API into the unified\n     5→ * IOrchestrator interface, normalizing messages and collecting results.\n     6→ *\n     7→ * Supports both batch mode (run → Promise) and streaming mode (runStream → AsyncIterable).\n     8→ */\n     9→\n    10→import claude, { Options, SDKMessage, SDKResultSuccess, SDKResultError, SDKUserMessage } from '@anthropic-ai/claude-agent-sdk';\n    11→import {\n    12→    OrchestratorRequest,\n    13→    OrchestratorResult,\n    14→    OrchestratorMessage,\n    15→    OrchestratorUsage,\n    16→    GenericToolHooks,\n    17→} from '../types';\n    18→import { toClaudeHooks, mergeWithClaudeHooks } from '../hooks/claude-hook-adapter';\n    19→import { BaseOrchestrator } from './base-orchestrator';\n    20→\n    21→export class ClaudeOrchestrator extends BaseOrchestrator {\n    22→\n    23→    /** Reference to the current query iterator for interrupt support */\n    24→    private currentQueryIterator: AsyncIterable<SDKMessage> & { interrupt?: () => void } | null = null;\n    25→\n    26→    /**\n    27→     * Execute a prompt and stream normalized messages as they arrive.\n    28→     *\n    29→     * Yields OrchestratorMessage objects for each SDK message, ending with\n    30→     * a 'result'-type message containing the embedded OrchestratorResult.\n    31→     */\n    32→    async *runStream(request: OrchestratorRequest): AsyncIterable<OrchestratorMessage> {\n    33→        const options = this.buildOptions(request);\n    34→\n    35→        let sessionId: string | undefined;\n    36→\n    37→        const prompt = request.userContext\n    38→            ? this.buildPromptWithContext(request.userContext, request.prompt)\n    39→            : request.prompt;\n    40→        const messageStream = claude.query({ prompt, options });\n    41→        this.currentQueryIterator = messageStream;\n    42→\n    43→        try {\n    44→            for await (const message of messageStream) {\n    45→                // Capture session ID from the init system message\n    46→                if (message.type === 'system' && 'subtype' in message && message.subtype === 'init') {\n    47→                    sessionId = message.session_id;\n    48→                }\n    49→\n    50→                // Normalize and yield each message\n    51→                const normalized = this.toOrchestratorMessage(message, sessionId);\n    52→                if (normalized) {\n    53→                    yield normalized;\n    54→                }\n    55→            }\n    56→        } finally {\n    57→            this.currentQueryIterator = null;\n    58→        }\n    59→    }\n    60→\n    61→    /**\n    62→     * Interrupt the currently running orchestrator execution.\n    63→     */\n    64→    async interrupt(): Promise<void> {\n    65→        if (this.currentQueryIterator && 'interrupt' in this.currentQueryIterator) {\n    66→            (this.currentQueryIterator as any).interrupt();\n    67→        }\n    68→    }\n    69→\n    70→    /**\n    71→     * Build an async generator that yields user context as a user message\n    72→     * followed by the main user query, allowing context injection without\n    73→     * requiring the agent to read it from disk via a tool call.\n    74→     */\n    75→    private async *buildPromptWithContext(userContext: string, userQuery: string): AsyncIterable<SDKUserMessage> {\n    76→        const sessionId = crypto.randomUUID();\n    77→        yield {\n    78→            type: 'user',\n    79→            message: {\n    80→                role: 'user', content: [\n    81→                    { type: 'text', text: `<user-context>\\n${userContext}\\n</user-context>` },\n    82→                    { type: 'text', text: `<user-query>\\n${userQuery}\\n</user-query>` },\n    83→                ]\n    84→            },\n    85→            parent_tool_use_id: null,\n    86→            session_id: sessionId,\n    87→        };\n    88→    }\n    89→\n    90→    /**\n    91→     * Map OrchestratorRequest fields to Claude SDK Options.\n    92→     *\n    93→     * Handles generic-to-Claude hook adaptation:\n    94→     * - If request.toolHooks is provided, adapts GenericToolHooks → Claude format\n    95→     * - Merges with any existing Claude hooks from providerOptions\n    96→     * - Provider-specific fields from `providerOptions` are spread last to allow overrides\n    97→     */\n    98→    private buildOptions(request: OrchestratorRequest): Options {\n    99→        const options: Options = {};\n   100→\n   101→        if (request.model) options.model = request.model;\n   102→        if (request.maxTurns) options.maxTurns = request.maxTurns;\n   103→        // GHCP uses 'xhigh'; Claude SDK expects 'max' for the same tier. 'max' passes through.\n   104→        if (request.reasoningEffort) {\n   105→            options.effort = request.reasoningEffort === 'xhigh' ? 'max' : request.reasoningEffort;\n   106→        }\n   107→        if (request.allowedTools) options.allowedTools = request.allowedTools;\n   108→        if (request.disallowedTools) options.disallowedTools = request.disallowedTools;\n   109→        if (request.cwd) options.cwd = request.cwd;\n   110→        if (request.abortController) options.abortController = request.abortController;\n   111→        if (request.systemPrompt) options.systemPrompt = request.systemPrompt;\n   112→        if (request.sessionId) (options as any).resume = request.sessionId;\n   113→\n   114→        // Claude-specific: read `continue` from providerOptions\n   115→        if (request.providerOptions?.continue !== undefined) {\n   116→            (options as any).continue = request.providerOptions.continue;\n   117→        }\n   118→\n   119→        if (request.env) {\n   120→            options.env = { ...process.env, ...request.env };\n   121→        }\n   122→\n   123→        // Merge provider-specific options (e.g. `stderr`, `settingSources`, `permissionMode`)\n   124→        if (request.providerOptions) {\n   125→            Object.assign(options, request.providerOptions);\n   126→        }\n   127→\n   128→        // Adapt generic tool hooks to Claude SDK format\n   129→        if (request.toolHooks) {\n   130→            const existingClaudeHooks = options.hooks ?? {};\n   131→            options.hooks = mergeWithClaudeHooks(existingClaudeHooks, request.toolHooks);\n   132→        }\n   133→\n   134→        return options;\n   135→    }\n   136→\n   137→    /**\n   138→     * Normalize a raw SDK message into the provider-agnostic OrchestratorMessage format.\n   139→     * Returns null for message types that should not be forwarded.\n   140→     */\n   141→    private toOrchestratorMessage(message: SDKMessage, sessionId?: string): OrchestratorMessage | null {\n   142→        switch (message.type) {\n   143→            case 'assistant':\n   144→                return {\n   145→                    type: 'assistant',\n   146→                    content: this.extractAssistantText(message),\n   147→                    raw: message,\n   148→                };\n   149→            case 'result': {\n   150→                const resultMsg = message as SDKResultSuccess | SDKResultError;"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"18e943f8-97d1-4f9f-9a45-922669fc8104"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PtgEkHog6N2nqS2nwGq7KU","type":"tool_result","content":"     1→/**\n     2→ * Orchestrator factory with provider registration pattern.\n     3→ *\n     4→ * Partner teams call `registerProvider()` to add new harnesses.\n     5→ * Built-in providers (Claude, Copilot) auto-register at module load.\n     6→ */\n     7→\n     8→import { IOrchestrator } from './types';\n     9→import { ClaudeOrchestrator } from './providers';\n    10→\n    11→// ---------------------------------------------------------------------------\n    12→// Types\n    13→// ---------------------------------------------------------------------------\n    14→\n    15→/**\n    16→ * Supported orchestrator harness types.\n    17→ */\n    18→export type HarnessType = 'claude' | 'ghcp';\n    19→\n    20→/** Factory function that creates an IOrchestrator given optional config. */\n    21→export type OrchestratorFactory = (config?: Record<string, unknown>) => IOrchestrator;\n    22→\n    23→// ---------------------------------------------------------------------------\n    24→// Registry\n    25→// ---------------------------------------------------------------------------\n    26→\n    27→const providerRegistry = new Map<string, OrchestratorFactory>();\n    28→\n    29→/**\n    30→ * Register a provider factory. Partner teams call this to add new harnesses.\n    31→ *\n    32→ * @param type - Unique string identifier for the provider\n    33→ * @param factory - Function that creates a new IOrchestrator instance\n    34→ * @throws If a provider with the same type is already registered\n    35→ *\n    36→ * @example\n    37→ * ```typescript\n    38→ * import { registerProvider } from '@officeagent/orchestrator';\n    39→ * registerProvider('github-copilot', (config) => new GitHubCopilotOrchestrator(config));\n    40→ * ```\n    41→ */\n    42→export function registerProvider(type: string, factory: OrchestratorFactory): void {\n    43→    if (providerRegistry.has(type)) {\n    44→        throw new Error(\n    45→            `Orchestrator provider '${type}' is already registered. ` +\n    46→            `Use a unique type name or call unregisterProvider('${type}') first.`\n    47→        );\n    48→    }\n    49→    providerRegistry.set(type, factory);\n    50→}\n    51→\n    52→/**\n    53→ * Unregister a previously registered provider. Primarily useful for testing.\n    54→ *\n    55→ * @param type - The provider type to remove\n    56→ * @returns true if the provider was removed, false if it wasn't registered\n    57→ */\n    58→export function unregisterProvider(type: string): boolean {\n    59→    return providerRegistry.delete(type);\n    60→}\n    61→\n    62→/**\n    63→ * List all registered provider type names.\n    64→ *\n    65→ * @returns Array of registered provider type strings\n    66→ */\n    67→export function listProviders(): string[] {\n    68→    return [...providerRegistry.keys()];\n    69→}\n    70→\n    71→/**\n    72→ * Create an orchestrator instance by provider type.\n    73→ *\n    74→ * GhcpOrchestrator is lazy-loaded to avoid requiring @github/copilot-sdk\n    75→ * at startup — that package may not be installed in all environments (e.g. Docker).\n    76→ *\n    77→ * @param type - The orchestrator provider to instantiate\n    78→ * @param config - Optional configuration passed to the provider factory\n    79→ * @returns A new IOrchestrator instance\n    80→ * @throws If no provider is registered for the given type\n    81→ *\n    82→ * @example\n    83→ * ```typescript\n    84→ * const orchestrator = createOrchestrator('claude');\n    85→ * const result = await orchestrator.run({ prompt: 'Hello', model: 'claude-sonnet-4-5-20250929' });\n    86→ *\n    87→ * const ghcp = createOrchestrator('ghcp');\n    88→ * const result2 = await ghcp.run({ prompt: 'Hello' });\n    89→ * ```\n    90→ */\n    91→export function createOrchestrator(type: HarnessType, config?: Record<string, unknown>): IOrchestrator {\n    92→    const factory = providerRegistry.get(type);\n    93→    if (!factory) {\n    94→        const registered = listProviders();\n    95→        throw new Error(\n    96→            `Unknown orchestrator type: '${type}'. ` +\n    97→            `Registered providers: [${registered.join(', ')}]`\n    98→        );\n    99→    }\n   100→    return factory(config);\n   101→}\n   102→\n   103→// ---------------------------------------------------------------------------\n   104→// Built-in provider registration\n   105→// ---------------------------------------------------------------------------\n   106→\n   107→registerProvider('claude', () => new ClaudeOrchestrator());\n   108→\n   109→// Lazy-load ghcp to avoid eagerly requiring @github/copilot-sdk\n   110→// (that package may not be installed in all environments, e.g. Docker).\n   111→registerProvider('ghcp', () => {\n   112→    const { GhcpOrchestrator } = require('./providers/ghcp-orchestrator');\n   113→    return new GhcpOrchestrator();\n   114→});\n   115→"}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"b8e0af49-8e72-478a-bff4-8d1788b380c7"}
