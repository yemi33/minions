{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ND4Erk2jFcKhiK3auzY5ho","type":"tool_result","content":"     1→import { encodeJsonScriptTag } from '@bebopjs/bebop-conversation-orchestrator';\n     2→import type { ParserResult } from '@bebopjs/bebop-response-parser';\n     3→\n     4→export const emitResultToStream = (\n     5→  result: ParserResult | null,\n     6→  controller: ReadableStreamDefaultController<string>\n     7→): void => {\n     8→  if (result) {\n     9→    const output = result.html + result.mutations.join('');\n    10→\n    11→    if (output) {\n    12→      controller.enqueue(output);\n    13→    }\n    14→  }\n    15→};\n    16→\n    17→export type ConversationState = {\n    18→  conversationId: string;\n    19→};\n    20→export const emitConversationState = (\n    21→  conversationState: ConversationState,\n    22→  controller: ReadableStreamDefaultController<string>\n    23→): void => {\n    24→  controller.enqueue(`\\n${encodeJsonScriptTag(conversationState, 'conversation')}\\n`);\n    25→};\n    26→\n    27→// JSON.stringify serializes non-finite numbers (NaN / Infinity / -Infinity) as null,\n    28→// which would silently corrupt metrics values. This replacer preserves them as strings.\n    29→const sanitizeNonFinite = (_key: string, value: unknown): unknown =>\n    30→  typeof value === 'number' && !Number.isFinite(value) ? value.toString() : value;\n    31→\n    32→export const emitServerMetrics = (\n    33→  metrics: Record<string, number>,\n    34→  controller: ReadableStreamDefaultController<string>\n    35→): void => {\n    36→  controller.enqueue(`\\n${encodeJsonScriptTag(metrics, 'serverMetrics', sanitizeNonFinite)}\\n`);\n    37→};\n    38→\n    39→export const emitTraceResults = (\n    40→  traceResults: Record<string, unknown>,\n    41→  controller: ReadableStreamDefaultController<string>\n    42→): void => {\n    43→  controller.enqueue(`\\n${encodeJsonScriptTag(traceResults, 'traceResults')}\\n`);\n    44→};\n    45→"}]},"parent_tool_use_id":"toolu_01DLPgnTkmGzXzsDrb5HSUSt","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"a963d30c-32f5-4745-878a-1bdc0b062004"}
