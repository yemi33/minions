{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WG1iKMixhXzVNUnKCiSK1v","type":"tool_result","content":"C:/Users/yemishin/OfficeAgent/modules/core/src/agent/claude-hooks.ts:export interface HookProvider {\nC:/Users/yemishin/OfficeAgent/modules/core/src/agent/claude-hooks.ts:export class HookRegistry {\nC:/Users/yemishin/OfficeAgent/modules/core/src/agent/claude-hooks.ts:    private providers = new Map<string, HookProvider>();\nC:/Users/yemishin/OfficeAgent/modules/core/src/agent/claude-hooks.ts:    register(key: string, provider: HookProvider): void {\nC:/Users/yemishin/OfficeAgent/modules/core/src/agent/claude-hooks.ts:    getProvider(key: string): HookProvider | undefined {\nC:/Users/yemishin/OfficeAgent/modules/core/src/agent/claude-hooks.ts:    constructor(private registry: HookRegistry) { }\nC:/Users/yemishin/OfficeAgent/modules/core/src/agent/claude-hooks.ts:    registry: HookRegistry,\nC:/Users/yemishin/OfficeAgent/modules/core/src/agent/cross-turn-hooks.ts: * These utilities are agent-agnostic. Each agent creates a thin HookProvider","is_error":false}]},"parent_tool_use_id":"toolu_01TKCt5XCBDve7zLFaUYAVs5","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"bd270f0e-5e0c-40c3-ad4b-06df1e1a6e9b"}
