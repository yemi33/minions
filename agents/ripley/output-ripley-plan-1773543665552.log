   finalConversationId = warmupResult.conversationId;\n   243→    }\n   244→\n   245→    // Check if conversation is already processing a request\n   246→    if (activeConversations.has(finalConversationId)) {\n   247→        logInfo(0x1e0dc1c5 /* tag_4d2hf */, `🚫 Conversation ${finalConversationId} is already processing a request, discarding incoming requestId = ${finalRequestId}`);\n   248→        return res.status(429).json({\n   249→            success: false,\n   250→            error: 'CONVERSATION_BUSY',\n   251→            message: `Conversation ${finalConversationId} is already processing a request. Please wait for completion.`,\n   252→            conversationId: finalConversationId\n   253→        });\n   254→    }\n   255→\n   256→    // Mark conversation as active\n   257→    activeConversations.add(finalConversationId);\n   258→\n   259→    logInfo(0x1e0dc1c4 /* tag_4d2he */, 'Waiting for session initialization to complete');\n   260→    await sessionInitCompletePromise;\n   261→    setCurrentQueryContextForLogging({\n   262→        conversationId: finalConversationId,\n   263→        requestId: finalRequestId,\n   264→        traceId: getTraceIdFromHeaders(req.headers)\n   265→    });\n   266→\n   267→    // Parse grounding content for clarification questions\n   268→    const groundingContentParsed = parseGroundingContent(groundingContent);\n   269→\n   270→    // Handle flag-based flight enablement\n   271→    let processedUserQuery = `User Query: ${userQuery}\\n${groundingContentParsed ? ('Additional Context: ' + groundingContentParsed) : ''}`;\n   272→\n   273→    // Check for -enableEnterpriseSearchV2 flag\n   274→    const enterpriseSearchResult = checkAndEnableFlightFlag(\n   275→        userQuery,\n   276→        processedUserQuery,\n   277→        '-enableEnterpriseSearchV2',\n   278→        'OfficeAgent.EnableEnterpriseSubstrateStrategy',\n   279→    );\n   280→    const hasEnterpriseSearchV2Flag = enterpriseSearchResult.hasFlag;\n   281→   