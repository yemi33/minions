{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sbm3GhzHsskWGWYBvamyiq","type":"tool_result","content":"     1→// llm-proxy-handler.ts\n     2→// LLM API proxy handler\n     3→// This handler creates a local HTTP server that mimics LLM APIs (like Anthropic's Claude)\n     4→// but routes requests through WebSocket to an external client with internet access\n     5→\n     6→import {\n     7→    LLMRequestMessage,\n     8→    LLMResponseType, MessageType\n     9→} from '@officeagent/message-protocol';\n    10→import { Application, Request, Response } from 'express';\n    11→import { v4 as uuidv4 } from 'uuid';\n    12→import { logError, logWarn, OfficeAgentSettingsManager, wsRouter, wsManager, logInfo } from '@officeagent/core';\n    13→import { logLLMRequest, logLLMResponse, logCompletionReason } from './llm-logger';\n    14→\n    15→// Configuration constants\n    16→const MAX_PENDING_REQUESTS = 1000;\n    17→const REQUEST_TIMEOUT_MS = 60 * 60 * 1000; // 60 minutes\n    18→\n    19→interface PendingRequest {\n    20→    res: Response;\n    21→    isStreaming: boolean;\n    22→    timeout: NodeJS.Timeout;\n    23→}\n    24→\n    25→// Pending requests: requestId -> PendingRequest\n    26→const pendingWsRequests = new Map<string, PendingRequest>();\n    27→\n    28→// Settings getter function (initialized during registration)\n    29→let getSettingsManager: (() => OfficeAgentSettingsManager) | null = null;\n    30→\n    31→/**\n    32→ * Create a simple LLM request message for WebSocket routing\n    33→ */\n    34→function createLLMRequest(reqBody: any, requestId: string, sessionId: string): LLMRequestMessage {\n    35→    const isOverrideMaxTokensEnabled = getSettingsManager?.()?.changeGate('OverrideMaxTokens') ?? false;\n    36→    if (isOverrideMaxTokensEnabled) {\n    37→        try {\n    38→            // Override Claude LLM request max_tokens.\n    39→            // This is a way to get around limitation in GHCP SDK. GHCP SDK does not let us set max_tokens and this is causing frequent failures\n    40→            if (isClaudeModel(reqBody?.model) && process.env.OFFICEAGENT_CLAUDE_MAX_TOKENS) {\n    41→                const envMaxTokens = parseInt(process.env.OFFICEAGENT_CLAUDE_MAX_TOKENS, 10);\n    42→                const currMaxTokens = reqBody.max_tokens ? parseInt(reqBody.max_tokens, 10) : 0;\n    43→                if (!isNaN(envMaxTokens) && currMaxTokens < envMaxTokens) {\n    44→                    logInfo(0x1e04031d /* tag_4bam3 */, `Updating request body max_tokens from ${currMaxTokens} to $ ${envMaxTokens}`);\n    45→                    reqBody.max_tokens = envMaxTokens;\n    46→                }\n    47→            }\n    48→        } catch (_e) {\n    49→            logWarn(0x1e04031c /* tag_4bam2 */, 'Error occurred while updating request body max_tokens');\n    50→        }\n    51→    }\n    52→    return {\n    53→        id: requestId,\n    54→        type: MessageType.LLMRequest,\n    55→        sessionId: sessionId,\n    56→        payload: {\n    57→            body: reqBody\n    58→        }\n    59→    };\n    60→}\n    61→\n    62→/** Returns true when the (already-mapped) model name is an Opus or Sonnet variant. */\n    63→function isClaudeModel(model: string | undefined): boolean {\n    64→    if (!model) return false;\n    65→    const m = model.toLowerCase();\n    66→    return m.includes('opus') || m.includes('sonnet');\n    67→}\n    68→\n    69→/**\n    70→ * Handles LLM response messages from WebSocket clients\n    71→ * Routes responses back to the appropriate HTTP response\n    72→ * Implements rate limiting by queueing function calls for 429 responses\n    73→ */\n    74→async function handleLLMResponse(message: any): Promise<boolean> {\n    75→    if (message.type !== MessageType.LLMResponse) {\n    76→        return false; // Not an LLM response message\n    77→    }\n    78→\n    79→    // Use requestId from protocol contract for response correlation\n    80→    if (!message.requestId || !pendingWsRequests.has(message.requestId)) {\n    81→        logWarn(0x1e0dc0c4 /* tag_4d2de */, 'Received LLM response for unknown request ID:', message.requestId);\n    82→        return true; // We handled it, even if we couldn't process it\n    83→    }\n    84→\n    85→    const { res, timeout } = pendingWsRequests.get(message.requestId)!;\n    86→    clearTimeout(timeout);\n    87→\n    88→    // Check if rate limiting is enabled and handle accordingly\n    89→    const isRateLimitingEnabled = getSettingsManager?.()?.changeGate('EnableRateLimiting') ?? false;\n    90→    if (isRateLimitingEnabled && delayExecutionIfThrottled(message, res)) {\n    91→        return true; // Queued for delayed execution\n    92→    }\n    93→\n    94→    // No rate limiting - execute immediately\n    95→    const responseType = message.payload?.responseType;\n    96→    switch (responseType) {\n    97→        case LLMResponseType.Start:\n    98→        case LLMResponseType.Chunk:\n    99→        case LLMResponseType.Complete:\n   100→            handleStreamingResponse(message, res);\n   101→            break;\n   102→        case LLMResponseType.Final:\n   103→        default:\n   104→            handleNonStreamingResponse(message, res);\n   105→            break;\n   106→    }\n   107→\n   108→    return true;\n   109→}\n   110→\n   111→/**\n   112→ * Handles streaming responses by writing SSE chunks directly to the HTTP response\n   113→ */\n   114→function handleStreamingResponse(data: any, res: Response): void {\n   115→    const responseType = data.payload?.responseType;\n   116→\n   117→    if (responseType === LLMResponseType.Start) {\n   118→        // Set Anthropic-like headers for streaming response\n   119→        const defaultHeaders: Record<string, any> = {\n   120→            'Content-Type': 'text/event-stream; charset=utf-8',\n   121→            'Cache-Control': 'no-cache',\n   122→            'Connection': 'close',\n   123→            'X-RequestId': data.requestId || '',\n   124→            'X-ModelName': data.model || '',\n   125→            'X-ModelVersion': 'Proxy',\n   126→            'X-ModelLatency': data.modelLatency || '',\n   127→            'X-Powered-By': undefined, // Remove Express default\n   128→            ...((data.payload.headers && typeof data.payload.headers === 'object') ? data.payload.headers : {})\n   129→        };\n   130→\n   131→        // Remove undefined headers\n   132→        Object.keys(defaultHeaders).forEach(k =>\n   133→            defaultHeaders[k] === undefined && delete defaultHeaders[k]\n   134→        );\n   135→\n   136→        res.writeHead(data.payload.status || 200, defaultHeaders);\n   137→\n   138→    } else if (responseType === LLMResponseType.Chunk && data.payload.body && data.payload.body.raw !== undefined) {\n   139→        // Write the raw SSE chunk as-is\n   140→        res.write(data.payload.body.raw);\n   141→\n   142→    } else if (responseType === LLMResponseType.Complete) {\n   143→        res.write('event: message_stop\\ndata: {}\\n\\n');\n   144→        res.write('data: [DONE]\\n\\n');\n   145→        res.end();\n   146→        pendingWsRequests.delete(data.requestId);\n   147→\n   148→    } else if (data.payload.error) {\n   149→        if (!res.headersSent) {\n   150→            res.status(data.payload.status || 500);\n   151→        }\n   152→        res.write(`event: error\\ndata: {\"error\":${JSON.stringify(data.payload.error)}}\\n\\n`);\n   153→        res.end();\n   154→        pendingWsRequests.delete(data.requestId);\n   155→    }\n   156→}\n   157→\n   158→/**\n   159→ * Handles non-streaming responses by sending JSON directly\n   160→ */\n   161→function handleNonStreamingResponse(data: any, res: Response): void {\n   162→    if (!res.headersSent) {\n   163→        res.status(data.payload.status || 200).json(data.payload.body || data.payload);\n   164→    }\n   165→    pendingWsRequests.delete(data.requestId);\n   166→}\n   167→\n   168→// ============================================================================\n   169→// Rate Limiting for 429 Responses\n   170→// ============================================================================\n   171→// When rate limiting is enabled and a 429 response is received:\n   172→// 1. Queue all calls to handle any messages for that request\n   173→// 2. Wait for retry-after seconds (from 429 response headers)\n   174→// 3. Process all function calls queued in order after the delay\n   175→//\n   176→// This ensures message ordering is preserved while respecting rate limits.\n   177→\n   178→// Queue to store function calls per request waiting for 429 delay\n   179→const functionCallQueues = new Map<string, Array<{ fn: Function; args: any[] }>>();\n   180→const rateLimitTimeouts = new Map<string, NodeJS.Timeout>();\n   181→\n   182→\n   183→/**\n   184→ * Delays execution if request is throttled (429 response)\n   185→ * Returns true if queued for delayed execution, false if should be processed immediately\n   186→ */\n   187→function delayExecutionIfThrottled(message: any, res: Response): boolean {\n   188→    const responseType = message.payload?.responseType;\n   189→    const status = message.payload?.status;\n   190→    const requestId = message.requestId;\n   191→\n   192→    // Determine if this is a 429 response\n   193→    const is429Response = status === 429 &&\n   194→        (responseType === LLMResponseType.Start || responseType === LLMResponseType.Final);\n   195→\n   196→    // If this is a 429 or request already queued, queue this message\n   197→    if (is429Response || functionCallQueues.has(requestId)) {\n   198→        // Determine which handler function to queue\n   199→        let handlerFn: Function;\n   200→        if (responseType === LLMResponseType.Start ||\n   201→            responseType === LLMResponseType.Chunk ||\n   202→            responseType === LLMResponseType.Complete) {\n   203→            handlerFn = handleStreamingResponse;\n   204→        } else {\n   205→            handlerFn = handleNonStreamingResponse;\n   206→        }\n   207→\n   208→        // Queue the function call\n   209→        if (is429Response) {\n   210→            const retryAfterSeconds = parseInt(message.payload?.headers?.['retry-after'], 10) || 15;\n   211→            queueFunctionCall(requestId, handlerFn, [message, res], retryAfterSeconds);\n   212→        } else {\n   213→            queueFunctionCall(requestId, handlerFn, [message, res]);\n   214→        }\n   215→\n   216→        return true; // Queued for delayed execution\n   217→    }\n   218→\n   219→    return false; // Process immediately\n   220→}\n   221→\n   222→/**\n   223→ * Processes queued function calls for a request after rate limit delay\n   224→ */\n   225→function processFunctionQueue(requestId: string): void {\n   226→    const queue = functionCallQueues.get(requestId);\n   227→    if (!queue || queue.length === 0) {\n   228→        return;\n   229→    }\n   230→\n   231→    logWarn(0x1e0dc0c3 /* tag_4d2dd */, `[RateLimit] Processing ${queue.length} queued messages for request ${requestId}`);\n   232→\n   233→    // Check if response is still writable\n   234→    const { res } = pendingWsRequests.get(requestId)!;\n   235→    if (res.writableEnded || res.closed) {\n   236→        cleanupRateLimitData(requestId);\n   237→        return;\n   238→    }\n   239→\n   240→    // Execute all queued function calls in order\n   241→    for (let i = 0; i < queue.length; i++) {\n   242→        const { fn, args } = queue[i];\n   243→\n   244→        try {\n   245→            fn(...args);\n   246→        } catch (err) {\n   247→            logError(0x1e0dc0c2 /* tag_4d2dc */, `[RateLimit] Error executing queued call ${i + 1}/${queue.length}:`, err);\n   248→            // Continue processing remaining calls\n   249→        }\n   250→    }\n   251→\n   252→    // Clean up\n   253→    cleanupRateLimitData(requestId);\n   254→}\n   255→\n   256→/**\n   257→ * Queues a function call for later execution after rate limit delay\n   258→ */\n   259→function queueFunctionCall(requestId: string, fn: Function, args: any[], retryAfterSeconds: number | null = null): void {\n   260→    // Initialize queue if needed\n   261→    if (!functionCallQueues.has(requestId)) {\n   262→        functionCallQueues.set(requestId, []);\n   263→    }\n   264→\n   265→    // Add function call to queue\n   266→    functionCallQueues.get(requestId)!.push({ fn, args });\n   267→\n   268→    // If this is the first queued call, start the timeout\n   269→    if (!rateLimitTimeouts.has(requestId) && retryAfterSeconds !== null) {\n   270→        logWarn(0x1e0dc0c1 /* tag_4d2db */, `[RateLimit] Starting ${retryAfterSeconds}s delay for request ${requestId}`);\n   271→        const timeoutHandle = setTimeout(() => {\n   272→            processFunctionQueue(requestId);\n   273→        }, retryAfterSeconds * 1000);\n   274→        rateLimitTimeouts.set(requestId, timeoutHandle);\n   275→    }\n   276→}\n   277→\n   278→/**\n   279→ * Cleans up rate limiting data for a request\n   280→ */\n   281→function cleanupRateLimitData(requestId: string): void {\n   282→    const rateLimitTimeout = rateLimitTimeouts.get(requestId);\n   283→    if (rateLimitTimeout) {\n   284→        clearTimeout(rateLimitTimeout);\n   285→    }\n   286→    functionCallQueues.delete(requestId);\n   287→    rateLimitTimeouts.delete(requestId);\n   288→}\n   289→\n   290→/**\n   291→ * Registers the LLM API proxy handlers\n   292→ *\n   293→ * @param app - Express application instance\n   294→ * @param getWsClient - Function that returns the current WebSocket client\n   295→ * @param getConversationId - Function that returns the current conversation ID\n   296→ * @param getLogsDir - Function that returns the current output directory (for logging)\n   297→ * @param getSettings - Function that returns the settings manager\n   298→ */\n   299→function registerLLMProxyHandlers(\n   300→    app: Application,\n   301→    getConversationId: () => string | null,\n   302→    getLogsDir: () => string | null,\n   303→    getSettings: () => OfficeAgentSettingsManager\n   304→): void {\n   305→    // Store settings getter function for rate limiting\n   306→    getSettingsManager = getSettings;\n   307→\n   308→    // Create a wrapper handler that logs responses with output directory access\n   309→    const handleLLMResponseWithLogging = async (message: any): Promise<boolean> => {\n   310→        const result = await handleLLMResponse(message);\n   311→\n   312→        // Log the response if it was handled successfully and we have an output directory\n   313→        if (result && message.type === MessageType.LLMResponse) {\n   314→            const logsDir = getLogsDir();\n   315→            if (logsDir) {\n   316→                try {\n   317→                    logLLMResponse(message, logsDir);\n   318→                } catch (err) {\n   319→                    logError(0x1e0dc0c0 /* tag_4d2da */, 'Error logging LLM response:', err);\n   320→                }\n   321→            }\n   322→            const responseType = message.payload?.responseType;\n   323→            if (responseType === LLMResponseType.Final || responseType === LLMResponseType.Complete) {\n   324→                logCompletionReason(message);\n   325→            }\n   326→        }\n   327→\n   328→        return result;\n   329→    };\n   330→\n   331→    // Register WebSocket message handler with the global router\n   332→    wsRouter.registerHandler(MessageType.LLMResponse, handleLLMResponseWithLogging);\n   333→\n   334→    // HTTP handler - mimics LLM API /v1/messages endpoint (compatible with Anthropic Claude)\n   335→    app.post('/v1/messages', async (req: Request, res: Response) => {\n   336→        const requestId = uuidv4();\n   337→        // Use conversationId from getter if available, otherwise generate a session-specific ID\n   338→        const sessionId = getConversationId() || `http-session-${Date.now()}`;\n   339→        const wsPayload = createLLMRequest(req.body, requestId, sessionId);\n   340→        const isStreaming = req.body && req.body.stream === true;\n   341→\n   342→        // Write request payload to log file (in logsDir, not workspaceDir)\n   343→        const logsDir = getLogsDir();\n   344→        await logLLMRequest(wsPayload, logsDir);\n   345→\n   346→        // Note: Original request headers are not passed through as not needed yet\n   347→        // External client handles its own authentication and routing\n   348→\n   349→        // Set up timeout for the request\n   350→        const timeout = setTimeout(() => {\n   351→            if (pendingWsRequests.has(requestId)) {\n   352→                const { res } = pendingWsRequests.get(requestId)!;\n   353→                if (!res.headersSent) {\n   354→                    res.status(504).json({\n   355→                        error: 'Timeout waiting for WebSocket client response'\n   356→                    });\n   357→                }\n   358→                pendingWsRequests.delete(requestId);\n   359→\n   360→                // Clean up rate limiting data if request times out\n   361→                cleanupRateLimitData(requestId);\n   362→            }\n   363→        }, REQUEST_TIMEOUT_MS);\n   364→\n   365→        // Track the pending request\n   366→        pendingWsRequests.set(requestId, { res, isStreaming, timeout });\n   367→\n   368→        // Validate the WebSocket is ready\n   369→        if (!wsManager.isConnected()) {\n   370→            clearTimeout(timeout);\n   371→            pendingWsRequests.delete(requestId);\n   372→            return res.status(503).json({\n   373→                error: 'No WebSocket client connected'\n   374→            });\n   375→        }\n   376→\n   377→        // Check if we're at capacity\n   378→        if (pendingWsRequests.size >= MAX_PENDING_REQUESTS) {\n   379→            clearTimeout(timeout);\n   380→            pendingWsRequests.delete(requestId);\n   381→            return res.status(429).json({\n   382→                error: 'Too many pending requests',\n   383→                retry_after: 5\n   384→            });\n   385→        }\n   386→\n   387→        // Forward the request to the WebSocket client\n   388→        wsManager.sendMessage(wsPayload);\n   389→    });\n   390→}\n   391→\n   392→// Export the main functionality and configuration\n   393→export {\n   394→    registerLLMProxyHandlers,\n   395→    createLLMRequest,\n   396→    pendingWsRequests,\n   397→    cleanupRateLimitData,\n   398→    type PendingRequest\n   399→};\n   400→"}]},"parent_tool_use_id":"toolu_01AJXnfzeHR2byH3TcFHovhb","session_id":"d982c5f4-98da-4461-b748-c7175dcade88","uuid":"f3f763cb-67bc-4ae4-aee1-60c00fd2076f"}
