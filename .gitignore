# Agent runtime state (regenerated per dispatch)
agents/*/status.json
agents/*/output.log
agents/*/output-*
agents/*/live-output.log
agents/*/live-output-prev.log
agents/*/history.md
agents/*/session.json
agents/temp-*/
identity/now.md

# Runtime data (generated by engine, machine-specific)
knowledge/**
!knowledge/.gitkeep
notes/inbox/*
!notes/inbox/.gitkeep
notes/archive/*
!notes/archive/.gitkeep
notes.md
projects/*
!projects/*/
projects/*/*
work-items.json
work-items-archive.json
work-items.json.backup
config.json
pinned.md

# Meeting state (runtime, generated by engine)
meetings/

# Pipelines (runtime, user-created on each machine)
pipelines/

# Plan-generated PRDs (minions-internal work records)
plans/

# Machine-specific (synced from ~/.claude.json on engine start)
mcp-servers.json

# PRDs and their artifacts
prd/*.json
prd/*.bak
prd/*.backup
prd/archive/
prd/guides/

