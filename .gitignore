.minions/
.squad/
.minions-version
.minions-commit
worktrees/
reports/

# Windows artifacts
NUL

# Temp/scratch files
tmp-*.json
tmp_*.json
*.png
squad*pull-requests.json
D?squad*

# Test output
test-results/
test/playwright/report/

# Dependencies
node_modules/

# Agent runtime state — only charter.md is tracked under each agent
agents/*/*
!agents/*/charter.md

# Untracked agent worktree drops (e.g. agents/pr-1890-conflict/)
